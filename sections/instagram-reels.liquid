    { "type": "range",  "id": "tag_pad_x",   "label": "Tag padding X (px)",           "min": 4, "max": 20,  "step": 1, "default": 10 },
    { "type": "range",  "id": "tag_radius",  "label": "Tag border radius (px)",       "min": 0, "max": 30,  "step": 1, "default": 4 },
    { "type": "checkbox","id": "show_dot",   "label": "Show dot",                     "default": true },
    { "type": "color",  "id": "dot_color",   "label": "Dot color",                    "default": "#3b5bdb" },
    { "type": "range",  "id": "dot_size",    "label": "Dot size (px)",                "min": 4, "max": 12,  "step": 1, "default": 7 },

    {
      "type": "header",
      "content": "Play Button"
    },
    { "type": "checkbox","id": "show_play",       "label": "Show play button",         "default": true },
    { "type": "range",   "id": "play_size",       "label": "Button size (px)",          "min": 20,"max": 60, "step": 2, "default": 32 },
    { "type": "range",   "id": "play_icon_size",  "label": "Icon size (px)",            "min": 8, "max": 30, "step": 1, "default": 12 },
    { "type": "color",   "id": "play_bg",         "label": "Button background",         "default": "#1a1a1a" },
    { "type": "color",   "id": "play_icon_color", "label": "Icon color",                "default": "#ffffff" },

    {
      "type": "header",
      "content": "Caption"
    },
    { "type": "range",  "id": "caption_bottom", "label": "Caption distance from bottom (px)", "min": 8, "max": 40, "step": 2, "default": 14 },
