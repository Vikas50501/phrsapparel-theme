{% style %}
  #shopify-section-{{ section.id }} .reels-section {
    background: {{ section.settings.section_bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .reels-section__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding: 0 {{ section.settings.section_h_padding }}px {{ section.settings.head_gap }}px;
  }

  #shopify-section-{{ section.id }} .reels-section__head .reels-head-left p {
    margin: 0 0 6px;
    font-size: {{ section.settings.eyebrow_size }}px;
    letter-spacing: 0.22em;
    font-weight: 400;
    color: {{ section.settings.eyebrow_color }};
    text-transform: uppercase;
    font-family: {{ section.settings.ui_font }}, monospace;
  }

  #shopify-section-{{ section.id }} .reels-section__head .reels-head-left {{ section.settings.heading_size }} {
    margin: 0;
    font-size: {{ section.settings.heading_font_size }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    color: {{ section.settings.heading_color }};
    font-family: {{ section.settings.heading_font }}, Georgia, serif;
    line-height: 1.08;
    letter-spacing: -0.01em;
  }

  #shopify-section-{{ section.id }} .reels-section__handle {
    font-size: {{ section.settings.eyebrow_size }}px;
    letter-spacing: 0.2em;
    font-weight: 400;
    color: {{ section.settings.handle_color }};
    text-decoration: none;
    text-transform: uppercase;
    font-family: {{ section.settings.ui_font }}, monospace;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ section.id }} .reels-section__handle:hover { opacity: 0.6; }

  /* ── Viewport ── */
  #shopify-section-{{ section.id }} .reels-section__viewport {
    position: relative;
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .reels-track {
    display: flex;
    gap: {{ section.settings.card_gap }}px;
    overflow: hidden;
    padding: 4px {{ section.settings.section_h_padding }}px 12px;
  }

  /* ── Reel card ── */
  #shopify-section-{{ section.id }} .reel-card {
    flex: 0 0 {{ section.settings.card_width }}px;
    width: {{ section.settings.card_width }}px;
    aspect-ratio: {{ section.settings.card_aspect }};
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    border: 1px solid {{ section.settings.card_border }};
    overflow: hidden;
    position: relative;
    display: block;
    text-decoration: none;
    transition: transform 0.25s ease;
  }
  #shopify-section-{{ section.id }} .reel-card:hover { transform: translateY(-3px); }

  #shopify-section-{{ section.id }} .reel-card__media {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ section.id }} .reel-card__media video,
  #shopify-section-{{ section.id }} .reel-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* gradient overlay — top + bottom */
  #shopify-section-{{ section.id }} .reel-card__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, transparent 28%),
      linear-gradient(to top,    rgba(0,0,0,0.55) 0%, transparent 35%);
    z-index: 1;
    pointer-events: none;
  }

  /* placeholder */
  #shopify-section-{{ section.id }} .reel-card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: {{ section.settings.ui_font }}, monospace;
  }
  #shopify-section-{{ section.id }} .reel-card__placeholder-num {
    font-size: 18px;
    font-weight: 500;
    color: rgba(255,255,255,0.15);
    letter-spacing: 0.1em;
  }
  #shopify-section-{{ section.id }} .reel-card__placeholder-hint {
    font-size: 10px;
    color: rgba(255,255,255,0.1);
    letter-spacing: 0.08em;
  }

  /* ── Top row: tag left + play right ── */
  #shopify-section-{{ section.id }} .reel-card__top {
    position: absolute;
    top: {{ section.settings.tag_top }}px;
    left: {{ section.settings.tag_left }}px;
    right: {{ section.settings.tag_left }}px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 3;
    gap: 8px;
  }

  /* Tag pill */
  #shopify-section-{{ section.id }} .reel-card__tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: {{ section.settings.tag_bg }};
    color: {{ section.settings.tag_color }};
    font-family: {{ section.settings.ui_font }}, monospace;
    font-size: {{ section.settings.tag_size }}px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: {{ section.settings.tag_pad_y }}px {{ section.settings.tag_pad_x }}px;
    border-radius: {{ section.settings.tag_radius }}px;
    line-height: 1;
    white-space: nowrap;
    max-width: calc({{ section.settings.card_width }}px - 72px);
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 1;
  }
  #shopify-section-{{ section.id }} .reel-card__tag::before {
    content: '';
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ section.settings.dot_color }};
    flex-shrink: 0;
    display: {% if section.settings.show_dot %}block{% else %}none{% endif %};
  }

  /* Play button — small circle top-right */
  #shopify-section-{{ section.id }} .reel-card__play {
    flex-shrink: 0;
    width: {{ section.settings.play_size }}px;
    height: {{ section.settings.play_size }}px;
    background: {{ section.settings.play_bg }};
    border-radius: 50%;
    display: {% if section.settings.show_play %}flex{% else %}none{% endif %};
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .reel-card__play svg {
    width: {{ section.settings.play_icon_size }}px;
    height: {{ section.settings.play_icon_size }}px;
    fill: {{ section.settings.play_icon_color }};
    margin-left: 1px;
  }

  /* Caption — bottom left */
  #shopify-section-{{ section.id }} .reel-card__caption {
    position: absolute;
    bottom: {{ section.settings.caption_bottom }}px;
    left: {{ section.settings.tag_left }}px;
    right: {{ section.settings.tag_left }}px;
    z-index: 3;
  }
  #shopify-section-{{ section.id }} .reel-card__caption p {
    margin: 0;
    color: {{ section.settings.caption_color }};
    font-size: {{ section.settings.caption_size }}px;
    font-family: {{ section.settings.caption_font }}, Georgia, serif;
    font-weight: 400;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: {{ section.settings.caption_lines }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Shop button — above caption if product linked */
  #shopify-section-{{ section.id }} .reel-card__shop {
    position: absolute;
    bottom: {% assign shop_bottom = section.settings.caption_bottom | plus: 32 %}{{ shop_bottom }}px;
    right: {{ section.settings.tag_left }}px;
    z-index: 4;
    background: {{ section.settings.shop_bg }};
    color: {{ section.settings.shop_color }};
    font-family: {{ section.settings.ui_font }}, monospace;
    font-size: {{ section.settings.shop_size }}px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: {{ section.settings.shop_pad_y }}px {{ section.settings.shop_pad_x }}px;
    border-radius: {{ section.settings.shop_radius }}px;
    display: {% if section.settings.show_shop %}flex{% else %}none{% endif %};
    align-items: center;
    gap: 3px;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ section.id }} .reel-card__shop:hover { opacity: 0.8; }
  #shopify-section-{{ section.id }} .reel-card__shop svg {
    width: 10px; height: 10px;
    stroke: {{ section.settings.shop_color }};
  }

  /* ── Follow footer ── */
  #shopify-section-{{ section.id }} .reels-follow {
    text-align: center;
    padding: {{ section.settings.follow_top }}px 0 0;
    display: {% if section.settings.show_follow %}block{% else %}none{% endif %};
  }
  #shopify-section-{{ section.id }} .reels-follow a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: {{ section.settings.follow_color }};
    font-family: {{ section.settings.ui_font }}, monospace;
    font-size: {{ section.settings.eyebrow_size }}px;
    letter-spacing: 0.14em;
    text-decoration: none;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ section.id }} .reels-follow a svg {
    width: 17px; height: 17px;
    stroke: {{ section.settings.follow_color }};
  }
  #shopify-section-{{ section.id }} .reels-follow a:hover { opacity: 0.65; }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .reels-section__head {
      padding-left: 16px;
      padding-right: 16px;
    }
    #shopify-section-{{ section.id }} .reels-track {
      padding-left: 16px;
      padding-right: 16px;
    }
    #shopify-section-{{ section.id }} .reels-section__head .reels-head-left {{ section.settings.heading_size }} {
      font-size: {{ section.settings.heading_font_size | times: 0.6 | round }}px;
    }
    #shopify-section-{{ section.id }} .reel-card {
      flex: 0 0 {{ section.settings.mobile_card_width }}px;
      width: {{ section.settings.mobile_card_width }}px;
    }
  }
{% endstyle %}

<section class="reels-section">

  <div class="reels-section__head">
    <div class="reels-head-left">
      {%- if section.settings.eyebrow != blank -%}
        <p>{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_size }}>{{ section.settings.heading }}</{{ section.settings.heading_size }}>
      {%- endif -%}
    </div>
    {%- if section.settings.instagram_handle != blank -%}
      <a href="{{ section.settings.instagram_url | default: '#' }}" target="_blank" rel="noopener" class="reels-section__handle">
        @{{ section.settings.instagram_handle }} &rarr;
      </a>
    {%- endif -%}
  </div>

  <div class="reels-section__viewport">

    <div class="reels-track" id="reels-track-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_href = block.settings.product_link | default: block.settings.custom_link | default: section.settings.instagram_url | default: '#'
        -%}
        <a href="{{ card_href }}"
           {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
           class="reel-card"
           {{ block.shopify_attributes }}>

          <div class="reel-card__media">
            {%- if block.settings.video_url != blank -%}
              <video
                src="{{ block.settings.video_url }}"
                muted
                autoplay
                loop
                playsinline
                preload="auto"
              ></video>
            {%- else -%}
              <div class="reel-card__placeholder">
                <span class="reel-card__placeholder-num">REEL {{ forloop.index }}</span>
                <span class="reel-card__placeholder-hint">Drop your .mp4 here</span>
              </div>
            {%- endif -%}
          </div>

          <div class="reel-card__overlay"></div>

          <!-- Top row: tag pill (left) + play circle (right) -->
          <div class="reel-card__top">
            {%- if block.settings.tag != blank -%}
              <span class="reel-card__tag">{{ block.settings.tag }}</span>
            {%- else -%}
              <span></span>
            {%- endif -%}
            <div class="reel-card__play">
              <svg viewBox="0 0 24 24"><polygon points="6 3 20 12 6 21 6 3"/></svg>
            </div>
          </div>

          <!-- Shop button -->
          {%- if section.settings.show_shop and block.settings.product_link != blank -%}
            <a href="{{ block.settings.product_link }}"
               class="reel-card__shop"
               {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
               onclick="event.stopPropagation();">
              {{ section.settings.shop_label }}
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          {%- endif -%}

          <!-- Caption -->
          {%- if block.settings.caption != blank -%}
            <div class="reel-card__caption"><p>{{ block.settings.caption }}</p></div>
          {%- endif -%}

        </a>
      {%- endfor -%}
    </div>

  </div>

  {%- if section.settings.instagram_handle != blank and section.settings.show_follow -%}
    <div class="reels-follow">
      <a href="{{ section.settings.instagram_url | default: '#' }}" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        Follow @{{ section.settings.instagram_handle }} for more
      </a>
    </div>
  {%- endif -%}

</section>

<script>
(function(){
  var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
  if (!sectionEl) return;
  var track = sectionEl.querySelector('.reels-track');
  if (!track) return;

  /* ── 1. Grab originals before any cloning ── */
  var origCards = Array.from(track.children);
  var count = origCards.length;
  if (count === 0) return;

  /* ── 2. Wrap track content in an inner strip so we can translate freely ── */
  var strip = document.createElement('div');
  strip.style.cssText = 'display:flex;gap:inherit;will-change:transform;';
  /* Move all original cards into strip */
  origCards.forEach(function(c){ strip.appendChild(c); });
  /* Clone entire strip for seamless loop */
  var clone = strip.cloneNode(true);
  clone.setAttribute('aria-hidden', 'true');
  /* Put both in track */
  track.appendChild(strip);
  track.appendChild(clone);
  /* track itself: flex row, no overflow clip needed on inner */
  track.style.display = 'flex';
  track.style.overflow = 'hidden';

  /* ── 3. Play all videos ── */
  track.querySelectorAll('video').forEach(function(v){
    v.muted = true;
    v.loop  = true;
    v.play().catch(function(){});
  });

  var speed  = {{ section.settings.auto_scroll_speed }}; /* px / sec */
  var paused = false;
  var pos    = 0;
  var last   = null;
  var setW   = 0; /* measured after paint */

  function measureSetWidth() {
    /* Real pixel width of one strip including gap between strips */
    var gap = parseFloat(getComputedStyle(track).gap) || {{ section.settings.card_gap }};
    setW = strip.offsetWidth + gap;
  }

  function tick(ts) {
    if (!paused) {
      if (last !== null) {
        pos += (ts - last) / 1000 * speed;
        if (setW > 0 && pos >= setW) pos -= setW; /* seamless reset */
        strip.style.transform = 'translateX(-' + pos + 'px)';
        clone.style.transform = 'translateX(-' + pos + 'px)';
      }
      last = ts;
    } else {
      last = null;
    }
    requestAnimationFrame(tick);
  }

  /* ── 4. Start after browser has painted ── */
  requestAnimationFrame(function(){
    requestAnimationFrame(function(){
      measureSetWidth();
      window.addEventListener('resize', measureSetWidth);
      requestAnimationFrame(tick);
    });
  });

  /* ── 5. Pause on hover / touch ── */
  sectionEl.addEventListener('mouseenter', function(){ paused = true; });
  sectionEl.addEventListener('mouseleave', function(){ paused = false; });
  sectionEl.addEventListener('touchstart', function(){ paused = true; }, { passive: true });
  sectionEl.addEventListener('touchend',   function(){ setTimeout(function(){ paused = false; }, 800); }, { passive: true });
})();
</script>

{% schema %}
{
  "name": "Instagram Reels",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    { "type": "text",     "id": "eyebrow",           "label": "Eyebrow text",               "default": "From the feed" },
    { "type": "text",     "id": "heading",            "label": "Heading",                    "default": "See it. Feel it." },
    { "type": "select",   "id": "heading_size",       "label": "Heading tag",                "options": [{"value":"h1","label":"H1"},{"value":"h2","label":"H2"},{"value":"h3","label":"H3"},{"value":"h4","label":"H4"}], "default": "h2" },
    { "type": "text",     "id": "instagram_handle",   "label": "Instagram handle (no @)",    "default": "indinoir.store" },
    { "type": "url",      "id": "instagram_url",      "label": "Instagram profile URL" },
    { "type": "checkbox", "id": "show_follow",        "label": "Show follow link at bottom", "default": true },
    { "type": "text",     "id": "shop_label",         "label": "Shop button label",          "default": "Shop Now" },
    { "type": "checkbox", "id": "show_shop",          "label": "Show shop button on cards",  "default": true },

    {
      "type": "header",
      "content": "Section Layout"
    },
    { "type": "color",  "id": "section_bg_color",   "label": "Section background",       "default": "#111111" },
    { "type": "range",  "id": "padding_top",         "label": "Padding top (px)",          "min": 0, "max": 200, "step": 4,  "default": 96 },
    { "type": "range",  "id": "padding_bottom",      "label": "Padding bottom (px)",       "min": 0, "max": 200, "step": 4,  "default": 64 },
    { "type": "range",  "id": "section_h_padding",   "label": "Side padding (px)",         "min": 0, "max": 120, "step": 4,  "default": 40 },
    { "type": "range",  "id": "head_gap",            "label": "Header bottom gap (px)",    "min": 8, "max": 64,  "step": 4,  "default": 32 },
    { "type": "range",  "id": "follow_top",          "label": "Follow link top gap (px)",  "min": 8, "max": 60,  "step": 4,  "default": 24 },

    {
      "type": "header",
      "content": "Typography"
    },
    { "type": "text",   "id": "ui_font",             "label": "UI / eyebrow font family",      "default": "monospace" },
    { "type": "text",   "id": "heading_font",         "label": "Heading font family",           "default": "Georgia" },
    { "type": "range",  "id": "eyebrow_size",         "label": "Eyebrow / handle font size",    "min": 8,  "max": 18, "step": 1, "default": 11 },
    { "type": "range",  "id": "heading_font_size",    "label": "Heading font size (px)",         "min": 24, "max": 120,"step": 2, "default": 60 },
    { "type": "select", "id": "heading_font_weight",  "label": "Heading font weight",            "options": [{"value":"300","label":"Light"},{"value":"400","label":"Regular"},{"value":"500","label":"Medium"},{"value":"600","label":"SemiBold"},{"value":"700","label":"Bold"}], "default": "400" },
    { "type": "color",  "id": "eyebrow_color",        "label": "Eyebrow color",                  "default": "#888888" },
    { "type": "color",  "id": "heading_color",        "label": "Heading color",                  "default": "#f5f5f5" },
    { "type": "color",  "id": "handle_color",         "label": "Handle color",                   "default": "#888888" },
    { "type": "color",  "id": "follow_color",         "label": "Follow link color",              "default": "#888888" },

    {
      "type": "header",
      "content": "Card"
    },
    { "type": "range",  "id": "card_width",     "label": "Card width — desktop (px)",    "min": 140, "max": 500, "step": 10, "default": 270 },
    { "type": "range",  "id": "mobile_card_width","label": "Card width — mobile (px)",   "min": 120, "max": 320, "step": 10, "default": 190 },
    { "type": "text",   "id": "card_aspect",    "label": "Card aspect ratio",            "default": "9/16",    "info": "e.g. 9/16  4/5  3/4  1/1" },
    { "type": "range",  "id": "card_gap",       "label": "Gap between cards (px)",       "min": 0,   "max": 40,  "step": 2,  "default": 10 },
    { "type": "range",  "id": "card_radius",    "label": "Card border radius (px)",      "min": 0,   "max": 40,  "step": 2,  "default": 10 },
    { "type": "color",  "id": "card_bg",        "label": "Card background (no media)",   "default": "#1d1d1d" },
    { "type": "color",  "id": "card_border",    "label": "Card border color",            "default": "#2c2c2c" },

    {
      "type": "header",
      "content": "Tag Pill"
    },
    { "type": "range",  "id": "tag_top",     "label": "Tag distance from top (px)",   "min": 4, "max": 30,  "step": 1, "default": 12 },
    { "type": "range",  "id": "tag_left",    "label": "Tag distance from sides (px)", "min": 4, "max": 24,  "step": 1, "default": 12 },
    { "type": "color",  "id": "tag_bg",      "label": "Tag background",               "default": "#ffffff" },
    { "type": "color",  "id": "tag_color",   "label": "Tag text color",               "default": "#111111" },
