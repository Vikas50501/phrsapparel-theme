{%- style -%}
  /* ══════════════════════════════════════════════════════
     MARQUEE TICKER — Two scrolling rows with inline images
     Matches video exactly: large muted text + product images
  ══════════════════════════════════════════════════════ */

  .mq-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    overflow: hidden;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    border-top: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
    border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
  }

  /* ── Each marquee row ─────────────────────────────── */
  .mq-row-{{ section.id }} {
    display: flex;
    overflow: hidden;
    position: relative;
    height: {{ section.settings.row_height }}px;
    align-items: center;
  }

  /* Divider between row 1 and row 2 */
  .mq-row-{{ section.id }} + .mq-row-{{ section.id }} {
    border-top: {{ section.settings.divider_width }}px solid {{ section.settings.divider_color }};
  }

  /* ── Scrolling track ─────────────────────────────── */
  .mq-track-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.item_gap }}px;
    white-space: nowrap;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    will-change: transform;
    flex-shrink: 0;
    min-width: max-content;
  }

  /* Row 1 — scroll left */
  .mq-row-{{ section.id }}[data-row="1"] .mq-track-{{ section.id }} {
    animation-name: mq-scroll-left-{{ section.id }};
    animation-duration: {{ section.settings.row1_speed }}s;
  }

  /* Row 2 — scroll left (different speed) */
  .mq-row-{{ section.id }}[data-row="2"] .mq-track-{{ section.id }} {
    animation-name: mq-scroll-left-{{ section.id }};
    animation-duration: {{ section.settings.row2_speed }}s;
    animation-direction: {{ section.settings.row2_direction }};
  }

  /* Pause on hover */
  .mq-section-{{ section.id }}[data-pause-hover="true"] .mq-track-{{ section.id }}:hover {
    animation-play-state: paused;
  }

  @keyframes mq-scroll-left-{{ section.id }} {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Text item ────────────────────────────────────── */
  .mq-text-{{ section.id }} {
    font-size: {{ section.settings.text_size }}px;
    font-weight: {{ section.settings.text_weight }};
    font-family: inherit;
    color: {{ section.settings.text_color }};
    letter-spacing: {{ section.settings.text_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.text_transform }};
    line-height: 1;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .mq-text-{{ section.id }}:hover {
    color: {{ section.settings.text_hover_color }};
  }

  /* ── Logo item (replaces text when enabled) ───────── */
  .mq-logo-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    height: {{ section.settings.logo_height }}px;
    text-decoration: none;
  }
  .mq-logo-{{ section.id }} img {
    height: 100%;
    width: auto;
    object-fit: contain;
    display: block;
  }
  @media (max-width: 749px) {
    .mq-logo-{{ section.id }} { height: {{ section.settings.logo_height_mobile }}px; }
  }

  /* ── Separator between items ──────────────────────── */
  .mq-sep-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    color: {{ section.settings.sep_color }};
    font-size: {{ section.settings.sep_size }}px;
    flex-shrink: 0;
    line-height: 1;
    opacity: {{ section.settings.sep_opacity | divided_by: 100.0 }};
  }

  /* ── Inline image ─────────────────────────────────── */
  .mq-img-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    width: {{ section.settings.img_width }}px;
    height: {{ section.settings.img_height }}px;
  }

  .mq-img-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  /* ── Mobile overrides ─────────────────────────────── */
  @media (max-width: 749px) {
    .mq-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .mq-row-{{ section.id }} { height: {{ section.settings.row_height_mobile }}px; }
    .mq-track-{{ section.id }} { gap: {{ section.settings.item_gap_mobile }}px; }
    .mq-text-{{ section.id }} {
      font-size: {{ section.settings.text_size_mobile }}px;
      letter-spacing: {{ section.settings.text_spacing_mobile | divided_by: 100.0 }}em;
    }
    .mq-img-{{ section.id }} {
      width: {{ section.settings.img_width_mobile }}px;
      height: {{ section.settings.img_height_mobile }}px;
    }
    .mq-sep-{{ section.id }} { font-size: {{ section.settings.sep_size_mobile }}px; }
  }
{%- endstyle -%}

{%- comment -%} Grab row 1 and row 2 blocks {%- endcomment -%}
{%- assign row1_items = section.blocks | where: "type", "row1_item" -%}
{%- assign row2_items = section.blocks | where: "type", "row2_item" -%}

<div
  class="mq-section-{{ section.id }}"
  data-pause-hover="{{ section.settings.pause_on_hover }}"
>

  {%- comment -%} ── ROW 1 ──────────────────────────── {%- endcomment -%}
  {%- if row1_items.size > 0 -%}
    <div class="mq-row-{{ section.id }}" data-row="1">
      {%- comment -%} Duplicate track for seamless loop {%- endcomment -%}
      {%- for _dup in (1..2) -%}
        <div class="mq-track-{{ section.id }}" aria-hidden="{% if _dup == 2 %}true{% else %}false{% endif %}">
          {%- for block in row1_items -%}
            {%- liquid
              assign is_logo = false
              if block.settings.item_type == 'logo'
                assign is_logo = true
              endif
            -%}
            {%- comment -%} Optional product image — shown for BOTH text and logo items {%- endcomment -%}
            {%- if block.settings.image != blank -%}
              <span class="mq-img-{{ section.id }}" {{ block.shopify_attributes }}>
                <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.image.alt | default: block.settings.text | escape }}" loading="lazy">
              </span>
            {%- endif -%}
            {%- comment -%} Then the logo (uses section Logo image) or the text {%- endcomment -%}
            {%- if is_logo and section.settings.logo_image != blank -%}
              {%- if block.settings.link != blank -%}
                <a class="mq-logo-{{ section.id }}" href="{{ block.settings.link }}" aria-label="{{ shop.name | escape }}" {{ block.shopify_attributes }}><img src="{{ section.settings.logo_image | image_url: width: 700 }}" alt="{{ shop.name | escape }}" loading="lazy"></a>
              {%- else -%}
                <span class="mq-logo-{{ section.id }}" {{ block.shopify_attributes }}><img src="{{ section.settings.logo_image | image_url: width: 700 }}" alt="{{ shop.name | escape }}" loading="lazy"></span>
              {%- endif -%}
            {%- elsif block.settings.text != blank -%}
              {%- if block.settings.link != blank -%}
                <a class="mq-text-{{ section.id }}" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
              {%- else -%}
                <span class="mq-text-{{ section.id }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
              {%- endif -%}
            {%- endif -%}
            {%- if section.settings.show_separator and forloop.last == false -%}
              <span class="mq-sep-{{ section.id }}">{{ section.settings.separator }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── ROW 2 ──────────────────────────── {%- endcomment -%}
  {%- if row2_items.size > 0 -%}
    <div class="mq-row-{{ section.id }}" data-row="2">
      {%- for _dup in (1..2) -%}
        <div class="mq-track-{{ section.id }}" aria-hidden="{% if _dup == 2 %}true{% else %}false{% endif %}">
          {%- for block in row2_items -%}
            {%- liquid
              assign is_logo = false
              if block.settings.item_type == 'logo'
                assign is_logo = true
              endif
            -%}
            {%- comment -%} Optional product image — shown for BOTH text and logo items {%- endcomment -%}
            {%- if block.settings.image != blank -%}
              <span class="mq-img-{{ section.id }}" {{ block.shopify_attributes }}>
                <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.image.alt | default: block.settings.text | escape }}" loading="lazy">
              </span>
            {%- endif -%}
            {%- comment -%} Then the logo (uses section Logo image) or the text {%- endcomment -%}
            {%- if is_logo and section.settings.logo_image != blank -%}
              {%- if block.settings.link != blank -%}
                <a class="mq-logo-{{ section.id }}" href="{{ block.settings.link }}" aria-label="{{ shop.name | escape }}" {{ block.shopify_attributes }}><img src="{{ section.settings.logo_image | image_url: width: 700 }}" alt="{{ shop.name | escape }}" loading="lazy"></a>
              {%- else -%}
                <span class="mq-logo-{{ section.id }}" {{ block.shopify_attributes }}><img src="{{ section.settings.logo_image | image_url: width: 700 }}" alt="{{ shop.name | escape }}" loading="lazy"></span>
              {%- endif -%}
            {%- elsif block.settings.text != blank -%}
              {%- if block.settings.link != blank -%}
                <a class="mq-text-{{ section.id }}" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
              {%- else -%}
                <span class="mq-text-{{ section.id }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
              {%- endif -%}
            {%- endif -%}
            {%- if section.settings.show_separator and forloop.last == false -%}
              <span class="mq-sep-{{ section.id }}">{{ section.settings.separator }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Marquee Ticker",
  "tag": "section",
  "class": "section-marquee-ticker",
  "max_blocks": 20,
  "blocks": [
    {
      "type": "row1_item",
      "name": "Row 1 — item",
      "settings": [
        {
          "type": "paragraph",
          "content": "Add text, an image, or both. Items appear in order, looping endlessly."
        },
        {
          "type": "select", "id": "item_type", "label": "This item shows",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "logo", "label": "Logo image" }
          ],
          "default": "text"
        },
        { "type": "text",         "id": "text",  "label": "Text",  "info": "Used when 'This item shows' = Text" },
        { "type": "url",          "id": "link",  "label": "Link",  "info": "Optional — makes the item a link" },
        { "type": "image_picker", "id": "image", "label": "Image", "info": "Optional product image, shown before the text/logo in this item." }
      ]
    },
    {
      "type": "row2_item",
      "name": "Row 2 — item",
      "settings": [
        {
          "type": "paragraph",
          "content": "Add text, an image, or both. Items appear in order, looping endlessly."
        },
        {
          "type": "select", "id": "item_type", "label": "This item shows",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "logo", "label": "Logo image" }
          ],
          "default": "text"
        },
        { "type": "text",         "id": "text",  "label": "Text",  "info": "Used when 'This item shows' = Text" },
        { "type": "url",          "id": "link",  "label": "Link",  "info": "Optional — makes the item a link" },
        { "type": "image_picker", "id": "image", "label": "Image", "info": "Optional product image, shown before the text/logo in this item." }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "Logo image" },
    { "type": "paragraph", "content": "Upload your logo once here, then set any item's 'This item shows' to Logo image — so you can alternate text and logo (text → logo → text → logo)." },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "range", "id": "logo_height", "label": "Logo height (desktop)", "min": 20, "max": 140, "step": 2, "unit": "px", "default": 56 },
    { "type": "range", "id": "logo_height_mobile", "label": "Logo height (mobile)", "min": 14, "max": 90, "step": 2, "unit": "px", "default": 30 },

    { "type": "header", "content": "Text style" },
    {
      "type": "range", "id": "text_size", "label": "Text size",
      "min": 20, "max": 120, "step": 2, "unit": "px", "default": 64
    },
    {
      "type": "select", "id": "text_weight", "label": "Font weight",
      "options": [
        { "value": "200", "label": "Extra light" },
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select", "id": "text_transform", "label": "Text case",
      "options": [
        { "value": "uppercase",  "label": "UPPERCASE" },
        { "value": "none",       "label": "As typed" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range", "id": "text_spacing", "label": "Letter spacing",
      "min": 0, "max": 50, "step": 1, "unit": "em", "default": 15,
      "info": "Divided by 100 (15 = 0.15em)"
    },
    { "type": "color", "id": "text_color",       "label": "Text colour",       "default": "#c8c8c8" },
    { "type": "color", "id": "text_hover_color",  "label": "Text colour — hover","default": "#111111" },

    { "type": "header", "content": "Inline images" },
    {
      "type": "range", "id": "img_width", "label": "Image width",
      "min": 20, "max": 200, "step": 4, "unit": "px", "default": 80
    },
    {
      "type": "range", "id": "img_height", "label": "Image height",
      "min": 20, "max": 160, "step": 4, "unit": "px", "default": 56
    },

    { "type": "header", "content": "Separator between items" },
    { "type": "checkbox", "id": "show_separator", "label": "Show separator",    "default": false },
    { "type": "text",     "id": "separator",      "label": "Separator symbol",  "default": "✦" },
    { "type": "color",    "id": "sep_color",       "label": "Separator colour",  "default": "#c8c8c8" },
    {
      "type": "range", "id": "sep_size", "label": "Separator size",
      "min": 8, "max": 40, "step": 2, "unit": "px", "default": 16
    },
    {
      "type": "range", "id": "sep_opacity", "label": "Separator opacity",
      "min": 10, "max": 100, "step": 5, "unit": "%", "default": 60
    },

    { "type": "header", "content": "Row layout" },
    {
      "type": "range", "id": "row_height", "label": "Row height",
      "min": 40, "max": 200, "step": 4, "unit": "px", "default": 100
    },
    {
      "type": "range", "id": "item_gap", "label": "Gap between items",
      "min": 8, "max": 120, "step": 4, "unit": "px", "default": 48
    },

    { "type": "header", "content": "Row 1 speed & direction" },
    {
      "type": "range", "id": "row1_speed", "label": "Row 1 speed (seconds)",
      "min": 5, "max": 60, "step": 1, "unit": "s", "default": 20,
      "info": "Lower = faster"
    },

    { "type": "header", "content": "Row 2 speed & direction" },
    {
      "type": "range", "id": "row2_speed", "label": "Row 2 speed (seconds)",
      "min": 5, "max": 60, "step": 1, "unit": "s", "default": 25,
      "info": "Different speed from Row 1 creates depth"
    },
    {
      "type": "select", "id": "row2_direction", "label": "Row 2 direction",
      "options": [
        { "value": "normal",  "label": "← Left (same as Row 1)" },
        { "value": "reverse", "label": "→ Right (opposite)" }
      ],
      "default": "normal"
    },

    { "type": "header", "content": "Behaviour" },
    {
      "type": "checkbox", "id": "pause_on_hover", "label": "Pause on hover", "default": true
    },

    { "type": "header", "content": "Divider between rows" },
    {
      "type": "range", "id": "divider_width", "label": "Divider thickness",
      "min": 0, "max": 4, "step": 1, "unit": "px", "default": 1
    },
    { "type": "color", "id": "divider_color", "label": "Divider colour", "default": "#e5e5e5" },

    { "type": "header", "content": "Section border" },
    {
      "type": "range", "id": "border_width", "label": "Top/bottom border thickness",
      "min": 0, "max": 4, "step": 1, "unit": "px", "default": 1
    },
    { "type": "color", "id": "border_color", "label": "Border colour", "default": "#e5e5e5" },

    { "type": "header", "content": "Mobile view (≤ 749px)" },
    {
      "type": "range", "id": "text_size_mobile", "label": "Text size",
      "min": 12, "max": 64, "step": 1, "unit": "px", "default": 28
    },
    {
      "type": "range", "id": "text_spacing_mobile", "label": "Letter spacing",
      "min": 0, "max": 50, "step": 1, "unit": "em", "default": 8,
      "info": "Divided by 100 (8 = 0.08em)"
    },
    {
      "type": "range", "id": "row_height_mobile", "label": "Row height",
      "min": 28, "max": 140, "step": 2, "unit": "px", "default": 52
    },
    {
      "type": "range", "id": "item_gap_mobile", "label": "Gap between items",
      "min": 6, "max": 80, "step": 2, "unit": "px", "default": 24
    },
    {
      "type": "range", "id": "img_width_mobile", "label": "Image width",
      "min": 16, "max": 140, "step": 2, "unit": "px", "default": 48
    },
    {
      "type": "range", "id": "img_height_mobile", "label": "Image height",
      "min": 16, "max": 120, "step": 2, "unit": "px", "default": 34
    },
    {
      "type": "range", "id": "sep_size_mobile", "label": "Separator size",
      "min": 6, "max": 32, "step": 1, "unit": "px", "default": 11
    },
    {
      "type": "range", "id": "padding_top_mobile", "label": "Top padding",
      "min": 0, "max": 60, "step": 2, "unit": "px", "default": 0
    },
    {
      "type": "range", "id": "padding_bottom_mobile", "label": "Bottom padding",
      "min": 0, "max": 60, "step": 2, "unit": "px", "default": 0
    },

    { "type": "header", "content": "Background & padding" },
    { "type": "color", "id": "bg_color",       "label": "Background",    "default": "#f0efed" },
    {
      "type": "range", "id": "padding_top",    "label": "Top padding",   "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "range", "id": "padding_bottom", "label": "Bottom padding","min": 0, "max": 80, "step": 4, "unit": "px", "default": 0
    }
  ],
  "presets": [
    {
      "name": "Marquee Ticker",
      "blocks": [
        { "type": "row1_item", "settings": { "text": "NEW: LE SAC BAGUETTE" } },
        { "type": "row1_item", "settings": { "text": "NEW: LE SAC BAGUETTE" } },
        { "type": "row1_item", "settings": { "text": "NEW: LE SAC BAGUETTE" } },
        { "type": "row2_item", "settings": { "text": "SHOP NEW ARRIVALS" } },
        { "type": "row2_item", "settings": { "text": "SHOP NEW ARRIVALS" } },
        { "type": "row2_item", "settings": { "text": "SHOP NEW ARRIVALS" } }
      ]
    }
  ]
}
{% endschema %}
