{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section-{{ section.id }}-padding .video-section__media {
    border-radius: {{ section.settings.media_border_radius }}px;
    {% if section.settings.media_box_shadow %}
      box-shadow: 0 {{ section.settings.media_shadow_offset_y }}px {{ section.settings.media_shadow_blur }}px {{ section.settings.media_shadow_spread }}px {{ section.settings.media_shadow_color }};
    {% endif %}
    {% if section.settings.media_border %}
      border: {{ section.settings.media_border_width }}px solid {{ section.settings.media_border_color }};
    {% endif %}
    overflow: hidden;
  }

  .section-{{ section.id }}-padding .video-section__poster {
    opacity: {{ section.settings.poster_overlay_opacity | divided_by: 100.0 }};
  }

  .section-{{ section.id }}-padding .deferred-media__poster-button {
    {% if section.settings.play_button_style == 'custom' %}
      background-color: {{ section.settings.play_button_bg_color }};
      color: {{ section.settings.play_button_icon_color }};
      width: {{ section.settings.play_button_size }}px;
      height: {{ section.settings.play_button_size }}px;
      border-radius: {{ section.settings.play_button_border_radius }}%;
      border: {{ section.settings.play_button_border_width }}px solid {{ section.settings.play_button_border_color }};
    {% endif %}
  }

  .section-{{ section.id }}-padding .title-wrapper {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
  }

  .section-{{ section.id }}-padding .title {
    color: {{ section.settings.heading_color }};
    {% if section.settings.heading_letter_spacing != 0 %}
      letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    {% endif %}
    {% if section.settings.heading_text_transform != 'none' %}
      text-transform: {{ section.settings.heading_text_transform }};
    {% endif %}
  }

  {% if section.settings.poster_overlay_enable %}
    .section-{{ section.id }}-padding .video-section__poster::after {
      content: '';
      position: absolute;
      inset: 0;
      background-color: {{ section.settings.poster_overlay_color }};
      opacity: {{ section.settings.poster_overlay_opacity | divided_by: 100.0 }};
      pointer-events: none;
    }
  {% endif %}

  {% if section.settings.max_video_width != 0 %}
    .section-{{ section.id }}-padding .video-section__media {
      max-width: {{ section.settings.max_video_width }}px;
      margin-left: auto;
      margin-right: auto;
    }
  {% endif %}
{%- endstyle -%}

{%- liquid
  assign video_id = section.settings.video.id | default: section.settings.video_url.id
  assign video_alt = section.settings.video.alt | default: section.settings.description
  assign alt = 'sections.video.load_video' | t: description: video_alt | escape
  assign poster = section.settings.video.preview_image | default: section.settings.cover_image

  if section.settings.video != null
    assign ratio_diff = section.settings.video.aspect_ratio | minus: poster.aspect_ratio | abs
    if ratio_diff < 0.01 and ratio_diff > 0
      assign fix_ratio = true
    endif
  endif
-%}

{%- capture sizes -%}
  {% if section.settings.full_width -%}
    100vw
  {%- else -%}
    (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px)
    calc(100vw - 10rem), 100vw
  {%- endif %}
{%- endcapture -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="video-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding">
    <div
      {% if section.settings.full_width %}
        class="page-width"
      {% endif %}
    >
      {%- unless section.settings.heading == blank -%}
        <div class="title-wrapper title-wrapper--no-top-margin{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        </div>
      {%- endunless -%}

      {%- unless section.settings.subheading == blank -%}
        <div class="video-section__subheading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" style="text-align: {{ section.settings.heading_alignment }}; margin-bottom: {{ section.settings.heading_margin_bottom }}px; color: {{ section.settings.subheading_color }};">
          <p>{{ section.settings.subheading }}</p>
        </div>
      {%- endunless -%}
    </div>
    <deferred-media
      class="video-section__media deferred-media gradient global-media-settings{% if section.settings.full_width %} global-media-settings--full-width{% endif %}{% if fix_ratio %} media-fit-cover{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      data-media-id="{{ video_id }}"
      {% if poster != null %}
        style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
      {% endif %}
    >
      <button
        id="Deferred-Poster-Modal-{{ video_id }}"
        class="video-section__poster media deferred-media__poster media--landscape"
        type="button"
        aria-label="{{ alt }}"
      >
        {%- if poster != null -%}
          {{
            poster
            | image_url: width: 3840
            | image_tag: sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', alt: alt
          }}
        {%- else -%}
          {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
        {%- endif -%}
        <span class="deferred-media__poster-button motion-reduce">
          <span class="svg-wrapper">
            {{- 'icon-play.svg' | inline_asset_content -}}
          </span>
        </span>
      </button>
      <template>
        {%- if section.settings.video == null and section.settings.video_url != null -%}
          {%- liquid
            assign loop = ''
            if section.settings.enable_video_looping
              assign loop = '&loop=1&playlist=' | append: video_id
            endif
          -%}
          {%- if section.settings.video_url.type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&autoplay=1{{ loop }}"
              class="js-youtube"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.description | escape }}"
            ></iframe>
          {%- else -%}
            <iframe
              src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1{{ loop }}"
              class="js-vimeo"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.description | escape }}"
            ></iframe>
          {%- endif -%}
        {%- else -%}
          {{
            section.settings.video
            | video_tag:
              image_size: '1100x',
              autoplay: true,
              loop: section.settings.enable_video_looping,
              controls: section.settings.show_video_controls,
              muted: section.settings.mute_video
          }}
        {%- endif -%}
      </template>
    </deferred-media>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.video.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [

    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.video.settings.heading.default",
      "label": "t:sections.video.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": -5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "heading_text_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "Default" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Heading bottom spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "info": "Optional text shown below the heading."
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },

    {
      "type": "header",
      "content": "Video — Shopify-hosted"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video.settings.video.label"
    },
    {
      "type": "checkbox",
      "id": "show_video_controls",
      "label": "Show video controls",
      "default": true,
      "info": "Applies to Shopify-hosted videos only."
    },
    {
      "type": "checkbox",
      "id": "mute_video",
      "label": "Mute video by default",
      "default": false,
      "info": "Applies to Shopify-hosted videos only."
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "t:sections.video.settings.enable_video_looping.label",
      "default": false
    },

    {
      "type": "header",
      "content": "t:sections.video.settings.header__2.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.video.settings.paragraph.content"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "label": "t:sections.video.settings.video_url.label",
      "info": "t:sections.video.settings.video_url.info"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.video.settings.cover_image.label"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.video.settings.description.label",
      "info": "t:sections.video.settings.description.info"
    },

    {
      "type": "header",
      "content": "Poster / Thumbnail overlay"
    },
    {
      "type": "checkbox",
      "id": "poster_overlay_enable",
      "label": "Enable poster overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "poster_overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "poster_overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 30
    },

    {
      "type": "header",
      "content": "Play button"
    },
    {
      "type": "select",
      "id": "play_button_style",
      "label": "Play button style",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "color",
      "id": "play_button_bg_color",
      "label": "Button background color",
      "default": "#ffffff",
      "info": "Applied when 'Custom' style is selected."
    },
    {
      "type": "color",
      "id": "play_button_icon_color",
      "label": "Button icon color",
      "default": "#000000",
      "info": "Applied when 'Custom' style is selected."
    },
    {
      "type": "range",
      "id": "play_button_size",
      "label": "Button size",
      "min": 40,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64,
      "info": "Applied when 'Custom' style is selected."
    },
    {
      "type": "range",
      "id": "play_button_border_radius",
      "label": "Button shape (border radius)",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "%",
      "default": 50,
      "info": "50% = circle. Applied when 'Custom' style is selected."
    },
    {
      "type": "range",
      "id": "play_button_border_width",
      "label": "Button border width",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "Applied when 'Custom' style is selected."
    },
    {
      "type": "color",
      "id": "play_button_border_color",
      "label": "Button border color",
      "default": "#ffffff",
      "info": "Applied when 'Custom' style is selected."
    },

    {
      "type": "header",
      "content": "Media container"
    },
    {
      "type": "range",
      "id": "media_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "max_video_width",
      "label": "Max video width",
      "min": 0,
      "max": 1600,
      "step": 40,
      "unit": "px",
      "default": 0,
      "info": "Set to 0 to disable (full container width)."
    },
    {
      "type": "checkbox",
      "id": "media_border",
      "label": "Show border",
      "default": false
    },
    {
      "type": "range",
      "id": "media_border_width",
      "label": "Border width",
      "min": 1,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "media_border_color",
      "label": "Border color",
      "default": "#e8e8e8"
    },
    {
      "type": "checkbox",
      "id": "media_box_shadow",
      "label": "Show box shadow",
      "default": false
    },
    {
      "type": "range",
      "id": "media_shadow_offset_y",
      "label": "Shadow vertical offset",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "media_shadow_blur",
      "label": "Shadow blur radius",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "media_shadow_spread",
      "label": "Shadow spread",
      "min": -20,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "media_shadow_color",
      "label": "Shadow color",
      "default": "rgba(0,0,0,0.15)"
    },

    {
      "type": "header",
      "content": "t:sections.video.settings.header__3.content"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.video.settings.full_width.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },

    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }

  ],
  "presets": [
    {
      "name": "t:sections.video.presets.name"
    }
  ]
}
{% endschema %}