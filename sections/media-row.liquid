{%- style -%}
  /* ══════════════════════════════════════════════════════
     MEDIA ROWS — Stack of full-width image/video rows
     Each row: media + content. Layout: "corner" (text bottom-left
     + arrow button bottom-right, default) or "overlay".
  ══════════════════════════════════════════════════════ */

  .mr-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .mr-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Section heading — centered with orange underline accent ── */
  .mr-section-heading-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto {{ section.settings.section_heading_gap }}px;
    padding: 0 {{ section.settings.side_padding }}px;
    text-align: center;
  }

  .mr-section-title-{{ section.id }} {
    display: inline-block;
    position: relative;
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    color: {{ section.settings.section_heading_color }};
    letter-spacing: {{ section.settings.section_heading_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.section_heading_transform }};
    line-height: 1.15;
    margin: 0;
    padding-bottom: 10px;
  }
  .mr-section-title-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 3px;
    background: {{ section.settings.underline_color | default: '#c47a5a' }};
    border-radius: 3px;
  }

  /* ── Rows wrapper — full screen, no max-width ────────── */
  .mr-rows-{{ section.id }} {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.row_gap }}px;
  }

  /* ── Single row ──────────────────────────────────────── */
  .mr-row-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.row_radius }}px;
  }

  /* ── Media container ─────────────────────────────────── */
  .mr-media-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* Fixed height rows */
  .mr-row-{{ section.id }}[data-height-mode="fixed"] .mr-media-{{ section.id }} {
    height: var(--mr-row-h, {{ section.settings.row_height_desktop }}px);
  }

  @media (max-width: 749px) {
    .mr-row-{{ section.id }}[data-height-mode="fixed"] .mr-media-{{ section.id }} {
      height: var(--mr-row-h-mobile, {{ section.settings.row_height_mobile }}px);
    }
  }

  /* Aspect ratio rows */
  .mr-row-{{ section.id }}[data-height-mode="ratio"] .mr-media-{{ section.id }} {
    aspect-ratio: var(--mr-ratio, {{ section.settings.row_aspect }});
  }

  /* Per-viewport aspect ratio (separate desktop / mobile control) */
  {%- if section.settings.use_aspect_ratio -%}
    .mr-row-{{ section.id }} .mr-media-{{ section.id }} {
      aspect-ratio: {{ section.settings.desktop_aspect }} !important;
      height: auto !important;
    }
    @media (max-width: 749px) {
      .mr-row-{{ section.id }} .mr-media-{{ section.id }} {
        aspect-ratio: {{ section.settings.mobile_aspect }} !important;
        height: auto !important;
      }
    }
  {%- endif -%}

  .mr-media-{{ section.id }} img,
  .mr-media-{{ section.id }} video,
  .mr-media-{{ section.id }} .mr-video-wrap,
  .mr-media-{{ section.id }} .mr-video-wrap > video,
  .mr-media-{{ section.id }} .mr-video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.media_fit }};
    object-position: center;
    display: block;
  }

  /* Hover zoom on the media */
  {%- if section.settings.media_hover_zoom -%}
    .mr-media-{{ section.id }} img,
    .mr-media-{{ section.id }} video,
    .mr-media-{{ section.id }} .mr-video-wrap > video {
      transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .mr-row-{{ section.id }}:hover .mr-media-{{ section.id }} img,
    .mr-row-{{ section.id }}:hover .mr-media-{{ section.id }} video,
    .mr-row-{{ section.id }}:hover .mr-media-{{ section.id }} .mr-video-wrap > video {
      transform: scale(1.03);
    }
    @media (prefers-reduced-motion: reduce) {
      .mr-row-{{ section.id }}:hover .mr-media-{{ section.id }} img,
      .mr-row-{{ section.id }}:hover .mr-media-{{ section.id }} video,
      .mr-row-{{ section.id }}:hover .mr-media-{{ section.id }} .mr-video-wrap > video { transform: none; }
    }
  {%- endif -%}

  /* Whole-row clickable overlay (corner layout) */
  .mr-row-link-{{ section.id }} {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: block;
  }

  /* ── Overlay tint ────────────────────────────────────── */
  .mr-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: var(--mr-overlay-color, rgba(0,0,0,0));
    pointer-events: none;
    z-index: 1;
  }

  /* ── Content (heading + buttons) ────────────────────── */
  .mr-content-{{ section.id }} {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: var(--mr-align-h, center);
    justify-content: var(--mr-align-v, center);
    padding: {{ section.settings.content_pad_y }}px {{ section.settings.content_pad_x }}px;
    text-align: var(--mr-text-align, center);
  }

  .mr-row-{{ section.id }}[data-align-h="left"]   { --mr-align-h: flex-start; --mr-text-align: left; }
  .mr-row-{{ section.id }}[data-align-h="center"] { --mr-align-h: center;     --mr-text-align: center; }
  .mr-row-{{ section.id }}[data-align-h="right"]  { --mr-align-h: flex-end;   --mr-text-align: right; }
  .mr-row-{{ section.id }}[data-align-v="top"]    { --mr-align-v: flex-start; }
  .mr-row-{{ section.id }}[data-align-v="middle"] { --mr-align-v: center; }
  .mr-row-{{ section.id }}[data-align-v="bottom"] { --mr-align-v: flex-end; }

  .mr-content-inner-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: inherit;
    gap: {{ section.settings.content_gap }}px;
    max-width: {{ section.settings.content_max_width }}px;
    width: 100%;
    background: var(--mr-content-box-bg, transparent);
    padding: var(--mr-content-box-pad, 0px);
    border-radius: var(--mr-content-box-radius, 0px);
  }

  /* Eyebrow */
  .mr-eyebrow-{{ section.id }} {
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: {{ section.settings.eyebrow_weight }};
    letter-spacing: {{ section.settings.eyebrow_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.eyebrow_transform }};
    line-height: 1.2;
    margin: 0;
  }

  /* Heading */
  .mr-heading-{{ section.id }} {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-size: var(--font-h2-size);
    font-weight: var(--font-heading-weight);
    letter-spacing: {{ section.settings.heading_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.heading_transform }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    margin: 0;
    word-break: break-word;
    text-shadow: 0 2px 16px rgba(0,0,0,0.45);
  }

  /* Subheading */
  .mr-subheading-{{ section.id }} {
    font-size: {{ section.settings.subheading_size }}px;
    font-weight: {{ section.settings.subheading_weight }};
    letter-spacing: {{ section.settings.subheading_spacing | divided_by: 100.0 }}em;
    line-height: 1.6;
    margin: 0;
    max-width: {{ section.settings.subheading_max_width }}px;
  }

  /* Button row */
  .mr-btn-row-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ section.settings.btn_gap }}px;
    align-items: center;
    justify-content: inherit;
  }

  /* Buttons */
  .mr-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.btn_pad_y }}px {{ section.settings.btn_pad_x }}px;
    font-size: {{ section.settings.btn_size }}px;
    font-weight: {{ section.settings.btn_weight }};
    letter-spacing: {{ section.settings.btn_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.btn_transform }};
    border-radius: {{ section.settings.btn_radius }}px;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, border-color 0.25s, transform 0.2s;
    border-width: {{ section.settings.btn_border_width }}px;
    border-style: solid;
  }

  .mr-btn-{{ section.id }}:hover { transform: translateY(-1px); }

  /* Primary button — colours set per row via CSS vars */
  .mr-btn-primary-{{ section.id }} {
    background: var(--mr-btn1-bg, {{ section.settings.btn1_bg }});
    color: var(--mr-btn1-color, {{ section.settings.btn1_color }});
    border-color: var(--mr-btn1-border, {{ section.settings.btn1_border }});
  }
  .mr-btn-primary-{{ section.id }}:hover {
    background: var(--mr-btn1-bg-h, {{ section.settings.btn1_bg_hover }});
    color: var(--mr-btn1-color-h, {{ section.settings.btn1_color_hover }});
    border-color: var(--mr-btn1-border-h, {{ section.settings.btn1_border_hover }});
  }

  /* Secondary button */
  .mr-btn-secondary-{{ section.id }} {
    background: var(--mr-btn2-bg, {{ section.settings.btn2_bg }});
    color: var(--mr-btn2-color, {{ section.settings.btn2_color }});
    border-color: var(--mr-btn2-border, {{ section.settings.btn2_border }});
  }
  .mr-btn-secondary-{{ section.id }}:hover {
    background: var(--mr-btn2-bg-h, {{ section.settings.btn2_bg_hover }});
    color: var(--mr-btn2-color-h, {{ section.settings.btn2_color_hover }});
    border-color: var(--mr-btn2-border-h, {{ section.settings.btn2_border_hover }});
  }

  /* ── Corner layout: heading bottom-left + arrow button bottom-right ── */
  .mr-corner-{{ section.id }} {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    text-align: left;
    padding: {{ section.settings.content_pad_y }}px {{ section.settings.content_pad_x }}px;
    pointer-events: none;
  }
  /* Subtle bottom scrim so text stays legible over any media */
  .mr-corner-{{ section.id }}::before {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 55%;
    background: linear-gradient(to top, rgba(0,0,0,{{ section.settings.corner_scrim | divided_by: 100.0 }}), rgba(0,0,0,0));
    pointer-events: none;
    z-index: -1;
  }
  .mr-corner-text-{{ section.id }} {
    position: relative;
    max-width: {{ section.settings.content_max_width }}px;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.content_gap }}px;
    pointer-events: none;
  }
  /* Reserve room so long headings never sit under the arrow button (bottom-right) */
  .mr-corner-text-{{ section.id }} { padding-right: {{ section.settings.corner_btn_size | plus: 24 }}px; }

  /* Outlined circular arrow (white) — editorial / luxury style */
  .mr-arrow-btn-{{ section.id }} {
    position: absolute;
    z-index: 3;
    right: {{ section.settings.corner_btn_offset }}px;
    bottom: {{ section.settings.corner_btn_offset }}px;
    width: {{ section.settings.corner_btn_size }}px;
    height: {{ section.settings.corner_btn_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--mr-btn1-bg, transparent);
    color: var(--mr-btn1-color, #ffffff);
    border: 1.5px solid var(--mr-btn1-border, rgba(255,255,255,0.85));
    transition: background 0.25s, color 0.25s, border-color 0.25s, transform 0.25s;
  }
  .mr-arrow-btn-{{ section.id }}:hover {
    background: var(--mr-btn1-bg-h, #ffffff);
    color: var(--mr-btn1-color-h, #111111);
    border-color: var(--mr-btn1-border-h, #ffffff);
    transform: scale(1.06) translateY(-1px);
  }
  .mr-arrow-btn-{{ section.id }} svg {
    width: 42%;
    height: 42%;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Mobile adjustments */
  @media (max-width: 749px) {
    .mr-content-{{ section.id }} {
      padding: {{ section.settings.content_pad_y | times: 0.7 | round: 0 }}px {{ section.settings.content_pad_x | times: 0.7 | round: 0 }}px;
    }
    .mr-heading-{{ section.id }} { font-size: var(--font-h2-size); }
    .mr-btn-row-{{ section.id }} { justify-content: center; }

    .mr-corner-{{ section.id }} {
      padding: {{ section.settings.content_pad_y | times: 0.55 | round: 0 }}px {{ section.settings.content_pad_x | times: 0.55 | round: 0 }}px;
    }
    .mr-arrow-btn-{{ section.id }} {
      width: {{ section.settings.corner_btn_size_mobile }}px;
      height: {{ section.settings.corner_btn_size_mobile }}px;
      right: {{ section.settings.corner_btn_offset | times: 0.6 | round: 0 }}px;
      bottom: {{ section.settings.corner_btn_offset | times: 0.6 | round: 0 }}px;
    }
    .mr-corner-text-{{ section.id }} { padding-right: {{ section.settings.corner_btn_size_mobile | plus: 16 }}px; }
  }

  {%- comment -%} ===== Mobile custom layout (portrait media + bottom content + single CTA) ===== {%- endcomment -%}
  {%- if section.settings.mobile_custom_layout -%}
    {%- assign mov_r = section.settings.mobile_overlay_color | color_extract: 'red' -%}
    {%- assign mov_g = section.settings.mobile_overlay_color | color_extract: 'green' -%}
    {%- assign mov_b = section.settings.mobile_overlay_color | color_extract: 'blue' -%}
    {%- assign mov_grad = section.settings.mobile_gradient_strength | divided_by: 100.0 -%}
    {%- assign mov_op = section.settings.mobile_overlay_opacity | divided_by: 100.0 -%}

    /* Mobile-only elements are hidden on desktop */
    .mr-media-mobile-{{ section.id }},
    .mr-m-gradient-{{ section.id }},
    .mr-m-content-{{ section.id }} { display: none; }

    @media (max-width: 749px) {
      .mr-row-{{ section.id }} { border-radius: 0; }

      /* Media fills the card; the mobile aspect-ratio setting handles portrait sizing */
      .mr-media-{{ section.id }} > img,
      .mr-media-{{ section.id }} .mr-video-wrap > video { object-fit: cover; }

      /* Swap to mobile media when provided; otherwise desktop media stays (fallback) */
      .mr-row-{{ section.id }}[data-mobile-media="true"] .mr-media-desktop-{{ section.id }} { display: none; }
      .mr-media-mobile-{{ section.id }} { display: block; }

      {%- comment -%} Overlay layout swaps to the single-CTA design; Corner layout keeps its heading + arrow on mobile {%- endcomment -%}
      {%- if section.settings.content_layout == 'overlay' -%}
      .mr-row-{{ section.id }} .mr-media-{{ section.id }} { height: {{ section.settings.mobile_card_height }}vh !important; aspect-ratio: auto !important; }
      .mr-content-{{ section.id }},
      .mr-overlay-{{ section.id }} { display: none !important; }

      /* Subtle bottom gradient for legibility (no big translucent box) */
      .mr-m-gradient-{{ section.id }} {
        display: block;
        position: absolute;
        inset: 0;
        z-index: 2;
        pointer-events: none;
        background-image: linear-gradient(to top, rgba({{ mov_r }},{{ mov_g }},{{ mov_b }},{{ mov_grad }}) 0%, rgba({{ mov_r }},{{ mov_g }},{{ mov_b }},0) 58%);
        {%- if mov_op > 0 %}background-color: rgba({{ mov_r }},{{ mov_g }},{{ mov_b }},{{ mov_op }});{%- endif %}
      }

      /* Bottom-aligned editorial content */
      .mr-m-content-{{ section.id }} {
        display: flex;
        position: absolute;
        inset: 0;
        z-index: 3;
        flex-direction: column;
        justify-content: flex-end;
        gap: 14px;
        padding: 24px 22px calc(24px + env(safe-area-inset-bottom, 0px));
        pointer-events: none;
      }
      .mr-m-content-{{ section.id }} > * { pointer-events: auto; }
      .mr-m-content-{{ section.id }}[data-mpos="bottom-left"]   { align-items: flex-start; text-align: left; }
      .mr-m-content-{{ section.id }}[data-mpos="bottom-center"] { align-items: center;     text-align: center; }
      .mr-m-content-{{ section.id }}[data-mpos="bottom-right"]  { align-items: flex-end;    text-align: right; }

      .mr-m-eyebrow-{{ section.id }} {
        margin: 0;
        color: #fff;
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        opacity: 0.9;
        text-shadow: 0 1px 6px rgba(0,0,0,0.5);
      }
      .mr-m-heading-{{ section.id }} {
        margin: 0;
        color: #fff;
        font-size: {{ section.settings.mobile_heading_size }}px;
        font-weight: {{ section.settings.mobile_heading_weight }};
        line-height: 1.08;
        letter-spacing: -0.01em;
        text-shadow: 0 2px 14px rgba(0,0,0,0.55);
      }
      .mr-m-btn-{{ section.id }} {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 26px;
        margin-top: 4px;
        font-size: {{ section.settings.mobile_button_size }}px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #111111;
        background: #ffffff;
        border-radius: 2px;
        text-decoration: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.28);
        transition: transform 0.2s ease, opacity 0.2s ease;
      }
      .mr-m-btn-{{ section.id }}:active { transform: scale(0.98); }
      {%- endif -%}
    }
    @media (prefers-reduced-motion: reduce) {
      .mr-m-btn-{{ section.id }} { transition: none; }
    }
  {%- endif -%}
{%- endstyle -%}

<section class="mr-section-{{ section.id }}">

  {%- comment -%} Optional section-level heading {%- endcomment -%}
  {%- if section.settings.section_heading != blank -%}
    <div class="mr-section-heading-{{ section.id }}">
      <h2 class="mr-section-title-{{ section.id }}">{{ section.settings.section_heading }}</h2>
    </div>
  {%- endif -%}

  <div class="mr-rows-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'row' -%}

        {%- comment -%} Build per-row CSS vars for overlay + button colours {%- endcomment -%}
        {%- assign row_vars = "" -%}
        {%- if block.settings.overlay_color != blank and block.settings.overlay_opacity > 0 -%}
          {%- assign ov_r = block.settings.overlay_color | color_extract: 'red' -%}
          {%- assign ov_g = block.settings.overlay_color | color_extract: 'green' -%}
          {%- assign ov_b = block.settings.overlay_color | color_extract: 'blue' -%}
          {%- assign ov_a = block.settings.overlay_opacity | divided_by: 100.0 -%}
          {%- assign ov_val = "rgba(" | append: ov_r | append: "," | append: ov_g | append: "," | append: ov_b | append: "," | append: ov_a | append: ")" -%}
          {%- assign row_vars = row_vars | append: "--mr-overlay-color:" | append: ov_val | append: ";" -%}
        {%- endif -%}
        {%- if block.settings.btn1_bg != blank -%}{%- assign row_vars = row_vars | append: "--mr-btn1-bg:" | append: block.settings.btn1_bg | append: ";" -%}{%- endif -%}
        {%- if block.settings.btn1_color != blank -%}{%- assign row_vars = row_vars | append: "--mr-btn1-color:" | append: block.settings.btn1_color | append: ";" -%}{%- endif -%}
        {%- if block.settings.btn1_border != blank -%}{%- assign row_vars = row_vars | append: "--mr-btn1-border:" | append: block.settings.btn1_border | append: ";" -%}{%- endif -%}
        {%- if block.settings.btn2_bg != blank -%}{%- assign row_vars = row_vars | append: "--mr-btn2-bg:" | append: block.settings.btn2_bg | append: ";" -%}{%- endif -%}
        {%- if block.settings.btn2_color != blank -%}{%- assign row_vars = row_vars | append: "--mr-btn2-color:" | append: block.settings.btn2_color | append: ";" -%}{%- endif -%}
        {%- if block.settings.btn2_border != blank -%}{%- assign row_vars = row_vars | append: "--mr-btn2-border:" | append: block.settings.btn2_border | append: ";" -%}{%- endif -%}
        {%- if block.settings.row_height_override > 0 -%}
          {%- assign row_vars = row_vars | append: "--mr-row-h:" | append: block.settings.row_height_override | append: "px;" -%}
        {%- endif -%}
        {%- if block.settings.row_height_mobile_override > 0 -%}
          {%- assign row_vars = row_vars | append: "--mr-row-h-mobile:" | append: block.settings.row_height_mobile_override | append: "px;" -%}
        {%- endif -%}
        {%- if block.settings.row_aspect_override != blank -%}
          {%- assign row_vars = row_vars | append: "--mr-ratio:" | append: block.settings.row_aspect_override | append: ";" -%}
        {%- endif -%}
        {%- assign content_color = block.settings.content_color | default: '#ffffff' -%}
        {%- if block.settings.content_box_color != blank and block.settings.content_box_opacity > 0 -%}
          {%- assign cb_r = block.settings.content_box_color | color_extract: 'red' -%}
          {%- assign cb_g = block.settings.content_box_color | color_extract: 'green' -%}
          {%- assign cb_b = block.settings.content_box_color | color_extract: 'blue' -%}
          {%- assign cb_a = block.settings.content_box_opacity | divided_by: 100.0 -%}
          {%- assign cb_val = "rgba(" | append: cb_r | append: "," | append: cb_g | append: "," | append: cb_b | append: "," | append: cb_a | append: ")" -%}
          {%- assign row_vars = row_vars | append: "--mr-content-box-bg:" | append: cb_val | append: ";" -%}
          {%- assign row_vars = row_vars | append: "--mr-content-box-pad:" | append: block.settings.content_box_padding | append: "px;" -%}
          {%- assign row_vars = row_vars | append: "--mr-content-box-radius:" | append: block.settings.content_box_radius | append: "px;" -%}
        {%- endif -%}

        {%- comment -%} Resolve mobile media presence for layout + fallback {%- endcomment -%}
        {%- assign mr_mobile_on = section.settings.mobile_custom_layout -%}
        {%- assign mr_has_mobile = false -%}
        {%- if block.settings.mobile_image != blank or block.settings.mobile_video != blank -%}
          {%- assign mr_has_mobile = true -%}
        {%- endif -%}

        <div
          class="mr-row-{{ section.id }}"
          data-align-h="{{ block.settings.align_h }}"
          data-align-v="{{ block.settings.align_v }}"
          data-height-mode="{{ section.settings.height_mode }}"
          data-mobile-media="{{ mr_has_mobile }}"
          style="{{ row_vars }}"
          {{ block.shopify_attributes }}
        >

          {%- comment -%} Media — separate desktop & mobile sources. Videos are
            JS-loaded by viewport (data-mq) so desktop video never loads on mobile
            and vice-versa. Desktop video only loads on mobile as a fallback when
            no dedicated mobile media is set. {%- endcomment -%}
          {%- liquid
            assign d_image = block.settings.image
            assign d_video = block.settings.video
            assign m_image = block.settings.mobile_image
            assign m_video = block.settings.mobile_video
            assign d_video_mq = ''
            if mr_mobile_on and mr_has_mobile
              assign d_video_mq = '(min-width: 750px)'
            endif
          -%}
          <div class="mr-media-{{ section.id }}">
            {%- comment -%} Desktop / default media {%- endcomment -%}
            {%- if d_video != blank -%}
              <div class="mr-video-wrap mr-media-desktop-{{ section.id }}">
                <video data-mr-video {% if d_video_mq != blank %}data-mq="{{ d_video_mq }}"{% endif %} muted loop playsinline preload="none"{% if d_image != blank %} poster="{{ d_image | image_url: width: 2000 }}"{% endif %}>
                  {%- for source in d_video.sources -%}<source data-src="{{ source.url }}" type="{{ source.mime_type }}">{%- endfor -%}
                </video>
              </div>
            {%- elsif d_image != blank -%}
              <img class="mr-media-desktop-{{ section.id }}" src="{{ d_image | image_url: width: 2400 }}" alt="{{ d_image.alt | default: block.settings.heading | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" width="{{ d_image.width }}" height="{{ d_image.height }}">
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            {%- comment -%} Dedicated mobile media (only rendered when custom mobile layout + mobile media set) {%- endcomment -%}
            {%- if mr_mobile_on and mr_has_mobile -%}
              {%- if m_video != blank -%}
                <div class="mr-video-wrap mr-media-mobile-{{ section.id }}">
                  <video data-mr-video data-mq="(max-width: 749px)" muted loop playsinline preload="none"{% if m_image != blank %} poster="{{ m_image | image_url: width: 1200 }}"{% endif %}>
                    {%- for source in m_video.sources -%}<source data-src="{{ source.url }}" type="{{ source.mime_type }}">{%- endfor -%}
                  </video>
                </div>
              {%- elsif m_image != blank -%}
                <img class="mr-media-mobile-{{ section.id }}" src="{{ m_image | image_url: width: 1200 }}" alt="{{ m_image.alt | default: block.settings.heading | escape }}" loading="lazy" width="{{ m_image.width }}" height="{{ m_image.height }}">
              {%- endif -%}
            {%- endif -%}
          </div>

          {%- comment -%} Overlay tint {%- endcomment -%}
          <div class="mr-overlay-{{ section.id }}"></div>

          {%- comment -%} Content {%- endcomment -%}
          {%- assign has_content = false -%}
          {%- if block.settings.eyebrow != blank or block.settings.heading != blank or block.settings.subheading != blank or block.settings.btn1_label != blank or block.settings.btn2_label != blank -%}
            {%- assign has_content = true -%}
          {%- endif -%}

          {%- if section.settings.content_layout == 'corner' -%}
            {%- comment -%} Corner layout: text bottom-left, arrow button bottom-right {%- endcomment -%}
            {%- if block.settings.btn1_link != blank -%}
              <a
                class="mr-row-link-{{ section.id }}"
                href="{{ block.settings.btn1_link }}"
                aria-hidden="true"
                tabindex="-1"
              ></a>
            {%- endif -%}
            {%- if has_content -%}
              <div class="mr-corner-{{ section.id }}" style="color: {{ content_color }};">
                <div class="mr-corner-text-{{ section.id }}">
                  {%- if block.settings.eyebrow != blank -%}
                    <p class="mr-eyebrow-{{ section.id }}">{{ block.settings.eyebrow | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.heading != blank -%}
                    <h2 class="mr-heading-{{ section.id }}">{{ block.settings.heading }}</h2>
                  {%- endif -%}
                  {%- if block.settings.subheading != blank -%}
                    <p class="mr-subheading-{{ section.id }}">{{ block.settings.subheading }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
            {%- if block.settings.btn1_link != blank or block.settings.btn1_label != blank -%}
              <a
                class="mr-arrow-btn-{{ section.id }}"
                href="{{ block.settings.btn1_link | default: '#' }}"
                aria-label="{{ block.settings.btn1_label | default: block.settings.heading | strip_html | escape | default: 'View' }}"
              >
                <svg viewBox="0 0 24 24"><path d="M7 17L17 7M7 7h10v10"/></svg>
              </a>
            {%- endif -%}

          {%- elsif has_content -%}
            <div class="mr-content-{{ section.id }}" style="color: {{ content_color }};">
              <div class="mr-content-inner-{{ section.id }}">

                {%- if block.settings.eyebrow != blank -%}
                  <p class="mr-eyebrow-{{ section.id }}">{{ block.settings.eyebrow | escape }}</p>
                {%- endif -%}

                {%- if block.settings.heading != blank -%}
                  <h2 class="mr-heading-{{ section.id }}">{{ block.settings.heading }}</h2>
                {%- endif -%}

                {%- if block.settings.subheading != blank -%}
                  <p class="mr-subheading-{{ section.id }}">{{ block.settings.subheading }}</p>
                {%- endif -%}

                {%- if block.settings.btn1_label != blank or block.settings.btn2_label != blank -%}
                  <div class="mr-btn-row-{{ section.id }}">
                    {%- if block.settings.btn1_label != blank -%}
                      <a class="mr-btn-{{ section.id }} mr-btn-primary-{{ section.id }}" href="{{ block.settings.btn1_link | default: '#' }}">
                        {{ block.settings.btn1_label }}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.btn2_label != blank -%}
                      <a class="mr-btn-{{ section.id }} mr-btn-secondary-{{ section.id }}" href="{{ block.settings.btn2_link | default: '#' }}">
                        {{ block.settings.btn2_label }}
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}

              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Mobile single-CTA overlay — Overlay layout only (Corner keeps its heading + arrow) ───── {%- endcomment -%}
          {%- if mr_mobile_on and section.settings.content_layout == 'overlay' -%}
            <div class="mr-m-gradient-{{ section.id }}" aria-hidden="true"></div>
            {%- assign m_heading = block.settings.mobile_heading | default: block.settings.heading -%}
            {%- assign m_btn_label = block.settings.mobile_button_label | default: block.settings.btn1_label -%}
            {%- assign m_btn_link = block.settings.mobile_button_link | default: block.settings.btn1_link -%}
            {%- if m_heading != blank or m_btn_label != blank -%}
              <div class="mr-m-content-{{ section.id }}" data-mpos="{{ section.settings.mobile_content_position }}">
                {%- if block.settings.eyebrow != blank -%}
                  <p class="mr-m-eyebrow-{{ section.id }}">{{ block.settings.eyebrow | escape }}</p>
                {%- endif -%}
                {%- if m_heading != blank -%}
                  <h3 class="mr-m-heading-{{ section.id }}">{{ m_heading }}</h3>
                {%- endif -%}
                {%- if m_btn_label != blank -%}
                  <a class="mr-m-btn-{{ section.id }}" href="{{ m_btn_link | default: '#' }}">{{ m_btn_label }}</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

</section>

<script>
  (function () {
    var section = document.querySelector('.mr-section-{{ section.id }}');
    if (!section) return;

    /* Load a video's sources only when its viewport (data-mq) matches, so the
       desktop video never downloads on mobile and vice-versa. */
    function loadVideo(v) {
      var mq = v.getAttribute('data-mq');
      if (mq && window.matchMedia && !window.matchMedia(mq).matches) return;
      if (v.dataset.mrLoaded === '1') { play(v); return; }
      v.querySelectorAll('source[data-src]').forEach(function (s) {
        if (!s.getAttribute('src')) s.setAttribute('src', s.getAttribute('data-src'));
      });
      v.dataset.mrLoaded = '1';
      v.muted = true;
      v.loop = true;
      v.load();
      v.addEventListener('loadeddata', function () { play(v); });
      play(v);
    }
    function play(v) { var p = v.play(); if (p && p.catch) p.catch(function () {}); }

    function run() {
      section.querySelectorAll('video[data-mr-video]').forEach(loadVideo);
    }
    run();

    /* On breakpoint change, load the now-matching video */
    var t;
    window.addEventListener('resize', function () {
      clearTimeout(t);
      t = setTimeout(run, 250);
    }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Media Rows",
  "tag": "section",
  "class": "section-media-rows",
  "max_blocks": 6,
  "blocks": [
    {
