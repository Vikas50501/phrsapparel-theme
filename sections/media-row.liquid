        { "type": "video",         "id": "video",   "label": "Desktop video" },

        { "type": "header",       "content": "Media — Mobile" },
        { "type": "paragraph",     "content": "Optional. If empty, the desktop media is used on mobile too." },
        { "type": "image_picker", "id": "mobile_image",   "label": "Mobile image (portrait 9:16)" },
        { "type": "video",         "id": "mobile_video",   "label": "Mobile video (portrait 9:16)" },

        { "type": "header",       "content": "Mobile content (optional overrides)" },
        { "type": "text",          "id": "mobile_heading",       "label": "Mobile heading",       "info": "Falls back to the heading below." },
        { "type": "text",          "id": "mobile_button_label",  "label": "Mobile button label",  "info": "Falls back to Button 1 label." },
        { "type": "url",           "id": "mobile_button_link",   "label": "Mobile button link",   "info": "Falls back to Button 1 link." },

        { "type": "header",   "content": "Row size (overrides section default)" },
