{%- comment -%}
  Media Rows — editorial corner layout.
  Per row: separate desktop & mobile media (image OR video), independent aspect
  ratios, heading + circular arrow button in opposite corners, bottom gradient.
  Theme typography. Videos load only for the matching viewport (data-mq).
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign g_r = s.gradient_color | default: '#000000' | color_extract: 'red'
  assign g_g = s.gradient_color | default: '#000000' | color_extract: 'green'
  assign g_b = s.gradient_color | default: '#000000' | color_extract: 'blue'
-%}

{% style %}
  .mr-{{ section.id }} {
    background: {{ s.bg_color }};
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .mr-{{ section.id }} {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }
  .mr-{{ section.id }}__inner {
    max-width: {% if s.full_width %}none{% else %}{{ s.max_width }}px{% endif %};
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ s.row_gap }}px;
    padding: 0 {% if s.full_width %}0{% else %}{{ s.side_padding }}px{% endif %};
  }
  .mr-{{ section.id }}__row {
    position: relative;
    isolation: isolate; /* keeps the arrow/heading layered inside the row, never over the sticky header */
    overflow: hidden;
    border-radius: {% if s.full_width %}0{% else %}{{ s.row_radius }}px{% endif %};
    text-decoration: none;
    display: block;
  }
  .mr-{{ section.id }}__media {
    position: relative;
    width: 100%;
    aspect-ratio: {{ s.desktop_aspect }};
    overflow: hidden;
    background: #111;
  }
  @media screen and (max-width: 749px) {
    .mr-{{ section.id }}__media { aspect-ratio: {{ s.mobile_aspect }}; }
  }
  .mr-{{ section.id }}__media img,
  .mr-{{ section.id }}__media video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  {%- if s.hover_zoom %}
  .mr-{{ section.id }}__row:hover img,
  .mr-{{ section.id }}__row:hover video { transform: scale(1.04); }
  {%- endif %}

  /* Bottom gradient scrim */
  .mr-{{ section.id }}__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(to top, rgba({{ g_r }},{{ g_g }},{{ g_b }},{{ s.gradient_strength | divided_by: 100.0 }}) 0%, rgba({{ g_r }},{{ g_g }},{{ g_b }},0) 55%);
  }
  {%- if s.top_gradient_strength > 0 %}
  /* Top gradient scrim — keeps the site header readable over the video */
  .mr-{{ section.id }}__scrim-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: {{ s.top_gradient_height }}%;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(0,0,0,{{ s.top_gradient_strength | divided_by: 100.0 }}) 0%, rgba(0,0,0,0) 100%);
  }
  {%- endif %}
  {%- if s.overlay_opacity > 0 %}
  .mr-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: {{ s.overlay_color }};
    opacity: {{ s.overlay_opacity | divided_by: 100.0 }};
  }
  {%- endif %}

  /* Heading content */
  .mr-{{ section.id }}__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: {{ s.content_padding }}px;
    pointer-events: none;
  }
  .mr-{{ section.id }}__content[data-pos="left"]   { align-items: flex-start; text-align: left; }
  .mr-{{ section.id }}__content[data-pos="center"] { align-items: center;     text-align: center; }
  .mr-{{ section.id }}__content[data-pos="right"]  { align-items: flex-end;   text-align: right; }
  .mr-{{ section.id }}__text { max-width: 80%; padding-right: {{ s.arrow_size | plus: 24 }}px; }
  .mr-{{ section.id }}__eyebrow {
    margin: 0 0 8px;
    color: {{ s.text_color }};
    font-size: 1.2rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.9;
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
  }
  .mr-{{ section.id }}__heading {
    margin: 0;
    color: var(--mr-hcolor, {{ s.text_color }});
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: var(--mr-hd, var(--font-h2-size));
    line-height: 1.1;
    text-transform: uppercase;
    text-shadow: 0 2px 16px rgba(0,0,0,0.5);
  }
  @media screen and (max-width: 749px) {
    .mr-{{ section.id }}__heading { font-size: var(--mr-hm, {{ s.heading_size_mobile }}px); }
  }
  .mr-{{ section.id }}__sub {
    margin: 10px 0 0;
    color: {{ s.text_color }};
    font-size: 1.4rem;
    line-height: 1.5;
    opacity: 0.92;
    text-shadow: 0 1px 8px rgba(0,0,0,0.5);
  }

  /* Circular arrow button (opposite corner) */
  .mr-{{ section.id }}__arrow {
    position: absolute;
    z-index: 3;
    right: {{ s.arrow_offset }}px;
    bottom: {{ s.arrow_offset }}px;
    width: {{ s.arrow_size }}px;
    height: {{ s.arrow_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: {{ s.arrow_color }};
    border: 1.5px solid {{ s.arrow_color }};
    transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease;
    pointer-events: none;
  }
  .mr-{{ section.id }}__row:hover .mr-{{ section.id }}__arrow {
    background: {{ s.arrow_color }};
    color: {{ s.arrow_hover_text }};
    transform: scale(1.06);
  }
  @media screen and (max-width: 749px) {
    .mr-{{ section.id }}__arrow {
      width: {{ s.arrow_size_mobile }}px;
      height: {{ s.arrow_size_mobile }}px;
      right: {{ s.arrow_offset | times: 0.7 | round: 0 }}px;
      bottom: {{ s.arrow_offset | times: 0.7 | round: 0 }}px;
    }
  }
  .mr-{{ section.id }}__arrow svg { width: 42%; height: 42%; }

  /* Per-viewport media visibility */
  .mr-{{ section.id }}__d { display: block; }
  .mr-{{ section.id }}__m { display: none; }
  @media screen and (max-width: 749px) {
    .mr-{{ section.id }}__row[data-has-mobile="true"] .mr-{{ section.id }}__d { display: none; }
    .mr-{{ section.id }}__row[data-has-mobile="true"] .mr-{{ section.id }}__m { display: block; }
  }

  /* Section heading (centered + orange underline, matches the Lookbook section) */
  .mr-{{ section.id }}__title-wrap {
    text-align: center;
    margin-bottom: {{ s.row_gap | plus: 16 }}px;
  }
  .mr-{{ section.id }}__title {
    display: inline-block;
    position: relative;
    margin: 0;
    padding-bottom: 10px;
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: var(--font-h2-size);
    color: {{ s.heading_color }};
    text-transform: uppercase;
    line-height: 1.2;
  }
  .mr-{{ section.id }}__title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 3px;
    background: {{ s.underline_color | default: '#c47a5a' }};
    border-radius: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .mr-{{ section.id }}__media img,
    .mr-{{ section.id }}__media video,
    .mr-{{ section.id }}__arrow { transition: none; }
  }
{% endstyle %}

<div class="mr-{{ section.id }}">
  <div class="mr-{{ section.id }}__inner">

    {%- if s.section_heading != blank -%}
      <div class="mr-{{ section.id }}__title-wrap">
        <h2 class="mr-{{ section.id }}__title">{{ s.section_heading }}</h2>
      </div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- liquid
        assign has_mobile = false
        if block.settings.mobile_image != blank or block.settings.mobile_video != blank
          assign has_mobile = true
        endif
        assign d_video = false
        if block.settings.desktop_media_type == 'video' and block.settings.video != blank
          assign d_video = true
        endif
        assign m_video = false
        if block.settings.mobile_media_type == 'video' and block.settings.mobile_video != blank
          assign m_video = true
        endif
        assign tag = 'div'
        if block.settings.link != blank
          assign tag = 'a'
        endif
      -%}
      <{{ tag }}
        class="mr-{{ section.id }}__row"
        data-has-mobile="{{ has_mobile }}"
        {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
        {{ block.shopify_attributes }}
      >
        <div class="mr-{{ section.id }}__media">
          {%- comment -%} Desktop media {%- endcomment -%}
          <div class="mr-{{ section.id }}__d">
            {%- if d_video -%}
              <video class="mr-{{ section.id }}__video" data-mq="(min-width: 750px)" muted loop playsinline preload="none"
                {% if block.settings.image != blank %}poster="{{ block.settings.image | image_url: width: 1600 }}"{% endif %}>
                {%- for src in block.settings.video.sources -%}<source data-src="{{ src.url }}" type="{{ src.mime_type }}">{%- endfor -%}
              </video>
            {%- elsif block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 2000 }}"
                srcset="{{ block.settings.image | image_url: width: 1000 }} 1000w, {{ block.settings.image | image_url: width: 2000 }} 2000w"
                sizes="100vw" alt="{{ block.settings.image.alt | default: block.settings.heading | strip_html | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}">
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          {%- comment -%} Mobile media (only when set) {%- endcomment -%}
          {%- if has_mobile -%}
            <div class="mr-{{ section.id }}__m">
              {%- if m_video -%}
                <video class="mr-{{ section.id }}__video" data-mq="(max-width: 749px)" muted loop playsinline preload="none"
                  {% if block.settings.mobile_image != blank %}poster="{{ block.settings.mobile_image | image_url: width: 900 }}"{% endif %}>
                  {%- for src in block.settings.mobile_video.sources -%}<source data-src="{{ src.url }}" type="{{ src.mime_type }}">{%- endfor -%}
                </video>
              {%- elsif block.settings.mobile_image != blank -%}
                <img src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
                  alt="{{ block.settings.mobile_image.alt | default: block.settings.heading | strip_html | escape }}"
                  loading="lazy" width="{{ block.settings.mobile_image.width }}" height="{{ block.settings.mobile_image.height }}">
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if s.overlay_opacity > 0 -%}<div class="mr-{{ section.id }}__overlay"></div>{%- endif -%}
        {%- if s.top_gradient_strength > 0 -%}<div class="mr-{{ section.id }}__scrim-top"></div>{%- endif -%}
        <div class="mr-{{ section.id }}__scrim"></div>

        {%- if block.settings.eyebrow != blank or block.settings.heading != blank or block.settings.subheading != blank -%}
          <div class="mr-{{ section.id }}__content" data-pos="{{ s.content_position }}">
            <div class="mr-{{ section.id }}__text">
              {%- if block.settings.eyebrow != blank -%}<p class="mr-{{ section.id }}__eyebrow">{{ block.settings.eyebrow | escape }}</p>{%- endif -%}
              {%- if block.settings.heading != blank -%}
                {%- capture h_style -%}
                  {%- if block.settings.heading_color != blank %}--mr-hcolor:{{ block.settings.heading_color }};{% endif -%}
                  {%- if block.settings.heading_size_desktop > 0 %}--mr-hd:{{ block.settings.heading_size_desktop }}px;{% endif -%}
                  {%- if block.settings.heading_size_mobile > 0 %}--mr-hm:{{ block.settings.heading_size_mobile }}px;{% endif -%}
                {%- endcapture -%}
                <h3 class="mr-{{ section.id }}__heading"{% if h_style != blank %} style="{{ h_style | strip_newlines | strip }}"{% endif %}>{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.subheading != blank -%}<p class="mr-{{ section.id }}__sub">{{ block.settings.subheading }}</p>{%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if block.settings.link != blank or block.settings.heading != blank -%}
          <span class="mr-{{ section.id }}__arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        {%- endif -%}
      </{{ tag }}>
    {%- endfor -%}

  </div>
</div>

<script>
  (function () {
    var root = document.currentScript && document.currentScript.previousElementSibling;
    var scope = document.querySelector('.mr-{{ section.id }}');
    if (!scope) return;
    function loadVideo(v) {
      var mq = v.getAttribute('data-mq');
      if (mq && window.matchMedia && !window.matchMedia(mq).matches) return;
      if (v.dataset.loaded === '1') { v.play().catch(function(){}); return; }
      v.querySelectorAll('source[data-src]').forEach(function (s) { if (!s.getAttribute('src')) s.setAttribute('src', s.getAttribute('data-src')); });
      v.dataset.loaded = '1';
      v.muted = true; v.loop = true; v.load();
      v.addEventListener('loadeddata', function () { v.play().catch(function(){}); });
      v.play().catch(function(){});
    }
    function run() { scope.querySelectorAll('video[data-mq]').forEach(loadVideo); }
    run();
    var t;
    window.addEventListener('resize', function () { clearTimeout(t); t = setTimeout(run, 250); }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Media Rows",
  "tag": "section",
  "class": "section-media-rows",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Section heading (optional)" },
    { "type": "text", "id": "section_heading", "label": "Heading" },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#111111" },
    { "type": "color", "id": "underline_color", "label": "Heading underline colour", "default": "#c47a5a" },

    { "type": "header", "content": "Aspect ratio" },
    {
      "type": "select", "id": "desktop_aspect", "label": "Desktop aspect ratio",
      "options": [
        { "value": "21/9", "label": "21:9" },
        { "value": "16/9", "label": "16:9" },
        { "value": "3/2", "label": "3:2" },
        { "value": "4/3", "label": "4:3" },
        { "value": "1/1", "label": "1:1" },
        { "value": "4/5", "label": "4:5" },
        { "value": "3/4", "label": "3:4" }
      ],
      "default": "16/9"
    },
    {
      "type": "select", "id": "mobile_aspect", "label": "Mobile aspect ratio",
      "options": [
        { "value": "9/16", "label": "9:16" },
        { "value": "3/4", "label": "3:4" },
        { "value": "4/5", "label": "4:5" },
        { "value": "1/1", "label": "1:1" },
        { "value": "4/3", "label": "4:3" }
      ],
      "default": "9/16"
    },

    { "type": "header", "content": "Content & overlay" },
    {
      "type": "select", "id": "content_position", "label": "Heading position",
      "options": [
        { "value": "left", "label": "Bottom left" },
        { "value": "center", "label": "Bottom center" },
        { "value": "right", "label": "Bottom right" }
      ],
      "default": "left"
    },
    { "type": "color", "id": "text_color", "label": "Heading / text colour", "default": "#ffffff" },
    { "type": "range", "id": "content_padding", "label": "Content padding", "min": 12, "max": 64, "step": 2, "unit": "px", "default": 28 },
    { "type": "range", "id": "heading_size_mobile", "label": "Mobile heading size", "min": 18, "max": 48, "step": 1, "unit": "px", "default": 30 },
    { "type": "color", "id": "gradient_color", "label": "Bottom overlay colour", "default": "#000000" },
    { "type": "range", "id": "gradient_strength", "label": "Bottom overlay strength", "min": 0, "max": 95, "step": 5, "unit": "%", "default": 65 },
    { "type": "header", "content": "Top overlay (header readability)" },
    { "type": "range", "id": "top_gradient_strength", "label": "Top gradient strength", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 45 },
    { "type": "range", "id": "top_gradient_height", "label": "Top gradient height", "min": 10, "max": 60, "step": 5, "unit": "%", "default": 35 },
    { "type": "color", "id": "overlay_color", "label": "Overlay colour", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 0 },
    { "type": "checkbox", "id": "hover_zoom", "label": "Zoom media on hover", "default": true },

    { "type": "header", "content": "Arrow button" },
    { "type": "color", "id": "arrow_color", "label": "Arrow colour", "default": "#ffffff" },
    { "type": "color", "id": "arrow_hover_text", "label": "Arrow colour on hover (icon)", "default": "#111111" },
    { "type": "range", "id": "arrow_size", "label": "Size (desktop)", "min": 36, "max": 84, "step": 2, "unit": "px", "default": 56 },
    { "type": "range", "id": "arrow_size_mobile", "label": "Size (mobile)", "min": 30, "max": 64, "step": 2, "unit": "px", "default": 44 },
    { "type": "range", "id": "arrow_offset", "label": "Edge offset", "min": 8, "max": 48, "step": 2, "unit": "px", "default": 24 },

    { "type": "header", "content": "Layout & background" },
    { "type": "checkbox", "id": "full_width", "label": "Full width (no side padding)", "default": true },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max width (when not full width)", "min": 800, "max": 1800, "step": 20, "unit": "px", "default": 1400 },
    { "type": "range", "id": "side_padding", "label": "Side padding (when not full width)", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "row_gap", "label": "Gap between rows", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "row_radius", "label": "Corner radius", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Media row",
      "settings": [
        { "type": "header", "content": "Desktop media" },
        {
          "type": "select", "id": "desktop_media_type", "label": "Desktop media type",
          "options": [ { "value": "image", "label": "Image" }, { "value": "video", "label": "Video" } ],
          "default": "image"
        },
        { "type": "image_picker", "id": "image", "label": "Desktop image", "info": "Also used as video poster" },
        { "type": "video", "id": "video", "label": "Desktop video" },

        { "type": "header", "content": "Mobile media (optional)" },
        { "type": "paragraph", "content": "If empty, the desktop media is used on mobile too." },
        {
          "type": "select", "id": "mobile_media_type", "label": "Mobile media type",
          "options": [ { "value": "image", "label": "Image" }, { "value": "video", "label": "Video" } ],
          "default": "image"
        },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile image (portrait)" },
        { "type": "video", "id": "mobile_video", "label": "Mobile video (portrait)" },

        { "type": "header", "content": "Content" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "inline_richtext", "id": "heading", "label": "Heading" },
        { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#ffffff" },
        { "type": "range", "id": "heading_size_desktop", "label": "Heading size (desktop)", "min": 0, "max": 96, "step": 2, "unit": "px", "default": 0, "info": "0 = use theme default" },
        { "type": "range", "id": "heading_size_mobile", "label": "Heading size (mobile)", "min": 0, "max": 56, "step": 1, "unit": "px", "default": 0, "info": "0 = use section default" },
        { "type": "text", "id": "subheading", "label": "Subheading" },
        { "type": "url", "id": "link", "label": "Link (whole row + arrow)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Media Rows",
      "blocks": [ { "type": "row" }, { "type": "row" } ]
    }
  ]
}
{% endschema %}
