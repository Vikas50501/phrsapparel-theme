    {
      "type": "select", "id": "eyebrow_weight", "label": "Weight",
      "options": [{"value":"300","label":"Light"},{"value":"400","label":"Regular"},{"value":"500","label":"Medium"},{"value":"600","label":"Semi-bold"}],
