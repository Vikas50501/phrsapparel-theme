{%- style -%}
  /* ══════════════════════════════════════════════════════
     IMAGE DUO — Heading + wavy divider + 2 image cards
  ══════════════════════════════════════════════════════ */

  .id-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .id-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .id-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding }}px;
  }

  /* ── Heading block ─────────────────────────────────── */
  .id-heading-wrap-{{ section.id }} {
    text-align: center;
    margin-bottom: {{ section.settings.heading_gap }}px;
  }

  .id-heading-{{ section.id }} {
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    font-style: normal;
    font-family: inherit;
    color: {{ section.settings.heading_color }};
    letter-spacing: {{ section.settings.heading_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.heading_transform }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    margin: 0;
    padding: 0;
    max-width: {{ section.settings.heading_max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Wavy divider ─────────────────────────────────── */
  .id-wave-{{ section.id }} {
    display: flex;
    justify-content: center;
    margin-top: {{ section.settings.wave_gap_top }}px;
    margin-bottom: {{ section.settings.wave_gap_bottom }}px;
  }

  .id-wave-{{ section.id }} svg {
    width: {{ section.settings.wave_width }}px;
    height: auto;
    stroke: {{ section.settings.wave_color }};
    fill: none;
    stroke-width: {{ section.settings.wave_stroke }};
    stroke-linecap: round;
  }

  /* ── Cards grid ────────────────────────────────────── */
  .id-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  @media (max-width: 749px) {
    .id-grid-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: {{ section.settings.grid_gap | divided_by: 2 }}px;
    }
  }

  /* ── Card ──────────────────────────────────────────── */
  .id-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .id-card-img-{{ section.id }} {
    width: 100%;
    aspect-ratio: {{ section.settings.image_aspect }};
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
    background: {{ section.settings.image_placeholder_bg }};
  }

  .id-card-img-{{ section.id }} img,
  .id-card-img-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .id-card-{{ section.id }}:hover .id-card-img-{{ section.id }} img {
    transform: scale({{ section.settings.image_hover_scale | divided_by: 100.0 }});
  }

  /* ── Card content below image ──────────────────────── */
  .id-card-info-{{ section.id }} {
    text-align: center;
    padding-top: {{ section.settings.info_gap }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ section.settings.title_link_gap }}px;
  }

  .id-card-title-{{ section.id }} {
    font-size: var(--font-h3-size);
    font-weight: var(--font-h3-weight);
    font-style: normal;
    font-family: inherit;
    color: {{ section.settings.card_title_color }};
    letter-spacing: {{ section.settings.card_title_spacing | divided_by: 100.0 }}em;
    line-height: 1.25;
    margin: 0;
    padding: 0;
  }

  /* ── Card link — "SHOP THE LOOK" style ─────────────── */
  .id-card-link-{{ section.id }} {
    display: inline-block;
    font-size: {{ section.settings.link_size }}px;
    font-weight: {{ section.settings.link_weight }};
    color: {{ section.settings.link_color }};
    letter-spacing: {{ section.settings.link_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.link_transform }};
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition: color 0.25s;
  }

  .id-card-link-{{ section.id }}::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: {{ section.settings.link_underline_thickness }}px;
    background: {{ section.settings.link_underline_color }};
    transition: background 0.25s, transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    transform-origin: center;
  }

  .id-card-{{ section.id }}:hover .id-card-link-{{ section.id }} {
    color: {{ section.settings.link_color_hover }};
  }

  .id-card-{{ section.id }}:hover .id-card-link-{{ section.id }}::after {
    background: {{ section.settings.link_underline_color_hover }};
    transform: scaleX(1.1);
  }
{%- endstyle -%}

<section class="id-section-{{ section.id }}">
  <div class="id-inner-{{ section.id }}">

    {%- comment -%} Heading {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <div class="id-heading-wrap-{{ section.id }}">
        <h2 class="id-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    {%- comment -%} Wavy divider {%- endcomment -%}
    {%- if section.settings.show_wave -%}
      <div class="id-wave-{{ section.id }}" aria-hidden="true">
        <svg viewBox="0 0 80 10" xmlns="http://www.w3.org/2000/svg">
          <path d="M 2 5 Q 10 0, 18 5 T 34 5 T 50 5 T 66 5 T 78 5"/>
        </svg>
      </div>
    {%- endif -%}

    {%- comment -%} Cards grid {%- endcomment -%}
    <div class="id-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          {%- assign tag = 'div' -%}
          {%- if block.settings.link != blank -%}
            {%- assign tag = 'a' -%}
          {%- endif -%}
          {%- assign card_href = block.settings.link | default: '#' -%}

          <{{ tag }}
            class="id-card-{{ section.id }}"
            {% if tag == 'a' %}href="{{ card_href }}"{% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="id-card-img-{{ section.id }}">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | img_url: '1200x' }}"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="id-card-info-{{ section.id }}">
              {%- if block.settings.title != blank -%}
                <h3 class="id-card-title-{{ section.id }}">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.link_label != blank -%}
                <span class="id-card-link-{{ section.id }}">{{ block.settings.link_label }}</span>
              {%- endif -%}
            </div>
          </{{ tag }}>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Image Duo",
  "tag": "section",
  "class": "section-image-duo",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "card",
      "name": "Image card",
      "settings": [
        { "type": "image_picker", "id": "image",      "label": "Image" },
        { "type": "text",         "id": "title",      "label": "Title",       "default": "Card title" },
        { "type": "text",         "id": "link_label", "label": "Link label",  "default": "SHOP THE LOOK" },
        { "type": "url",          "id": "link",       "label": "Card link",   "info": "Clicking anywhere on the card goes here" }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading",
      "default": "Products featuring the thing you love by an artist who loves it too." },
    { "type": "range",  "id": "heading_size", "label": "Heading size",
      "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },
    {
      "type": "select", "id": "heading_weight", "label": "Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select", "id": "heading_transform", "label": "Case",
      "options": [
        { "value": "none",       "label": "As typed" },
        { "value": "uppercase",  "label": "UPPERCASE" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    { "type": "range", "id": "heading_spacing", "label": "Letter spacing",
      "min": 0, "max": 20, "step": 1, "unit": "em", "default": 0,
      "info": "Divided by 100" },
    { "type": "range", "id": "heading_line_height", "label": "Line height",
      "min": 90, "max": 200, "step": 5, "unit": "%", "default": 125,
      "info": "Divided by 100" },
    { "type": "range", "id": "heading_max_width", "label": "Max width",
      "min": 400, "max": 1200, "step": 20, "unit": "px", "default": 900 },
    { "type": "color", "id": "heading_color", "label": "Colour", "default": "#111111" },
    { "type": "range", "id": "heading_gap", "label": "Gap below heading",
      "min": 0, "max": 60, "step": 2, "unit": "px", "default": 8 },

    { "type": "header", "content": "Wavy divider" },
    { "type": "checkbox", "id": "show_wave", "label": "Show wavy divider", "default": true },
    { "type": "range", "id": "wave_width", "label": "Wave width",
      "min": 40, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "wave_stroke", "label": "Wave thickness",
      "min": 1, "max": 4, "step": 1, "unit": "px", "default": 2 },
    { "type": "color", "id": "wave_color", "label": "Wave colour", "default": "#111111" },
    { "type": "range", "id": "wave_gap_top", "label": "Gap above wave",
      "min": 0, "max": 40, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "wave_gap_bottom", "label": "Gap below wave",
      "min": 0, "max": 80, "step": 4, "unit": "px", "default": 40 },

    { "type": "header", "content": "Grid layout" },
    { "type": "range", "id": "columns", "label": "Columns",
      "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "grid_gap", "label": "Gap between cards",
      "min": 8, "max": 60, "step": 2, "unit": "px", "default": 24 },

    { "type": "header", "content": "Card image" },
    {
      "type": "select", "id": "image_aspect", "label": "Image aspect ratio",
      "options": [
        { "value": "16/9",  "label": "Widescreen (16:9)" },
        { "value": "4/3",   "label": "Landscape (4:3)" },
        { "value": "1/1",   "label": "Square" },
        { "value": "4/5",   "label": "Portrait (4:5)" },
        { "value": "3/4",   "label": "Portrait (3:4)" },
        { "value": "3/2",   "label": "Landscape (3:2)" }
      ],
      "default": "4/3"
    },
    { "type": "range", "id": "image_radius", "label": "Corner radius",
      "min": 0, "max": 40, "step": 2, "unit": "px", "default": 4 },
    { "type": "range", "id": "image_hover_scale", "label": "Hover zoom",
      "min": 100, "max": 115, "step": 1, "unit": "%", "default": 104,
      "info": "100 = no zoom" },
    { "type": "color", "id": "image_placeholder_bg", "label": "Placeholder background",
      "default": "#f0efed" },

    { "type": "header", "content": "Card title" },
    { "type": "range", "id": "card_title_size", "label": "Size",
      "min": 16, "max": 60, "step": 2, "unit": "px", "default": 30 },
    {
      "type": "select", "id": "card_title_weight", "label": "Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    { "type": "range", "id": "card_title_spacing", "label": "Letter spacing",
      "min": 0, "max": 20, "step": 1, "unit": "em", "default": 0 },
    { "type": "color", "id": "card_title_color", "label": "Colour", "default": "#111111" },

    { "type": "header", "content": "Card link (underlined)" },
    { "type": "range", "id": "link_size", "label": "Size",
      "min": 10, "max": 18, "step": 1, "unit": "px", "default": 13 },
    {
      "type": "select", "id": "link_weight", "label": "Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ],
      "default": "500"
    },
    {
      "type": "select", "id": "link_transform", "label": "Case",
      "options": [
        { "value": "uppercase",  "label": "UPPERCASE" },
        { "value": "none",       "label": "As typed" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    { "type": "range", "id": "link_spacing", "label": "Letter spacing",
      "min": 0, "max": 40, "step": 2, "unit": "em", "default": 10 },
    { "type": "color", "id": "link_color",             "label": "Text colour",          "default": "#111111" },
    { "type": "color", "id": "link_color_hover",       "label": "Text — hover",         "default": "#666666" },
    { "type": "range", "id": "link_underline_thickness", "label": "Underline thickness",
      "min": 1, "max": 3, "step": 1, "unit": "px", "default": 1 },
    { "type": "color", "id": "link_underline_color",       "label": "Underline colour",   "default": "#111111" },
    { "type": "color", "id": "link_underline_color_hover", "label": "Underline — hover",  "default": "#666666" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "info_gap", "label": "Gap: image to title",
      "min": 8, "max": 48, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "title_link_gap", "label": "Gap: title to link",
      "min": 4, "max": 24, "step": 2, "unit": "px", "default": 14 },

    { "type": "header", "content": "Section background & padding" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max width",
      "min": 800, "max": 1800, "step": 20, "unit": "px", "default": 1400 },
    { "type": "range", "id": "side_padding", "label": "Side padding",
      "min": 0, "max": 80, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top", "label": "Top padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [
    {
      "name": "Image Duo",
      "blocks": [
        { "type": "card", "settings": { "title": "Gifts For Dads & Grads" } },
        { "type": "card", "settings": { "title": "Memorial Day Sale" } }
      ]
    }
  ]
}
{% endschema %}
