{%- style -%}
  /* ══════════════════════════════════════════════════════
     RELATED PRODUCTS — Prestige edition (clean rewrite)
     All setting IDs use v3 suffix to avoid cached conflicts.
  ══════════════════════════════════════════════════════ */

  .rp-section-{{ section.id }} {
    background: {{ section.settings.bg_color_v3 }};
    color: {{ section.settings.text_color_v3 }};
    padding-top: {{ section.settings.padding_top_v3 | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom_v3 | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .rp-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_v3 }}px;
      padding-bottom: {{ section.settings.padding_bottom_v3 }}px;
    }
  }

  .rp-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width_v3 }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Header ────────────────────────────────────────── */
  .rp-header-{{ section.id }} {
    display: flex;
    justify-content: {{ section.settings.heading_block_pos_v3 }};
    margin-bottom: {{ section.settings.header_gap_v3 }}px;
  }

  .rp-heading-{{ section.id }} {
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    font-style: normal;
    color: {{ section.settings.heading_color_v3 }};
    letter-spacing: {{ section.settings.heading_spacing_v3 | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.heading_transform_v3 }};
    line-height: {{ section.settings.heading_line_height_v3 | divided_by: 100.0 }};
    text-align: {{ section.settings.heading_text_align_v3 }};
    max-width: {{ section.settings.heading_max_width_v3 }}px;
    margin: 0;
    padding-bottom: {{ section.settings.heading_underline_gap_v3 }}px;
    position: relative;
    display: inline-block;
  }

  .rp-heading-{{ section.id }}[data-underline="true"]::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: {{ section.settings.heading_underline_width_v3 }}px;
    height: {{ section.settings.heading_underline_thickness_v3 }}px;
    background: {{ section.settings.heading_underline_color_v3 }};
  }

  .rp-heading-{{ section.id }}[data-underline="true"][data-halign="center"]::after {
    left: 50%;
    transform: translateX(-50%);
  }

  .rp-heading-{{ section.id }}[data-underline="true"][data-halign="right"]::after {
    left: auto;
    right: 0;
  }

  /* ── Grid — every card gets equal size ──────────────── */
  .rp-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile_v3 }}, 1fr);
    gap: {{ section.settings.card_gap_v3 }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .rp-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_desktop_v3 }}, 1fr);
    }
  }

  .rp-grid-{{ section.id }} > li {
    display: flex;
    margin: 0;
    padding: 0;
    min-width: 0;
  }

  /* ── Card ───────────────────────────────────────────── */
  .rp-card-{{ section.id }} {
    position: relative;
    background: {{ section.settings.card_bg_color_v3 }};
    border-radius: {{ section.settings.card_radius_v3 }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    width: 100%;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.4s ease;
  }

  .rp-card-{{ section.id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.08);
  }

  /* Media uses fixed aspect ratio — every card's image area is identical */
  .rp-media-{{ section.id }} {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: {{ section.settings.image_aspect_v3 }};
    overflow: hidden;
    background: {{ section.settings.image_bg_color_v3 }};
    flex-shrink: 0;
  }

  .rp-media-{{ section.id }} img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s;
  }

  .rp-card-{{ section.id }}:hover .rp-media-{{ section.id }} img.rp-img-primary {
    transform: scale(1.04);
  }

  .rp-media-{{ section.id }} img.rp-img-secondary {
    opacity: 0;
  }

  .rp-card-{{ section.id }}:hover .rp-media-{{ section.id }} img.rp-img-secondary {
    opacity: 1;
  }

  /* ── Badges ─────────────────────────────────────────── */
  .rp-badges-{{ section.id }} {
    position: absolute;
    top: 14px;
    left: 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 2;
  }

  .rp-badge-{{ section.id }} {
    display: inline-block;
    padding: 5px 10px;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    border-radius: 2px;
    line-height: 1;
  }

  .rp-badge-sale-{{ section.id }} {
    background: {{ section.settings.text_color_v3 }};
    color: {{ section.settings.card_bg_color_v3 }};
  }

  .rp-badge-sold-{{ section.id }} {
    background: {{ section.settings.muted_color_v3 }};
    color: {{ section.settings.card_bg_color_v3 }};
  }

  /* ── Quick-view pill ────────────────────────────────── */
  .rp-quickview-{{ section.id }} {
    position: absolute;
    left: 50%;
    bottom: 16px;
    transform: translate(-50%, 14px);
    padding: 10px 22px;
    background: {{ section.settings.card_bg_color_v3 }};
    color: {{ section.settings.text_color_v3 }};
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    border: 1px solid {{ section.settings.text_color_v3 }};
    border-radius: 999px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.32s ease, transform 0.32s cubic-bezier(0.2, 0.8, 0.2, 1);
    white-space: nowrap;
    z-index: 2;
  }

  .rp-card-{{ section.id }}:hover .rp-quickview-{{ section.id }} {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  /* ── Info area — takes remaining card height ───────── */
  .rp-info-{{ section.id }} {
    padding: {{ section.settings.info_padding_v3 }}px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex-grow: 1;
  }

  .rp-vendor-{{ section.id }} {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color_v3 }};
    font-weight: 500;
    margin: 0;
  }

  .rp-title-{{ section.id }} {
    font-size: var(--font-h3-size);
    font-weight: var(--font-h3-weight);
    color: {{ section.settings.text_color_v3 }};
    letter-spacing: 0.01em;
    line-height: 1.4;
    margin: 0;
    /* Clamp to 2 lines — keeps every card equal height */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .rp-title-{{ section.id }} a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .rp-title-{{ section.id }} a:hover {
    background-size: 100% 1px;
  }

  .rp-price-{{ section.id }} {
    font-size: {{ section.settings.price_size_v3 }}px;
    font-weight: 500;
    color: {{ section.settings.text_color_v3 }};
    letter-spacing: 0.02em;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: auto; /* pushes price to bottom so card heights match */
    padding-top: 4px;
  }

  .rp-price-sale-{{ section.id }} {
    color: {{ section.settings.accent_color_v3 }};
    font-weight: 600;
  }

  .rp-price-compare-{{ section.id }} {
    color: {{ section.settings.muted_color_v3 }};
    text-decoration: line-through;
    font-size: {{ section.settings.price_size_v3 | minus: 1 }}px;
    font-weight: 400;
  }

  .rp-price-from-{{ section.id }} {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color_v3 }};
    font-weight: 500;
    margin-right: 2px;
  }

  /* ── Swatches ───────────────────────────────────────── */
  .rp-swatches-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
    min-height: 16px;
  }

  .rp-swatch-{{ section.id }} {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    outline: 1px solid {{ section.settings.border_color_v3 }};
    outline-offset: 1px;
    background-size: cover;
    background-position: center;
    transition: outline-color 0.2s, transform 0.2s;
    cursor: pointer;
    flex-shrink: 0;
    display: inline-block;
  }

  .rp-swatch-{{ section.id }}:hover {
    outline-color: {{ section.settings.text_color_v3 }};
    transform: scale(1.2);
  }

  .rp-swatches-more-{{ section.id }} {
    font-size: 11px;
    letter-spacing: 0.04em;
    color: {{ section.settings.muted_color_v3 }};
    margin-left: 4px;
    font-weight: 500;
  }

  /* ── Rating ─────────────────────────────────────────── */
  .rp-rating-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: {{ section.settings.muted_color_v3 }};
    letter-spacing: 0.02em;
  }

  .rp-rating-{{ section.id }} .rp-stars {
    display: inline-flex;
    gap: 1px;
  }

  .rp-rating-{{ section.id }} svg {
    width: 11px;
    height: 11px;
    fill: {{ section.settings.text_color_v3 }};
  }

  .rp-rating-empty-{{ section.id }} {
    fill: {{ section.settings.border_color_v3 }};
  }
{%- endstyle -%}

<product-recommendations
  class="rp-section-{{ section.id }} color-{{ section.settings.color_scheme_v3 }}"
  data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.products_to_show_v3 }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="rp-inner-{{ section.id }}">

      <header class="rp-header-{{ section.id }}">
        <h2
          class="rp-heading-{{ section.id }}"
          data-underline="{{ section.settings.show_heading_underline_v3 }}"
          data-halign="{{ section.settings.heading_text_align_v3 }}"
        >{{ section.settings.heading_v3 }}</h2>
      </header>

      <ul class="rp-grid-{{ section.id }}" role="list">
        {%- for recommendation in recommendations.products -%}
          {%- liquid
            assign p = recommendation
            assign first_image = p.featured_image
            assign second_image = p.images[1]
            assign on_sale = false
            if p.compare_at_price > p.price
              assign on_sale = true
            endif
            assign sold_out = false
            unless p.available
              assign sold_out = true
            endunless
          -%}
          <li>
            <article class="rp-card-{{ section.id }}">

              <a href="{{ p.url }}" class="rp-media-{{ section.id }}" aria-label="{{ p.title | escape }}">
                {%- if first_image -%}
                  <img
                    class="rp-img-primary"
                    src="{{ first_image | img_url: '800x' }}"
                    alt="{{ first_image.alt | default: p.title | escape }}"
                    loading="lazy"
                    width="{{ first_image.width }}"
                    height="{{ first_image.height }}"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'rp-placeholder' }}
                {%- endif -%}

                {%- if section.settings.show_secondary_image_v3 and second_image -%}
                  <img
                    class="rp-img-secondary"
                    src="{{ second_image | img_url: '800x' }}"
                    alt=""
                    loading="lazy"
                    width="{{ second_image.width }}"
                    height="{{ second_image.height }}"
                  >
                {%- endif -%}

                <div class="rp-badges-{{ section.id }}">
                  {%- if sold_out -%}
                    <span class="rp-badge-{{ section.id }} rp-badge-sold-{{ section.id }}">Sold out</span>
                  {%- elsif on_sale -%}
                    {%- assign discount = p.compare_at_price | minus: p.price | times: 100.0 | divided_by: p.compare_at_price | round -%}
                    <span class="rp-badge-{{ section.id }} rp-badge-sale-{{ section.id }}">−{{ discount }}%</span>
                  {%- endif -%}
                </div>

                {%- if section.settings.show_quickview_v3 -%}
                  <span class="rp-quickview-{{ section.id }}">{{ section.settings.quickview_label_v3 }}</span>
                {%- endif -%}
              </a>

              <div class="rp-info-{{ section.id }}">

                {%- if section.settings.show_vendor_v3 and p.vendor != blank -%}
                  <p class="rp-vendor-{{ section.id }}">{{ p.vendor }}</p>
                {%- endif -%}

                <h3 class="rp-title-{{ section.id }}">
                  <a href="{{ p.url }}">{{ p.title | escape }}</a>
                </h3>

                {%- if section.settings.show_rating_v3 and p.metafields.reviews.rating.value != blank -%}
                  {%- assign rating = p.metafields.reviews.rating.value.rating | default: 0 -%}
                  {%- assign rating_count = p.metafields.reviews.rating_count | default: 0 -%}
                  <div class="rp-rating-{{ section.id }}">
                    <span class="rp-stars" aria-hidden="true">
                      {%- for i in (1..5) -%}
                        {%- if i <= rating -%}
                          <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        {%- else -%}
                          <svg viewBox="0 0 24 24" class="rp-rating-empty-{{ section.id }}"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        {%- endif -%}
                      {%- endfor -%}
                    </span>
                    <span>({{ rating_count }})</span>
                  </div>
                {%- endif -%}

                {%- if section.settings.show_swatches_v3 -%}
                  {%- assign color_option = null -%}
                  {%- for opt in p.options_with_values -%}
                    {%- assign opt_name = opt.name | downcase -%}
                    {%- if opt_name contains 'color' or opt_name contains 'colour' -%}
                      {%- assign color_option = opt -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}

                  {%- if color_option -%}
                    {%- assign max_swatches = section.settings.max_swatches_v3 -%}
                    {%- assign total_colors = color_option.values | size -%}
                    <div class="rp-swatches-{{ section.id }}">
                      {%- for value in color_option.values limit: max_swatches -%}
                        {%- if value.swatch.image -%}
                          <a
                            href="{{ p.url }}?variant={{ value.variant.id }}"
                            class="rp-swatch-{{ section.id }}"
                            title="{{ value }}"
                            style="background-image: url({{ value.swatch.image | image_url: width: 40 }});"
                          ></a>
                        {%- elsif value.swatch.color -%}
                          <a
                            href="{{ p.url }}?variant={{ value.variant.id }}"
                            class="rp-swatch-{{ section.id }}"
                            title="{{ value }}"
                            style="background-color: {{ value.swatch.color }};"
                          ></a>
                        {%- else -%}
                          <a
                            href="{{ p.url }}?variant={{ value.variant.id }}"
                            class="rp-swatch-{{ section.id }}"
                            title="{{ value }}"
                            style="background-color: {{ value | downcase | replace: ' ', '' }};"
                          ></a>
                        {%- endif -%}
                      {%- endfor -%}
                      {%- if total_colors > max_swatches -%}
                        {%- assign extra = total_colors | minus: max_swatches -%}
                        <span class="rp-swatches-more-{{ section.id }}">+{{ extra }}</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}

                <p class="rp-price-{{ section.id }}">
                  {%- if p.price_varies -%}
                    <span class="rp-price-from-{{ section.id }}">From</span>
                  {%- endif -%}
                  {%- if on_sale -%}
                    <span class="rp-price-sale-{{ section.id }}">{{ p.price | money }}</span>
                    <span class="rp-price-compare-{{ section.id }}">{{ p.compare_at_price | money }}</span>
                  {%- else -%}
                    <span>{{ p.price | money }}</span>
                  {%- endif -%}
                </p>

              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>

    </div>
  {%- endif -%}
</product-recommendations>

{% schema %}
{
  "name": "Related — Prestige",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "paragraph", "content": "Shows related products based on the current product page." },

    { "type": "header", "content": "Heading" },
    {
      "type": "inline_richtext", "id": "heading_v3", "label": "Heading",
      "default": "YOU MAY ALSO LIKE"
    },
    {
      "type": "range", "id": "heading_size_v3", "label": "Heading size",
      "min": 16, "max": 96, "step": 2, "unit": "px", "default": 32
    },
    {
      "type": "select", "id": "heading_weight_v3", "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra bold" }
      ],
      "default": "500"
    },
    {
      "type": "select", "id": "heading_transform_v3", "label": "Heading case",
      "options": [
        { "value": "none", "label": "As typed" },
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "lowercase", "label": "lowercase" },
        { "value": "capitalize", "label": "Capitalize Each Word" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range", "id": "heading_spacing_v3", "label": "Letter spacing",
      "min": 0, "max": 40, "step": 1, "unit": "em", "default": 15,
      "info": "Divided by 100 (15 = 0.15em)"
    },
    {
      "type": "range", "id": "heading_line_height_v3", "label": "Line height",
      "min": 90, "max": 200, "step": 5, "unit": "%", "default": 120,
      "info": "Divided by 100 (120 = 1.2)"
    },
    {
      "type": "color", "id": "heading_color_v3", "label": "Heading colour",
      "default": "#111111"
    },
    {
      "type": "select", "id": "heading_text_align_v3", "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select", "id": "heading_block_pos_v3", "label": "Block position",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range", "id": "heading_max_width_v3", "label": "Max heading width",
      "min": 300, "max": 1200, "step": 20, "unit": "px", "default": 800
    },
    {
      "type": "range", "id": "header_gap_v3", "label": "Gap below heading",
      "min": 20, "max": 120, "step": 4, "unit": "px", "default": 48
    },

    { "type": "header", "content": "Heading underline accent" },
    {
      "type": "checkbox", "id": "show_heading_underline_v3",
      "label": "Show underline below heading", "default": false
    },
    {
      "type": "range", "id": "heading_underline_width_v3", "label": "Line width",
      "min": 20, "max": 200, "step": 4, "unit": "px", "default": 48
    },
    {
      "type": "range", "id": "heading_underline_thickness_v3", "label": "Line thickness",
      "min": 1, "max": 6, "step": 1, "unit": "px", "default": 2
    },
    {
      "type": "range", "id": "heading_underline_gap_v3", "label": "Gap above line",
      "min": 4, "max": 40, "step": 2, "unit": "px", "default": 16
    },
    {
      "type": "color", "id": "heading_underline_color_v3", "label": "Line colour",
      "default": "#111111"
    },

    { "type": "header", "content": "Grid layout" },
    {
      "type": "range", "id": "products_to_show_v3", "label": "Products to show",
      "min": 2, "max": 12, "step": 1, "default": 4
    },
    {
      "type": "range", "id": "columns_desktop_v3", "label": "Columns on desktop",
      "min": 2, "max": 6, "step": 1, "default": 4
    },
    {
      "type": "select", "id": "columns_mobile_v3", "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "range", "id": "card_gap_v3", "label": "Gap between cards",
      "min": 4, "max": 48, "step": 2, "unit": "px", "default": 20
    },
    {
      "type": "range", "id": "max_width_v3", "label": "Max section width",
      "min": 900, "max": 1800, "step": 20, "unit": "px", "default": 1440
    },

    { "type": "header", "content": "Card style" },
    {
      "type": "range", "id": "card_radius_v3", "label": "Card corner radius",
      "min": 0, "max": 32, "step": 2, "unit": "px", "default": 12
    },
    {
      "type": "select", "id": "image_aspect_v3", "label": "Image aspect ratio",
      "info": "All cards use this ratio so every card has equal size",
      "options": [
        { "value": "4 / 5",   "label": "Portrait (4:5)" },
        { "value": "3 / 4",   "label": "Tall portrait (3:4)" },
        { "value": "1 / 1",   "label": "Square (1:1)" },
        { "value": "16 / 10", "label": "Landscape (16:10)" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "range", "id": "info_padding_v3", "label": "Card info padding",
      "min": 0, "max": 32, "step": 2, "unit": "px", "default": 14
    },
    {
      "type": "checkbox", "id": "show_secondary_image_v3",
      "label": "Swap to second image on hover", "default": true
    },
    {
