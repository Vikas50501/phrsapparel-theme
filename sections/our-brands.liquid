{%- style -%}
  /* ══════════════════════════════════════════════════════
     BRAND STORY — Full-screen pinned video
     Left: sticky heading | Right: text physically scrolls
     upward from bottom as you scroll
  ══════════════════════════════════════════════════════ */

  .bs-section-{{ section.id }} {
    position: relative;
    background: {{ section.settings.bg_color }};
    /* Extra scroll distance so text can travel through */
    height: calc({{ section.settings.scroll_depth }} * var(--bs-vh, 100vh));
    isolation: isolate;
  }

  /* ── Sticky pin — holds video + content in place ─────── */
  .bs-pin-{{ section.id }} {
    position: sticky;
    top: {{ section.settings.sticky_top }}px;
    width: 100%;
    height: calc(var(--bs-vh, 100vh) - {{ section.settings.sticky_top }}px);
    overflow: hidden;
  }

  /* When the mobile menu drawer is open, hide this pinned (sticky) content so
     it can't bleed through the menu on iOS Safari (sticky-over-overlay bug).
     Dawn adds .overflow-hidden-mobile to <body> while the drawer is open. */
  body.overflow-hidden-mobile .bs-pin-{{ section.id }} {
    visibility: hidden;
  }

  /* ── Full-bleed video / image background ────────────── */
  .bs-media-{{ section.id }} {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .bs-media-{{ section.id }} video,
  .bs-media-{{ section.id }} img,
  .bs-media-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Dark overlay for text legibility */
  .bs-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
    pointer-events: none;
  }

  /* ── Content grid — sits above video ─────────────────── */
  .bs-content-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    display: grid;
    grid-template-columns: {{ section.settings.left_col }}fr {{ section.settings.right_col }}fr;
    gap: {{ section.settings.col_gap }}px;
    align-items: end;
    padding: {{ section.settings.content_pad_y }}px {{ section.settings.content_pad_x }}px;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .bs-content-{{ section.id }} {
      grid-template-columns: 1fr;
      align-items: flex-end;
    }
    .bs-left-{{ section.id }} { display: none; }
  }

  /* ── Left — heading anchored to bottom-left ────────────── */
  .bs-left-{{ section.id }} {
    display: flex;
    align-items: flex-end;
    padding-bottom: 0;
  }

  .bs-heading-{{ section.id }} {
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    font-style: normal;
    font-family: inherit;
    color: {{ section.settings.heading_color }};
    letter-spacing: {{ section.settings.heading_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.heading_transform }};
    line-height: 1.1;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  /* ── Right — scrolling text container ───────────────── */
  .bs-right-{{ section.id }} {
    position: relative;
    height: 100%;
    overflow: hidden;
    /* Fade mask at top and bottom so text fades in/out */
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black {{ section.settings.fade_start }}%,
      black {{ section.settings.fade_end }}%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black {{ section.settings.fade_start }}%,
      black {{ section.settings.fade_end }}%,
      transparent 100%
    );
  }

  /* ── The text track — moves upward via JS translateY ─── */
  .bs-track-{{ section.id }} {
    position: absolute;
    width: 100%;
    will-change: transform;
    top: 0;
    transform: translateY(100%);
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.text_btn_gap }}px;
    padding-bottom: {{ section.settings.extra_pad }}px;
  }

  /* ── Text box background (optional) ─────────────────── */
  .bs-textbox-{{ section.id }} {
    background: var(--bs-textbox-bg, transparent);
    border-radius: {{ section.settings.textbox_radius }}px;
    padding: var(--bs-textbox-pad, 0);
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.text_btn_gap }}px;
  }

  /* ── Story text ──────────────────────────────────────── */
  .bs-story-{{ section.id }} {
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    font-style: normal;
    font-family: inherit;
    color: {{ section.settings.story_color }};
    line-height: {{ section.settings.story_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.story_spacing | divided_by: 100.0 }}em;
    margin: 0;
    text-align: {{ section.settings.story_text_align }};
  }

  /* ── Squiggle / decorative image ────────────────────── */
  .bs-squiggle-{{ section.id }} {
    max-width: {{ section.settings.squiggle_size }}px;
    height: auto;
    display: block;
  }

  /* ── Button ──────────────────────────────────────────── */
  .bs-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.btn_pad_y }}px {{ section.settings.btn_pad_x }}px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_color }};
    border: {{ section.settings.btn_border_width }}px solid {{ section.settings.btn_border_color }};
    border-radius: {{ section.settings.btn_radius }}px;
    font-size: {{ section.settings.btn_size }}px;
    font-weight: {{ section.settings.btn_weight }};
    letter-spacing: {{ section.settings.btn_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.btn_transform }};
    text-decoration: none;
    font-family: inherit;
    transition: background 0.22s, color 0.22s, border-color 0.22s;
    align-self: flex-start;
  }

  .bs-btn-{{ section.id }}:hover {
    background: {{ section.settings.btn_bg_hover }};
    color: {{ section.settings.btn_color_hover }};
    border-color: {{ section.settings.btn_border_hover }};
  }
{%- endstyle -%}

<section class="bs-section-{{ section.id }}" id="bs-sec-{{ section.id }}">
  <div class="bs-pin-{{ section.id }}" id="bs-pin-{{ section.id }}">

    {%- comment -%} Background media {%- endcomment -%}
    <div class="bs-media-{{ section.id }}">
      {%- if section.settings.video != blank -%}
        {{- section.settings.video | video_tag:
          autoplay: true,
          muted: true,
          loop: true,
          playsinline: true,
          controls: false,
          class: 'bs-vid'
        -}}
      {%- elsif section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | img_url: '2400x' }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          loading="eager"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    {%- comment -%} Overlay {%- endcomment -%}
    <div class="bs-overlay-{{ section.id }}"></div>

    {%- comment -%} Grid: heading left | scrolling text right {%- endcomment -%}
    <div class="bs-content-{{ section.id }}">

      {%- comment -%} LEFT — pinned heading {%- endcomment -%}
      <div class="bs-left-{{ section.id }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="bs-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT — text that scrolls up {%- endcomment -%}
      <div class="bs-right-{{ section.id }}">
        <div class="bs-track-{{ section.id }}" id="bs-track-{{ section.id }}">

          {%- comment -%} Textbox wrapper with optional background {%- endcomment -%}
          {%- assign tb_r = section.settings.textbox_color | color_extract: 'red' -%}
          {%- assign tb_g = section.settings.textbox_color | color_extract: 'green' -%}
          {%- assign tb_b = section.settings.textbox_color | color_extract: 'blue' -%}
          {%- assign tb_a = section.settings.textbox_opacity | divided_by: 100.0 -%}
          {%- assign tb_bg = 'rgba(' | append: tb_r | append: ',' | append: tb_g | append: ',' | append: tb_b | append: ',' | append: tb_a | append: ')' -%}
          {%- assign tb_pad = section.settings.textbox_pad | append: 'px' -%}

          <div
            class="bs-textbox-{{ section.id }}"
            style="--bs-textbox-bg:{{ tb_bg }};--bs-textbox-pad:{{ tb_pad }};"
          >
            {%- if section.settings.story_prefix != blank or section.settings.story != blank -%}
              <p class="bs-story-{{ section.id }}">
                {%- if section.settings.story_prefix != blank -%}
                  <span style="margin-right:0.25em;">{{ section.settings.story_prefix }}</span>
                {%- endif -%}
                {{- section.settings.story -}}
              </p>
            {%- endif -%}

            {%- if section.settings.squiggle_image != blank -%}
              <img
                class="bs-squiggle-{{ section.id }}"
                src="{{ section.settings.squiggle_image | img_url: '300x' }}"
                alt=""
                aria-hidden="true"
              >
            {%- endif -%}

            {%- if section.settings.btn_label != blank -%}
              <a
                class="bs-btn-{{ section.id }}"
                href="{{ section.settings.btn_link | default: '#' }}"
              >{{ section.settings.btn_label }}</a>
            {%- endif -%}
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  'use strict';

  var SID   = '{{ section.id }}';
  var NAV_H = {{ section.settings.sticky_top }};

  function setVH() {
    document.documentElement.style.setProperty('--bs-vh', window.innerHeight + 'px');
  }

  function init() {
    var section = document.getElementById('bs-sec-'   + SID);
    var track   = document.getElementById('bs-track-' + SID);
    if (!section || !track) return;

    setVH();
    window.addEventListener('resize', function () { setVH(); }, { passive: true });

    var ticking = false;

    function update() {
      ticking = false;

      var rect     = section.getBoundingClientRect();
      var vh       = window.innerHeight - NAV_H;
      var scrolled = -rect.top;          /* px scrolled past section top */
      var total    = rect.height - vh;   /* total scrollable distance */

      if (scrolled < 0) scrolled = 0;
      if (scrolled > total) scrolled = total;

      /* Progress 0 → 1 */
      var progress = total > 0 ? scrolled / total : 0;

      /* Track moves from +100% (below) → negative (exits top)
         At progress=0: track bottom is at bottom of pin (translateY 100%)
         At progress=1: track top has scrolled off the top
         Total travel = vh + track.offsetHeight
      */
      var trackH  = track.offsetHeight;
      var travel  = vh + trackH;
      var ty      = vh - (progress * travel);

      track.style.transform = 'translateY(' + ty.toFixed(1) + 'px)';
    }

    window.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }, { passive: true });

    requestAnimationFrame(update);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === SID) { setVH(); setTimeout(init, 50); }
  });
})();
</script>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "section-brand-story",
  "settings": [
    { "type": "header", "content": "Background media" },
    { "type": "video",        "id": "video", "label": "Background video",
      "info": "Autoplays muted and looped. Recommended: portrait or landscape MP4." },
    { "type": "image_picker", "id": "image", "label": "Background image (fallback)" },
    { "type": "range", "id": "overlay_opacity", "label": "Dark overlay opacity",
      "min": 0, "max": 80, "step": 5, "unit": "%", "default": 30 },

    { "type": "header", "content": "Left column — heading" },
    { "type": "text",   "id": "heading",          "label": "Heading",        "default": "Our brand" },
    { "type": "range",  "id": "heading_size",     "label": "Size",           "min": 24, "max": 120, "step": 2, "unit": "px", "default": 60 },
    {
      "type": "select", "id": "heading_weight", "label": "Weight",
      "options": [
        {"value":"300","label":"Light"},{"value":"400","label":"Regular"},
        {"value":"500","label":"Medium"},{"value":"600","label":"Semi-bold"},{"value":"700","label":"Bold"}
      ],
      "default": "400"
    },
    {
      "type": "select", "id": "heading_transform", "label": "Case",
      "options": [{"value":"none","label":"As typed"},{"value":"uppercase","label":"UPPERCASE"},{"value":"capitalize","label":"Capitalize"}],
      "default": "none"
    },
    { "type": "range", "id": "heading_spacing",   "label": "Letter spacing", "min": 0, "max": 20, "step": 1, "unit": "em", "default": 0 },
    { "type": "color", "id": "heading_color",     "label": "Colour",         "default": "#ffffff" },

    { "type": "header", "content": "Right column — story text" },
    { "type": "text", "id": "story_prefix", "label": "Emoji prefix (before text)",
      "default": "🌟",
      "info": "Shown before the first word. Leave empty to hide." },
    { "type": "textarea", "id": "story", "label": "Story text",
      "default": "Gario Jewelry brings modern elegance to your daily style. Our pieces are designed with clean lines, premium materials, and a focus on confidence and individuality. Whether you love minimal, chic, or bold jewelry, Gario creates designs that fit every mood and moment." },
    { "type": "range", "id": "story_size",        "label": "Text size",      "min": 18, "max": 60, "step": 2, "unit": "px", "default": 36 },
    {
      "type": "select", "id": "story_weight", "label": "Weight",
      "options": [{"value":"300","label":"Light"},{"value":"400","label":"Regular"},{"value":"500","label":"Medium"},{"value":"600","label":"Semi-bold"}],
      "default": "400"
    },
    { "type": "range", "id": "story_spacing",     "label": "Letter spacing", "min": 0, "max": 10, "step": 1, "unit": "em", "default": 0 },
    { "type": "range", "id": "story_line_height", "label": "Line height",    "min": 110, "max": 200, "step": 5, "unit": "%", "default": 155 },
    {
      "type": "select", "id": "story_text_align", "label": "Text alignment",
      "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}],
      "default": "left"
    },
    { "type": "color", "id": "story_color",       "label": "Text colour",    "default": "#ffffff" },

    { "type": "header", "content": "Fade mask on text column" },
    { "type": "range", "id": "fade_start", "label": "Fade-in stops at % from top",
      "min": 5, "max": 40, "step": 5, "unit": "%", "default": 15,
      "info": "Text is transparent above this point (creates fade-in from top)" },
    { "type": "range", "id": "fade_end", "label": "Fade-out starts at % from top",
      "min": 60, "max": 100, "step": 5, "unit": "%", "default": 85,
      "info": "Text fades out below this point" },

    { "type": "header", "content": "Text box background" },
    { "type": "paragraph", "content": "Add a colour panel behind the text for legibility over busy images." },
    { "type": "color", "id": "textbox_color",   "label": "Box colour",   "default": "#000000" },
    { "type": "range", "id": "textbox_opacity", "label": "Box opacity",
      "min": 0, "max": 100, "step": 5, "unit": "%", "default": 0,
      "info": "0 = fully transparent (no box). Increase to add a dark/coloured panel." },
    { "type": "range", "id": "textbox_pad",     "label": "Box padding",
      "min": 0, "max": 60, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "textbox_radius",  "label": "Box corner radius",
      "min": 0, "max": 32, "step": 2, "unit": "px", "default": 8 },

    { "type": "header", "content": "Scroll behaviour" },
    { "type": "range", "id": "scroll_depth", "label": "Scroll depth (screen heights)",
      "min": 2, "max": 6, "step": 1, "default": 3,
      "info": "How many viewports tall the scroll section is. More = slower scroll." },
    { "type": "range", "id": "extra_pad",   "label": "Extra bottom space on text",
      "min": 0, "max": 200, "step": 20, "unit": "px", "default": 80,
      "info": "Adds breathing room so the last word doesn't hit the edge" },

    { "type": "header", "content": "Decorative image (squiggle)" },
    { "type": "image_picker", "id": "squiggle_image", "label": "Squiggle / accent image" },
    { "type": "range",        "id": "squiggle_size",  "label": "Max width",
      "min": 40, "max": 200, "step": 10, "unit": "px", "default": 80 },

    { "type": "header", "content": "CTA button" },
    { "type": "text",   "id": "btn_label",        "label": "Label",          "default": "ABOUT US" },
    { "type": "url",    "id": "btn_link",          "label": "Link" },
    { "type": "range",  "id": "btn_size",         "label": "Font size",      "min": 11, "max": 20, "step": 1, "unit": "px", "default": 13 },
    {
      "type": "select", "id": "btn_weight", "label": "Weight",
      "options": [{"value":"400","label":"Regular"},{"value":"500","label":"Medium"},{"value":"600","label":"Semi-bold"}],
      "default": "500"
    },
    {
      "type": "select", "id": "btn_transform", "label": "Case",
      "options": [{"value":"uppercase","label":"UPPERCASE"},{"value":"none","label":"As typed"},{"value":"capitalize","label":"Capitalize"}],
      "default": "uppercase"
    },
    { "type": "range",  "id": "btn_spacing",      "label": "Letter spacing", "min": 0, "max": 30, "step": 1, "unit": "em", "default": 14 },
    { "type": "range",  "id": "btn_pad_x",        "label": "Padding X",      "min": 16, "max": 60, "step": 2, "unit": "px", "default": 32 },
    { "type": "range",  "id": "btn_pad_y",        "label": "Padding Y",      "min": 8, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range",  "id": "btn_radius",       "label": "Radius",         "min": 0, "max": 40, "step": 2, "unit": "px", "default": 0 },
    { "type": "range",  "id": "btn_border_width", "label": "Border width",   "min": 0, "max": 4, "step": 1, "unit": "px", "default": 1 },
    { "type": "range",  "id": "text_btn_gap",     "label": "Gap: text to button","min": 16, "max": 80, "step": 4, "unit": "px", "default": 32 },
    { "type": "color",  "id": "btn_bg",           "label": "Background",     "default": "rgba(0,0,0,0)" },
    { "type": "color",  "id": "btn_color",        "label": "Text colour",    "default": "#ffffff" },
    { "type": "color",  "id": "btn_border_color", "label": "Border colour",  "default": "#ffffff" },
    { "type": "color",  "id": "btn_bg_hover",     "label": "Background — hover","default": "#ffffff" },
    { "type": "color",  "id": "btn_color_hover",  "label": "Text — hover",   "default": "#111111" },
    { "type": "color",  "id": "btn_border_hover", "label": "Border — hover", "default": "#ffffff" },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "left_col",       "label": "Left column weight",   "min": 1, "max": 3, "step": 1, "default": 1 },
    { "type": "range", "id": "right_col",      "label": "Right column weight",  "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "range", "id": "col_gap",        "label": "Gap between columns",  "min": 16, "max": 120, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "max_width",      "label": "Max content width",    "min": 900, "max": 1800, "step": 20, "unit": "px", "default": 1400 },
    { "type": "range", "id": "content_pad_x", "label": "Content side padding", "min": 16, "max": 80, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "content_pad_y", "label": "Content bottom padding", "min": 24, "max": 120, "step": 4, "unit": "px", "default": 48, "info": "Space from the bottom edge to the heading and text" },
    { "type": "range", "id": "sticky_top",    "label": "Nav height offset",    "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0,
      "info": "Set to your theme header height so section sticks below it" },

    { "type": "header", "content": "Background" },
    { "type": "color", "id": "bg_color", "label": "Section background (behind video)", "default": "#000000" }
  ],
  "presets": [{"name": "Brand Story"}]
}
{% endschema %}
