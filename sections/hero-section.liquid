{%- style -%}
  /* ══════════════════════════════════════════════════════
     HERO CAROUSEL — Kalles-style full-width banner
  ══════════════════════════════════════════════════════ */

  .hero-{{ section.id }} {
    position: relative;
    width: 100%;
    background: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  .hero-{{ section.id }}-viewport {
    position: relative;
    width: 100%;
    height: {{ section.settings.hero_height_mobile }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .hero-{{ section.id }}-viewport {
      height: {{ section.settings.hero_height_desktop }}px;
    }
  }

  /* Use 100vh mode */
  .hero-{{ section.id }}[data-height="fullscreen"] .hero-{{ section.id }}-viewport {
    height: calc(100vh - {{ section.settings.vh_offset }}px);
  }

  .hero-{{ section.id }}-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* ── Individual slide ────────────────────────────────── */
  .hero-{{ section.id }}-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity {{ section.settings.transition_speed | times: 10 }}ms ease-in-out,
                visibility 0s linear {{ section.settings.transition_speed | times: 10 }}ms;
    pointer-events: none;
  }

  .hero-{{ section.id }}-slide.is-active {
    opacity: 1;
    visibility: visible;
    transition: opacity {{ section.settings.transition_speed | times: 10 }}ms ease-in-out,
                visibility 0s linear 0s;
    pointer-events: auto;
    z-index: 2;
  }

  .hero-{{ section.id }}-slide-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.hero-{{ section.id }}-slide-img::after {
  content: "";
  position: absolute;
  inset: 0;

  background: rgba(
    {{ section.settings.overlay_color | color_extract: 'red' }},
    {{ section.settings.overlay_color | color_extract: 'green' }},
    {{ section.settings.overlay_color | color_extract: 'blue' }},
    {{ section.settings.overlay_opacity | divided_by: 100.0 }}
  );

  z-index: 1;
  pointer-events: none;
}

  .hero-{{ section.id }}-slide-img img,
  .hero-{{ section.id }}-slide-img .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    object-position: {{ section.settings.image_position }};
    display: block;
  }

  /* No full-image overlay — content box background handles legibility */

  /* Ken Burns zoom effect on active slide */
  .hero-{{ section.id }}[data-kenburns="true"] .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-slide-img img {
    animation: hero-zoom-{{ section.id }} {{ section.settings.autoplay_speed | times: 100 | plus: section.settings.transition_speed | times: 10 | divided_by: 1000.0 }}s ease-out forwards;
  }

  @keyframes hero-zoom-{{ section.id }} {
    from { transform: scale(1); }
    to   { transform: scale(1.08); }
  }

  /* ── Content overlay ─────────────────────────────────── */
  .hero-{{ section.id }}-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: var(--hero-ai, center);
    justify-content: var(--hero-jc, center);
    text-align: var(--hero-ta, center);
    padding: {{ section.settings.content_padding_y }}px {{ section.settings.content_padding_x }}px;
    z-index: 3;
  }

  .hero-{{ section.id }}-slide[data-align-h="left"]   { --hero-ai: flex-start;  --hero-ta: left; }
  .hero-{{ section.id }}-slide[data-align-h="center"] { --hero-ai: center;      --hero-ta: center; }
  .hero-{{ section.id }}-slide[data-align-h="right"]  { --hero-ai: flex-end;    --hero-ta: right; }
  .hero-{{ section.id }}-slide[data-align-v="top"]    { --hero-jc: flex-start; }
  .hero-{{ section.id }}-slide[data-align-v="middle"] { --hero-jc: center; }
  .hero-{{ section.id }}-slide[data-align-v="bottom"] { --hero-jc: flex-end; }

  .hero-{{ section.id }}-content-inner {
    max-width: {{ section.settings.content_max_width }}px;
    display: flex;
    flex-direction: column;
    align-items: inherit;
    gap: {{ section.settings.content_gap }}px;
    /* Content background box — driven by per-slide CSS vars */
    background: var(--hero-box-bg, transparent);
    padding: var(--hero-box-pad, 0);
    border-radius: var(--hero-box-radius, 0px);
    backdrop-filter: var(--hero-box-blur, none);
    -webkit-backdrop-filter: var(--hero-box-blur, none);
  }

  /* ── Script subheading ──────────────── */
  .hero-{{ section.id }}-script {
    font-size: clamp(14px, 2vw, {{ section.settings.script_size }}px);
    font-style: normal;
    font-weight: 400;
    font-family: inherit;
    line-height: 1.2;
    margin: 0;
    padding: 0;
    letter-spacing: 0.01em;
  }

  /* Hero Logo */

.hero-{{ section.id }}-logo{
  display:block;
  width:100%;
  max-width:500px;
  height:auto;
  margin:0 auto;
}

@media screen and (max-width:749px){

  .hero-{{ section.id }}-logo{
    max-width:280px;
  }

  /* Move logo + button slightly down */
  .hero-{{ section.id }}-content-inner{
    transform:translateY(60px);
  }

  .hero-{{ section.id }}-script{
    margin-bottom:8px;
  }
}

  /* ── Main heading (BIG uppercase) ────────────────────── */
  .hero-{{ section.id }}-heading {
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    text-transform: {{ section.settings.heading_transform }};
    letter-spacing: {{ section.settings.heading_spacing | divided_by: 100.0 }}em;
    line-height: 1.05;
    margin: 0;
    padding: 0;
    word-break: break-word;
  }

  /* ── Description ─────────────────────────────────────── */
  .hero-{{ section.id }}-description {
    font-size: clamp(13px, 1.4vw, {{ section.settings.description_size }}px);
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
    padding: 0;
    max-width: {{ section.settings.description_max_width }}px;
    opacity: 0.92;
  }

  /* ── Custom button style (used when "Button style" = Custom). When the theme
     button is selected the .button class is added and these :not(.button)
     rules no longer apply, so the theme .button styling takes over. ── */
  .hero-{{ section.id }}-btn:not(.button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.button_pad_y }}px {{ section.settings.button_pad_x }}px;
    font-size: {{ section.settings.button_size }}px;
    font-weight: {{ section.settings.button_weight }};
    text-transform: {{ section.settings.button_transform }};
    letter-spacing: {{ section.settings.button_spacing | divided_by: 100.0 }}em;
    border-radius: {{ section.settings.button_radius }}px;
    border: {{ section.settings.button_border_width }}px solid var(--hero-btn-border, currentColor);
    background: var(--hero-btn-bg, transparent);
    color: var(--hero-btn-text, inherit);
    text-decoration: none;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    white-space: nowrap;
  }
  .hero-{{ section.id }}-btn:not(.button):hover {
    background: var(--hero-btn-bg-hover, currentColor);
    color: var(--hero-btn-text-hover, #fff);
    transform: translateY(-1px);
  }
  .hero-{{ section.id }}-btn2:not(.button) {
    background: var(--hero-btn2-bg, transparent) !important;
    color: var(--hero-btn2-text, inherit) !important;
    border-color: var(--hero-btn2-border, currentColor) !important;
  }

  /* Button row */
  .hero-{{ section.id }}-btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: inherit;
  }

  /* ── Staggered entry animation for active slide ──────── */
  .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-script,
  .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-heading,
  .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-description,
  .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-btn {
    animation: hero-fade-up-{{ section.id }} 0.9s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
  }
  .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-script     { animation-delay: 0.15s; }
  .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-heading    { animation-delay: 0.30s; }
  .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-description { animation-delay: 0.45s; }
  .hero-{{ section.id }}-slide.is-active .hero-{{ section.id }}-btn        { animation-delay: 0.60s; }

  @keyframes hero-fade-up-{{ section.id }} {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Arrow navigation ────────────────────────────────── */
  .hero-{{ section.id }}-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    border-radius: 50%;
    background: {{ section.settings.arrow_bg }};
    color: {{ section.settings.arrow_color }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    opacity: 0;
    transition: opacity 0.3s, background 0.3s;
  }

  .hero-{{ section.id }}:hover .hero-{{ section.id }}-arrow { opacity: 1; }
  .hero-{{ section.id }}-arrow:hover { background: {{ section.settings.arrow_bg_hover }}; color: {{ section.settings.arrow_color_hover }}; }

  .hero-{{ section.id }}-arrow-prev { left: 24px; }
  .hero-{{ section.id }}-arrow-next { right: 24px; }

  .hero-{{ section.id }}-arrow svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
  }

  /* ── Pagination dots ────────────────────────────────── */
  .hero-{{ section.id }}-dots {
    position: absolute;
    bottom: {{ section.settings.dots_bottom }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 5;
  }

  .hero-{{ section.id }}-dot {
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ section.settings.dot_color }};
    opacity: 0.45;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s, width 0.3s, background 0.3s;
  }

  .hero-{{ section.id }}-dot.is-active {
    opacity: 1;
    width: {{ section.settings.dot_size | times: 3 }}px;
    border-radius: {{ section.settings.dot_size }}px;
    background: {{ section.settings.dot_active_color }};
  }

  /* ── Progress bar ────────────────────────────────────── */
  .hero-{{ section.id }}-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(255,255,255,0.15);
    z-index: 5;
  }

  .hero-{{ section.id }}-progress-fill {
    height: 100%;
    width: 0;
    background: {{ section.settings.progress_color }};
    transition: width linear;
  }

  /* Mobile — adjust spacings */
  @media (max-width: 749px) {
    .hero-{{ section.id }}-content { padding: 24px 20px; }
    .hero-{{ section.id }}-arrow-prev { left: 12px; }
    .hero-{{ section.id }}-arrow-next { right: 12px; }
    .hero-{{ section.id }}-arrow { width: 40px; height: 40px; }
  }
{%- endstyle -%}

<div
  class="hero-{{ section.id }}"
  data-height="{{ section.settings.hero_height_mode }}"
  data-kenburns="{{ section.settings.enable_kenburns }}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed }}"
>
  <div class="hero-{{ section.id }}-viewport">
    <div class="hero-{{ section.id }}-track">

      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          {%- assign slide_vars = "" -%}

          {%- comment -%} Button vars {%- endcomment -%}
          {%- if block.settings.button_bg != blank -%}{%- assign slide_vars = slide_vars | append: "--hero-btn-bg:" | append: block.settings.button_bg | append: ";" -%}{%- endif -%}
          {%- if block.settings.button_text_color != blank -%}{%- assign slide_vars = slide_vars | append: "--hero-btn-text:" | append: block.settings.button_text_color | append: ";" -%}{%- endif -%}
          {%- if block.settings.button_border_color != blank -%}{%- assign slide_vars = slide_vars | append: "--hero-btn-border:" | append: block.settings.button_border_color | append: ";" -%}{%- endif -%}
          {%- if block.settings.button_bg_hover != blank -%}{%- assign slide_vars = slide_vars | append: "--hero-btn-bg-hover:" | append: block.settings.button_bg_hover | append: ";" -%}{%- endif -%}
          {%- if block.settings.button_text_hover != blank -%}{%- assign slide_vars = slide_vars | append: "--hero-btn-text-hover:" | append: block.settings.button_text_hover | append: ";" -%}{%- endif -%}

          {%- comment -%} Content box background {%- endcomment -%}
          {%- if block.settings.content_box_bg != blank and block.settings.content_box_opacity > 0 -%}
            {%- assign cb_opacity = block.settings.content_box_opacity | divided_by: 100.0 -%}
            {%- assign cb_r = block.settings.content_box_bg | color_extract: 'red' -%}
            {%- assign cb_g = block.settings.content_box_bg | color_extract: 'green' -%}
            {%- assign cb_b = block.settings.content_box_bg | color_extract: 'blue' -%}
            {%- assign cb_val = "rgba(" | append: cb_r | append: "," | append: cb_g | append: "," | append: cb_b | append: "," | append: cb_opacity | append: ")" -%}
            {%- assign slide_vars = slide_vars | append: "--hero-box-bg:" | append: cb_val | append: ";" -%}
            {%- assign cb_pad = block.settings.content_box_pad_y | append: "px " | append: block.settings.content_box_pad_x | append: "px" -%}
            {%- assign slide_vars = slide_vars | append: "--hero-box-pad:" | append: cb_pad | append: ";" -%}
            {%- assign slide_vars = slide_vars | append: "--hero-box-radius:" | append: block.settings.content_box_radius | append: "px;" -%}
            {%- if block.settings.content_box_blur > 0 -%}
              {%- assign slide_vars = slide_vars | append: "--hero-box-blur:blur(" | append: block.settings.content_box_blur | append: "px);" -%}
            {%- endif -%}
          {%- endif -%}

          {%- assign btn_style = slide_vars -%}

          <div
            class="hero-{{ section.id }}-slide{% if forloop.first %} is-active{% endif %}"
            data-slide-idx="{{ forloop.index0 }}"
            data-align-h="{{ block.settings.align_h }}"
            data-align-v="{{ block.settings.align_v }}"
            style="{{ slide_vars }}"
            {{ block.shopify_attributes }}
          >
            <div class="hero-{{ section.id }}-slide-img">
              {%- if block.settings.image_desktop != blank -%}
                <picture>
                  {%- if block.settings.image_mobile != blank -%}
                    <source
                      media="(max-width: 749px)"
                      srcset="{{ block.settings.image_mobile | img_url: '750x' }} 750w, {{ block.settings.image_mobile | img_url: '1100x' }} 1100w"
                      sizes="100vw"
                    >
                  {%- endif -%}
                  <img
                    src="{{ block.settings.image_desktop | img_url: '2400x' }}"
                    srcset="{{ block.settings.image_desktop | img_url: '800x' }} 800w, {{ block.settings.image_desktop | img_url: '1200x' }} 1200w, {{ block.settings.image_desktop | img_url: '1800x' }} 1800w, {{ block.settings.image_desktop | img_url: '2400x' }} 2400w"
                    sizes="100vw"
                    alt="{{ block.settings.image_desktop.alt | default: block.settings.heading | escape }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="{{ block.settings.image_desktop.width }}"
                    height="{{ block.settings.image_desktop.height }}"
                    style="object-position: {{ block.settings.image_focal_point | default: section.settings.image_position }};"
                  >
                </picture>
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="hero-{{ section.id }}-content">
              <div class="hero-{{ section.id }}-content-inner" style="color: {{ block.settings.text_color }}; width: {{ block.settings.content_width }};">

                {%- if block.settings.script_text != blank -%}
                  <p class="hero-{{ section.id }}-script" style="color: {{ block.settings.script_color }};">{{ block.settings.script_text }}</p>
                {%- endif -%}

                {% if block.settings.heading_logo != blank %}
  <img
    class="hero-{{ section.id }}-logo"
    src="{{ block.settings.heading_logo | image_url: width: 800 }}"
    alt="{{ shop.name }}"
    loading="lazy"
  >
{% elsif block.settings.heading != blank %}
  <h2 class="hero-{{ section.id }}-heading">
    {{ block.settings.heading }}
  </h2>
{% endif %}

                {%- if block.settings.description != blank -%}
                  <p class="hero-{{ section.id }}-description">{{ block.settings.description }}</p>
                {%- endif -%}

                {%- if block.settings.button_label != blank or block.settings.button2_label != blank -%}
                  {%- assign use_theme_btn = false -%}
                  {%- if section.settings.button_style == 'theme' -%}{%- assign use_theme_btn = true -%}{%- endif -%}
                  <div class="hero-{{ section.id }}-btn-row{% if use_theme_btn %} color-{{ section.settings.button_color_scheme }}{% endif %}">
                    {%- if block.settings.button_label != blank -%}
                      {%- capture hero_btn1_style -%}
                        {%- if use_theme_btn -%}
                          {%- if block.settings.button_bg != blank -%}--color-button: {{ block.settings.button_bg | color_extract: 'red' }},{{ block.settings.button_bg | color_extract: 'green' }},{{ block.settings.button_bg | color_extract: 'blue' }};--alpha-button-background: 1;--alpha-button-border: 1;{%- endif -%}
                          {%- if block.settings.button_text_color != blank -%}--color-button-text: {{ block.settings.button_text_color | color_extract: 'red' }},{{ block.settings.button_text_color | color_extract: 'green' }},{{ block.settings.button_text_color | color_extract: 'blue' }};{%- endif -%}
                        {%- endif -%}
                      {%- endcapture -%}
                      <a href="{{ block.settings.button_link | default: '#' }}" class="{% if use_theme_btn %}button {% endif %}hero-{{ section.id }}-btn"{% if hero_btn1_style != blank %} style="{{ hero_btn1_style | strip_newlines | strip }}"{% endif %}>{{ block.settings.button_label }}</a>
                    {%- endif -%}
                    {%- if block.settings.button2_label != blank -%}
                      {%- capture hero_btn2_style -%}
                        {%- if use_theme_btn -%}
                          {%- if block.settings.button2_bg != blank -%}--color-secondary-button: {{ block.settings.button2_bg | color_extract: 'red' }},{{ block.settings.button2_bg | color_extract: 'green' }},{{ block.settings.button2_bg | color_extract: 'blue' }};--alpha-button-background: 1;{%- endif -%}
                          {%- if block.settings.button2_text_color != blank -%}--color-secondary-button-text: {{ block.settings.button2_text_color | color_extract: 'red' }},{{ block.settings.button2_text_color | color_extract: 'green' }},{{ block.settings.button2_text_color | color_extract: 'blue' }};{%- endif -%}
                        {%- else -%}
                          {%- if block.settings.button2_bg != blank -%}--hero-btn2-bg:{{ block.settings.button2_bg }};{%- endif -%}
                          {%- if block.settings.button2_text_color != blank -%}--hero-btn2-text:{{ block.settings.button2_text_color }};{%- endif -%}
                          {%- if block.settings.button2_border_color != blank -%}--hero-btn2-border:{{ block.settings.button2_border_color }};{%- endif -%}
                        {%- endif -%}
                      {%- endcapture -%}
                      <a href="{{ block.settings.button2_link | default: '#' }}" class="{% if use_theme_btn %}button button--secondary {% endif %}hero-{{ section.id }}-btn hero-{{ section.id }}-btn2"{% if hero_btn2_style != blank %} style="{{ hero_btn2_style | strip_newlines | strip }}"{% endif %}>{{ block.settings.button2_label }}</a>
                    {%- endif -%}
                  </div>
                {%- endif -%}

              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- if section.blocks.size > 1 -%}

      {%- if section.settings.show_arrows -%}
        <button class="hero-{{ section.id }}-arrow hero-{{ section.id }}-arrow-prev" type="button" aria-label="Previous slide">
          <svg viewBox="0 0 24 24"><path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="hero-{{ section.id }}-arrow hero-{{ section.id }}-arrow-next" type="button" aria-label="Next slide">
          <svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      {%- endif -%}

      {%- if section.settings.show_dots -%}
        <div class="hero-{{ section.id }}-dots">
          {%- for block in section.blocks -%}
            {%- if block.type == 'slide' -%}
              <button
                class="hero-{{ section.id }}-dot{% if forloop.first %} is-active{% endif %}"
                type="button"
                data-dot-idx="{{ forloop.index0 }}"
                aria-label="Go to slide {{ forloop.index }}"
              ></button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_progress -%}
        <div class="hero-{{ section.id }}-progress">
          <div class="hero-{{ section.id }}-progress-fill"></div>
        </div>
      {%- endif -%}

    {%- endif -%}

  </div>
</div>

<script>
(function () {
  'use strict';

  var SID = '{{ section.id }}';
  var root = document.querySelector('.hero-' + SID);
  if (!root) return;

  var slides = root.querySelectorAll('.hero-' + SID + '-slide');
  var dots   = root.querySelectorAll('.hero-' + SID + '-dot');
  var prev   = root.querySelector('.hero-' + SID + '-arrow-prev');
  var next   = root.querySelector('.hero-' + SID + '-arrow-next');
  var fill   = root.querySelector('.hero-' + SID + '-progress-fill');

  var n = slides.length;
  if (n < 1) return;

  var current = 0;
  var autoplay = root.dataset.autoplay === 'true';
  var speed    = (parseInt(root.dataset.autoplaySpeed, 10) || 50) * 100;
  var timer = null;

  function go(idx) {
    idx = ((idx % n) + n) % n;
    if (idx === current) return;
    slides[current].classList.remove('is-active');
    slides[idx].classList.add('is-active');
    if (dots.length) {
      dots[current].classList.remove('is-active');
      dots[idx].classList.add('is-active');
    }
    current = idx;
    resetProgress();
  }

  function resetProgress() {
    if (!fill) return;
    fill.style.transition = 'none';
    fill.style.width = '0%';
    fill.offsetHeight; /* reflow */
    if (autoplay) {
      fill.style.transition = 'width ' + speed + 'ms linear';
      fill.style.width = '100%';
    }
  }

  function start() {
    if (!autoplay || n < 2) return;
    stop();
    timer = setInterval(function () { go(current + 1); }, speed);
    resetProgress();
  }

  function stop() {
    if (timer) { clearInterval(timer); timer = null; }
  }

  if (prev) prev.addEventListener('click', function () { go(current - 1); start(); });
  if (next) next.addEventListener('click', function () { go(current + 1); start(); });

  dots.forEach(function (d) {
    d.addEventListener('click', function () {
      go(parseInt(d.dataset.dotIdx, 10));
      start();
    });
  });

  /* Pause on hover */
  root.addEventListener('mouseenter', stop);
  root.addEventListener('mouseleave', start);

  /* Pause when tab is hidden */
  document.addEventListener('visibilitychange', function () {
    if (document.hidden) stop(); else start();
  });

  /* Basic touch swipe */
  var tx = 0;
  root.addEventListener('touchstart', function (e) { tx = e.touches[0].clientX; stop(); }, { passive: true });
  root.addEventListener('touchend', function (e) {
    var diff = e.changedTouches[0].clientX - tx;
    if (Math.abs(diff) > 40) {
      if (diff < 0) go(current + 1);
      else go(current - 1);
    }
    start();
  });

  start();

  /* Shopify editor — re-init without page reload so editor panel stays open */
  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === SID) {
      stop();
      /* Re-query elements after section re-render */
      slides = root.querySelectorAll('.hero-' + SID + '-slide');
      dots   = root.querySelectorAll('.hero-' + SID + '-dot');
      prev   = root.querySelector('.hero-' + SID + '-arrow-prev');
      next   = root.querySelector('.hero-' + SID + '-arrow-next');
      fill   = root.querySelector('.hero-' + SID + '-progress-fill');
      n = slides.length;
      current = 0;
      if (prev) prev.addEventListener('click', function () { go(current - 1); start(); });
      if (next) next.addEventListener('click', function () { go(current + 1); start(); });
      dots.forEach(function (d) {
        d.addEventListener('click', function () { go(parseInt(d.dataset.dotIdx, 10)); start(); });
      });
      start();
    }
  });

  /* Jump to the selected slide when clicking a block in the editor */
  document.addEventListener('shopify:block:select', function (e) {
    if (!e.detail || e.detail.sectionId !== SID) return;
    stop();
    var all = Array.prototype.slice.call(slides);
    for (var i = 0; i < all.length; i++) {
      if (all[i].dataset.blockId === e.detail.blockId || all[i].getAttribute('id') === e.detail.blockId) {
        go(i); return;
      }
    }
    /* fallback — find by shopify-attributes data */
    var target = root.querySelector('[id="' + e.detail.blockId + '"]');
    if (!target) return;
    for (var j = 0; j < all.length; j++) {
      if (all[j] === target || all[j].contains(target)) { go(j); return; }
    }
  });

  /* Resume autoplay when block is deselected */
  document.addEventListener('shopify:block:deselect', function (e) {
    if (e.detail && e.detail.sectionId === SID) start();
  });
})();
</script>

