    { "type": "header", "content": "Product Info Typography" },
    { "type": "range", "id": "title_size", "label": "Product title size (px)", "min": 14, "max": 48, "step": 1, "default": 26 },
    { "type": "select", "id": "title_weight", "label": "Product title weight", "options": [{"value":"300","label":"Light"},{"value":"400","label":"Regular"},{"value":"500","label":"Medium"},{"value":"600","label":"Semibold"},{"value":"700","label":"Bold"}], "default": "400" },
    { "type": "range", "id": "desc_size", "label": "Description size (px)", "min": 10, "max": 20, "step": 1, "default": 14 },
