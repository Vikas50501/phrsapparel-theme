{% style %}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
  }

  #shopify-section-{{ section.id }} .fps-wrap {
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .fps-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: {{ section.settings.header_gap }}px;
  }

  #shopify-section-{{ section.id }} .fps-eyebrow {
    font-size: {{ section.settings.eyebrow_size }}px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin: 0 0 14px;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .fps-heading {
    font-size: {{ section.settings.heading_size_desktop }}px;
    color: {{ section.settings.heading_color }};
    margin: 0;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.08;
    letter-spacing: -0.01em;
  }

  #shopify-section-{{ section.id }} .fps-view-all {
    font-size: {{ section.settings.eyebrow_size }}px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.view_all_color }};
    text-decoration: none;
    white-space: nowrap;
    padding-bottom: 4px;
    transition: color 0.2s;
  }

  #shopify-section-{{ section.id }} .fps-view-all:hover {
    color: {{ section.settings.heading_color }};
  }

  /* ── Grid ── */
  #shopify-section-{{ section.id }} .fps-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  /* fps-item wraps card image + text below */
  #shopify-section-{{ section.id }} .fps-item {
    display: flex;
    flex-direction: column;
  }

  /* ── Card (image box) ── */
  #shopify-section-{{ section.id }} .fps-card {
    display: block;
    text-decoration: none;
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 3 / 4;
    border: 1px solid oklch(0.32 0.008 270 / 40%);
    flex-shrink: 0;
    transition: transform 0.35s ease;
  }

  #shopify-section-{{ section.id }} .fps-card:hover {
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .fps-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, oklch(0.18 0.005 270 / 60%), transparent);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .fps-card:hover::after {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .fps-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    object-position: center;
    display: block;
    padding: 2rem;
    transition: transform 0.7s;
  }

  #shopify-section-{{ section.id }} .fps-card:hover img {
    transform: scale(1.05);
  }

  #shopify-section-{{ section.id }} .fps-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.15;
  }

  #shopify-section-{{ section.id }} .fps-placeholder svg {
    width: 50%;
    height: 50%;
  }

  /* ── Text below card ── */
  #shopify-section-{{ section.id }} .fps-info {
    padding: {{ section.settings.info_padding_top }}px 0 0;
  }

  #shopify-section-{{ section.id }} .fps-info__title {
    display: block;
    font-size: {{ section.settings.title_size }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    text-decoration: none;
    line-height: 1.2;
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }

  #shopify-section-{{ section.id }} .fps-info__title:hover {
    opacity: 0.75;
  }

  #shopify-section-{{ section.id }} .fps-info__desc {
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    font-style: italic;
    line-height: 1.55;
    margin: 0 0 14px;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .fps-info__meta {
    font-size: {{ section.settings.meta_size }}px;
    color: {{ section.settings.meta_color }};
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0;
  }

  /* ── Carousel dots ── */
  #shopify-section-{{ section.id }} .fps-dots {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  #shopify-section-{{ section.id }} .fps-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: {{ section.settings.dot_inactive }};
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.25s, transform 0.25s;
  }

  #shopify-section-{{ section.id }} .fps-dot.active {
    background: {{ section.settings.dot_active }};
    transform: scale(1.4);
  }

  /* ── Mobile carousel ── */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .fps-wrap {
      padding-left: {{ section.settings.mobile_padding_h }}px;
      padding-right: {{ section.settings.mobile_padding_h }}px;
    }

    #shopify-section-{{ section.id }} .fps-heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fps-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 2px;
    }

    #shopify-section-{{ section.id }} .fps-grid::-webkit-scrollbar {
      display: none;
    }

    #shopify-section-{{ section.id }} .fps-item {
      flex: 0 0 calc(100% - {{ section.settings.mobile_peek }}px);
      scroll-snap-align: start;
    }

    #shopify-section-{{ section.id }} .fps-dots {
      display: flex;
    }
  }
{% endstyle %}

<section id="shopify-section-{{ section.id }}">
  <div class="fps-wrap">

    <div class="fps-header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="fps-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="fps-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="fps-view-all">
          {{ section.settings.view_all_label }} &rarr;
        </a>
      {%- endif -%}
    </div>

    <div class="fps-grid" id="fps-grid-{{ section.id }}">
      {%- if section.settings.collection != blank -%}
        {%- for product in collections[section.settings.collection].products limit: section.settings.products_limit -%}
          {%- render 'fps-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            {%- render 'fps-card', product: block.settings.product -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="fps-dots" id="fps-dots-{{ section.id }}"></div>

  </div>
</section>

<script>
(function(){
  var grid = document.getElementById('fps-grid-{{ section.id }}');
  var dotsWrap = document.getElementById('fps-dots-{{ section.id }}');
  if (!grid || !dotsWrap) return;
  var items, dots = [], active = 0;

  function build() {
    items = grid.querySelectorAll('.fps-item');
    dotsWrap.innerHTML = '';
    dots = [];
    if (window.innerWidth > 768 || items.length < 2) return;
    items.forEach(function(_, i) {
      var b = document.createElement('button');
      b.className = 'fps-dot' + (i === 0 ? ' active' : '');
      b.setAttribute('aria-label', 'Slide ' + (i + 1));
      b.addEventListener('click', function() {
        items[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      });
      dotsWrap.appendChild(b);
      dots.push(b);
    });
  }

  function sync() {
    if (!items || !items.length || window.innerWidth > 768) return;
    var gap = parseInt(getComputedStyle(grid).gap) || 0;
    var w = (items[0].offsetWidth || 1) + gap;
    var idx = Math.min(Math.round(grid.scrollLeft / w), items.length - 1);
    if (idx !== active) {
      if (dots[active]) dots[active].classList.remove('active');
      if (dots[idx]) dots[idx].classList.add('active');
      active = idx;
    }
  }

  grid.addEventListener('scroll', sync, { passive: true });
  window.addEventListener('resize', build, { passive: true });
  build();
})();
</script>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The Collection" },
