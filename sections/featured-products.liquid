    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "view_all_color", "label": "View all color", "default": "#888899" },
    { "type": "color", "id": "title_color", "label": "Product title color", "default": "#ffffff" },
    { "type": "color", "id": "desc_color", "label": "Description color", "default": "#888899" },
    { "type": "color", "id": "meta_color", "label": "Price / meta color", "default": "#aaaaaa" },
    { "type": "color", "id": "dot_active", "label": "Carousel dot active", "default": "#ffffff" },
