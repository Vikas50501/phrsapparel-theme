    { "type": "range",  "id": "arrow_radius",     "label": "Radius",        "min": 0, "max": 50, "step": 2, "unit": "px", "default": 40 },
    { "type": "color",  "id": "arrow_bg",         "label": "Background",    "default": "#ffffff" },
    { "type": "color",  "id": "arrow_color",      "label": "Icon colour",   "default": "#111111" },
    { "type": "color",  "id": "arrow_border",     "label": "Border colour", "default": "#dddddd" },
    { "type": "range",  "id": "arrow_bottom_gap", "label": "Gap below",     "min": 0, "max": 40, "step": 2, "unit": "px", "default": 16 },

