{%- style -%}
  .tsp-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .tsp-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .tsp-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding }}px;
  }

  /* ── Header: left heading / right description ──────── */
  .tsp-header-{{ section.id }} {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: {{ section.settings.header_bottom }}px;
    flex-wrap: wrap;
  }

  .tsp-header-left-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.badge_gap }}px;
    align-items: flex-start;
  }

  .tsp-badge-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    padding: {{ section.settings.badge_pad_y }}px {{ section.settings.badge_pad_x }}px;
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_color }};
    border: 1px solid {{ section.settings.badge_border }};
    border-radius: {{ section.settings.badge_radius }}px;
    font-size: {{ section.settings.badge_size }}px;
    font-weight: 400;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.22s, color 0.22s;
  }

  .tsp-badge-{{ section.id }}:hover {
    background: {{ section.settings.badge_color }};
    color: {{ section.settings.badge_bg }};
  }

  .tsp-heading-{{ section.id }} {
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    color: {{ section.settings.heading_color }};
    letter-spacing: {{ section.settings.heading_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.heading_transform }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    margin: 0;
  }

  .tsp-header-right-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: {{ section.settings.desc_btn_gap }}px;
    max-width: {{ section.settings.desc_max_width }}px;
    padding-bottom: 4px;
  }

  @media (max-width: 749px) {
    .tsp-header-right-{{ section.id }} { display: none; }
  }

  .tsp-desc-{{ section.id }} {
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
  }

  .tsp-cta-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    padding: {{ section.settings.cta_pad_y }}px {{ section.settings.cta_pad_x }}px;
    background: {{ section.settings.cta_bg }};
    color: {{ section.settings.cta_color }};
    border: 1px solid {{ section.settings.cta_border }};
    border-radius: {{ section.settings.cta_radius }}px;
    font-size: {{ section.settings.cta_size }}px;
    font-weight: 400;
    text-decoration: none;
    transition: background 0.22s, color 0.22s, transform 0.2s;
    white-space: nowrap;
  }

  .tsp-cta-{{ section.id }}:hover {
    background: {{ section.settings.cta_color }};
    color: {{ section.settings.cta_bg }};
    transform: translateY(-1px);
  }

  /* ── Arrow row ────────────────────────────────────── */
  .tsp-arrow-row-{{ section.id }} {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-bottom: {{ section.settings.arrow_bottom_gap }}px;
  }

  .tsp-arrow-{{ section.id }} {
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    border-radius: {{ section.settings.arrow_radius }}px;
    background: {{ section.settings.arrow_bg }};
    color: {{ section.settings.arrow_color }};
    border: 1px solid {{ section.settings.arrow_border }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.22s, color 0.22s;
    flex-shrink: 0;
  }

  .tsp-arrow-{{ section.id }}:hover {
    background: {{ section.settings.arrow_color }};
    color: {{ section.settings.arrow_bg }};
  }

  .tsp-arrow-{{ section.id }}:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .tsp-arrow-{{ section.id }} svg {
    width: 18px; height: 18px;
    stroke: currentColor; fill: none;
    stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
  }

  /* ── Cards track ──────────────────────────────────── */
  .tsp-viewport-{{ section.id }} {
    overflow: hidden;
    -webkit-overflow-scrolling: touch;
  }

  .tsp-track-{{ section.id }} {
    display: flex;
    align-items: flex-start; /* ← all cards top-align; equal height via section setting */
    gap: {{ section.settings.card_gap }}px;
    transition: transform 0.48s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* ── Card ─────────────────────────────────────────── */
  .tsp-card-{{ section.id }} {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.info_gap }}px;
    text-decoration: none;
    color: inherit;
    /* width is set per-card via inline style */
  }

  /* Image box — uniform height driven by section.settings.card_height */
  .tsp-card-img-{{ section.id }} {
    width: 100%;
    height: {{ section.settings.card_height }}px; /* ← single section-level height = all cards equal */
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    background: {{ section.settings.img_bg }};
    position: relative;
    flex-shrink: 0;
  }

  .tsp-card-img-{{ section.id }} img,
  .tsp-card-img-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .tsp-card-{{ section.id }}:hover .tsp-card-img-{{ section.id }} img {
    transform: scale(1.04);
  }

  /* Diagonal arrow on hover */
  .tsp-hover-arrow-{{ section.id }} {
    position: absolute;
    bottom: {{ section.settings.hover_arrow_offset }}px;
    right: {{ section.settings.hover_arrow_offset }}px;
    width: {{ section.settings.hover_arrow_size }}px;
    height: {{ section.settings.hover_arrow_size }}px;
    border-radius: 50%;
    background: {{ section.settings.hover_arrow_bg }};
    color: {{ section.settings.hover_arrow_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 0.28s ease, transform 0.32s cubic-bezier(0.2, 0.8, 0.2, 1);
    pointer-events: none;
  }

  .tsp-card-{{ section.id }}:hover .tsp-hover-arrow-{{ section.id }} {
    opacity: 1;
    transform: scale(1);
  }

  .tsp-hover-arrow-{{ section.id }} svg {
    width: 16px; height: 16px;
    stroke: currentColor; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }

  /* Card info */
  .tsp-card-info-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tsp-card-row-{{ section.id }} {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }

  .tsp-card-title-{{ section.id }} {
    font-size: var(--font-h4-size);
    font-weight: var(--font-h4-weight);
    color: {{ section.settings.title_color }};
    margin: 0;
    line-height: 1.3;
    flex: 1;
  }

  .tsp-card-price-{{ section.id }} {
    font-size: {{ section.settings.price_size }}px;
    font-weight: {{ section.settings.price_weight }};
    color: {{ section.settings.price_color }};
    margin: 0;
    line-height: 1.3;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tsp-card-rating-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: {{ section.settings.rating_size }}px;
    color: {{ section.settings.rating_color }};
    margin: 0;
  }

  .tsp-star-{{ section.id }} {
    color: {{ section.settings.star_color }};
    line-height: 1;
  }

  /* ── Mobile overrides — modern 2-up swipe carousel ─── */
  @media (max-width: 749px) {
    .tsp-inner-{{ section.id }} { padding: 0 16px; }

    /* Heading scales down so it sits well above 2-up cards */
    .tsp-heading-{{ section.id }} { font-size: 25px; line-height: 1.2; }
    .tsp-header-{{ section.id }} { gap: 16px; }

    .tsp-track-{{ section.id }} { align-items: flex-start; }

    /* Two cards per view, with a small peek of the next */
    .tsp-card-{{ section.id }} {
      flex-shrink: 0;
      width: 45vw !important;
      max-width: none;
    }

    .tsp-card-img-{{ section.id }} {
      height: auto !important;
      aspect-ratio: 3 / 4;
    }

    /* Tighter, theme-matched typography for the smaller cards */
    .tsp-card-title-{{ section.id }} { font-size: 14px; line-height: 1.25; }
    .tsp-card-price-{{ section.id }} { font-size: 14px; }
    .tsp-card-rating-{{ section.id }} { font-size: 12px; }

    /* Keep arrows comfortably tappable */
    .tsp-arrow-{{ section.id }} { width: 40px; height: 40px; }
  }
{%- endstyle -%}

<section class="tsp-section-{{ section.id }}" id="tsp-section-{{ section.id }}">
  <div class="tsp-inner-{{ section.id }}">

    {%- comment -%} Header {%- endcomment -%}
    <div class="tsp-header-{{ section.id }}">
      <div class="tsp-header-left-{{ section.id }}">
        {%- if section.settings.badge_text != blank -%}
          <a class="tsp-badge-{{ section.id }}" href="{{ section.settings.badge_link | default: '#' }}">
            {{ section.settings.badge_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="tsp-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      <div class="tsp-header-right-{{ section.id }}">
        {%- if section.settings.description != blank -%}
          <p class="tsp-desc-{{ section.id }}">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a class="tsp-cta-{{ section.id }}" href="{{ section.settings.cta_link | default: '#' }}">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Count cards {%- endcomment -%}
    {%- assign card_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'card' -%}{%- assign card_count = card_count | plus: 1 -%}{%- endif -%}
    {%- endfor -%}

    {%- comment -%} Arrows {%- endcomment -%}
    {%- if card_count > section.settings.cards_visible -%}
      <div class="tsp-arrow-row-{{ section.id }}">
        <button class="tsp-arrow-{{ section.id }}" id="tsp-prev-{{ section.id }}" type="button" aria-label="Previous" disabled>
          <svg viewBox="0 0 24 24"><path d="M15 6l-6 6 6 6"/></svg>
        </button>
        <button class="tsp-arrow-{{ section.id }}" id="tsp-next-{{ section.id }}" type="button" aria-label="Next">
          <svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      </div>
    {%- endif -%}

    {%- comment -%} Cards {%- endcomment -%}
    <div class="tsp-viewport-{{ section.id }}">
      <div class="tsp-track-{{ section.id }}" id="tsp-track-{{ section.id }}">

        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            <a
              class="tsp-card-{{ section.id }}"
              href="{{ block.settings.link | default: '#' }}"
              style="width: calc({{ block.settings.card_width }}% - {{ section.settings.card_gap }}px);"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Image height now comes from section setting — no inline style needed {%- endcomment -%}
              <div class="tsp-card-img-{{ section.id }}">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | img_url: '800x' }}"
                    alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}

                <div class="tsp-hover-arrow-{{ section.id }}">
                  <svg viewBox="0 0 24 24"><path d="M7 17L17 7M7 7h10v10"/></svg>
                </div>
              </div>

              <div class="tsp-card-info-{{ section.id }}">
                <div class="tsp-card-row-{{ section.id }}">
                  {%- if block.settings.title != blank -%}
                    <h4 class="tsp-card-title-{{ section.id }}">{{ block.settings.title }}</h4>
                  {%- endif -%}
                  {%- if block.settings.price != blank -%}
                    <p class="tsp-card-price-{{ section.id }}">{{ block.settings.price }}</p>
                  {%- endif -%}
                </div>
                {%- if section.settings.show_rating and block.settings.rating > 0 -%}
                  <p class="tsp-card-rating-{{ section.id }}">
                    <span class="tsp-star-{{ section.id }}">★</span>
                    <span>({{ block.settings.rating | divided_by: 10.0 }})</span>
                  </p>
                {%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>

  </div>
</section>

<script>
(function () {
  'use strict';
  var SID     = '{{ section.id }}';
  var VISIBLE = {{ section.settings.cards_visible }};
  var GAP     = {{ section.settings.card_gap }};

  var track = document.getElementById('tsp-track-' + SID);
  var prev  = document.getElementById('tsp-prev-'  + SID);
  var next  = document.getElementById('tsp-next-'  + SID);
  if (!track) return;

  var cards  = Array.from(track.querySelectorAll('.tsp-card-' + SID));
  var total  = cards.length;
  var cur    = 0;

  function isMobile() { return window.innerWidth < 750; }

  function visibleCount() { return isMobile() ? 2 : VISIBLE; }

  function maxIdx() { return Math.max(0, total - visibleCount()); }

  /* Use getBoundingClientRect for accurate post-CSS width on mobile */
  function cardW() {
    return cards[0] ? (cards[0].getBoundingClientRect().width + GAP) : 220;
  }

  function go(idx) {
    idx = Math.max(0, Math.min(maxIdx(), idx));
    cur = idx;
    track.style.transform = 'translateX(-' + (idx * cardW()) + 'px)';
    if (prev) prev.disabled = idx === 0;
    if (next) next.disabled = idx >= maxIdx();
  }

  if (prev) prev.addEventListener('click', function () { go(cur - 1); });
  if (next) next.addEventListener('click', function () { go(cur + 1); });

  /* Touch / swipe */
  var tx = 0;
  track.addEventListener('touchstart', function (e) { tx = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function (e) {
    var d = tx - e.changedTouches[0].clientX;
    if (d > 40) go(cur + 1); else if (d < -40) go(cur - 1);
  });

  /* On resize: reset to 0 when crossing the mobile/desktop breakpoint,
     otherwise recalculate position for the current index */
  var _lastW = window.innerWidth;
  window.addEventListener('resize', function () {
    var w = window.innerWidth;
    if ((_lastW >= 750) !== (w >= 750)) {
      cur = 0;
      track.style.transition = 'none';
      go(0);
      /* Re-enable transition after layout settles */
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          track.style.transition = '';
        });
      });
    } else {
      go(cur);
    }
    _lastW = w;
  }, { passive: true });

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === SID) go(0);
  });
})();
</script>

{% schema %}
{
  "name": "Top Selling — Image Cards",
  "tag": "section",
  "class": "section-top-selling-img",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "card",
      "name": "Image card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url",  "id": "link",  "label": "Link (optional)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Product Name" },
        { "type": "text", "id": "price", "label": "Price", "default": "$99" },
        {
          "type": "range", "id": "card_width", "label": "Card width",
          "min": 10, "max": 100, "step": 5, "unit": "%", "default": 25,
          "info": "Set different widths per card for the varied editorial look"
        },
        {
          "type": "range", "id": "rating", "label": "Rating (x10)",
          "min": 0, "max": 50, "step": 1, "default": 42,
          "info": "Divided by 10 for display (42 = 4.2). Set to 0 to hide."
        }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "Badge" },
    { "type": "text",  "id": "badge_text",   "label": "Badge text",   "default": "See More product" },
    { "type": "url",   "id": "badge_link",   "label": "Badge link" },
    { "type": "color", "id": "badge_bg",     "label": "Background",   "default": "#ffffff" },
    { "type": "color", "id": "badge_color",  "label": "Text colour",  "default": "#111111" },
    { "type": "color", "id": "badge_border", "label": "Border colour","default": "#dddddd" },
    { "type": "range", "id": "badge_radius", "label": "Radius",       "min": 0, "max": 50, "step": 2, "unit": "px", "default": 40 },
    { "type": "range", "id": "badge_size",   "label": "Font size",    "min": 10, "max": 18, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "badge_pad_x",  "label": "Padding X",   "min": 8, "max": 40, "step": 2, "unit": "px", "default": 16 },
    { "type": "range", "id": "badge_pad_y",  "label": "Padding Y",   "min": 4, "max": 20, "step": 1, "unit": "px", "default": 8 },
    { "type": "range", "id": "badge_gap",    "label": "Gap to heading","min": 6, "max": 32, "step": 2, "unit": "px", "default": 12 },

