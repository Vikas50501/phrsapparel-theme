{%- comment -%}
  Section: Top Selling Products
  Product-reference blocks (pick a product per block). Each card is rendered with
  the SHARED snippet 'kc-product-card' — the exact same component the collection
  page uses — and styled by collection-page.css under the .template-collection
  scope, so cards are 100% identical to the collection page.
  Layout: 4 per row desktop, 3 tablet, 2 mobile.
{%- endcomment -%}

{{ 'collection-page.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign limit = section.settings.products_count
  assign cols_d = section.settings.columns_desktop
  assign shop_url = section.settings.button_link
-%}

{%- style -%}
  .ts-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    font-family: Helvetica, Arial, sans-serif;
  }
  @media (min-width: 750px) {
    .ts-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  /* Let the section background show through the .template-collection wrapper */
  .ts-{{ section.id }} .template-collection { background: transparent; color: inherit; }

  .ts-{{ section.id }} .ts-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding }}px;
  }

  /* Heading matches the "Our Collections" section: centered + orange underline */
  .ts-{{ section.id }} .ts-header {
    margin-bottom: {{ section.settings.header_gap }}px;
    text-align: center;
    padding: 0 24px;
  }
  .ts-{{ section.id }} .ts-heading {
    display: inline-block;
    position: relative;
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    font-family: inherit;
    color: {{ section.settings.heading_color }};
    line-height: 1.2;
    margin: 0;
    padding-bottom: 10px;
  }
  .ts-{{ section.id }} .ts-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 3px;
    background: {{ section.settings.underline_color }};
    border-radius: 3px;
  }
  .ts-{{ section.id }} .ts-sub {
    margin: 14px auto 0;
    font-size: 15px;
    line-height: 1.55;
    color: {{ section.settings.heading_color }};
    opacity: 0.7;
    max-width: 640px;
  }
  .ts-{{ section.id }} .ts-shopnow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding: 11px 22px;
    border: 1px solid {{ section.settings.heading_color }};
    border-radius: 40px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    text-decoration: none;
    transition: background 0.22s ease, color 0.22s ease;
  }
  .ts-{{ section.id }} .ts-shopnow:hover { background: {{ section.settings.heading_color }}; color: {{ section.settings.bg_color }}; }
  .ts-{{ section.id }} .ts-shopnow svg { width: 14px; height: 14px; }

  /* Grid: 4 desktop / 3 tablet / 2 mobile. Cards themselves come from collection-page.css */
  .ts-{{ section.id }} .ts-grid {
    display: grid;
    grid-template-columns: repeat({{ cols_d }}, 1fr);
    column-gap: 28px;
    row-gap: 48px;
  }
  @media (max-width: 989px) {
    .ts-{{ section.id }} .ts-grid { grid-template-columns: repeat(3, 1fr); column-gap: 20px; row-gap: 32px; }
  }
  @media (max-width: 749px) {
    .ts-{{ section.id }} .ts-grid { grid-template-columns: repeat(2, 1fr); column-gap: 5px; row-gap: 5px; }
  }

  .ts-{{ section.id }} .ts-empty {
    padding: 40px 0;
    text-align: center;
    color: {{ section.settings.heading_color }};
    opacity: 0.6;
    font-size: 14px;
  }
{%- endstyle -%}

<section class="ts-{{ section.id }}">
  <div class="ts-inner">

    {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.button_label != blank -%}
      <div class="ts-header">
        {%- if section.settings.heading != blank -%}<h2 class="ts-heading">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="ts-sub">{{ section.settings.subheading }}</p>{%- endif -%}
        {%- if section.settings.button_label != blank and shop_url != blank -%}
          <a class="ts-shopnow" href="{{ shop_url }}">
            {{ section.settings.button_label }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Count selected products {%- endcomment -%}
    {%- assign product_blocks = section.blocks | where: 'type', 'product' -%}
    {%- assign has_products = false -%}
    {%- for block in product_blocks -%}
      {%- if block.settings.product != blank -%}{%- assign has_products = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}

    <div class="template-collection">
      {%- if has_products -%}
        <div class="ts-grid" id="ts-grid-{{ section.id }}">
          {%- assign shown = 0 -%}
          {%- for block in product_blocks -%}
            {%- if block.settings.product != blank and shown < limit -%}
              {%- assign shown = shown | plus: 1 -%}
              {%- render 'kc-product-card', product: block.settings.product, max_swatches: section.settings.max_swatches, block: block -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- elsif request.design_mode -%}
        <p class="ts-empty">Add product blocks in the section settings to show your best sellers.</p>
      {%- endif -%}
    </div>

  </div>
</section>

<script>
(function () {
  var grid = document.getElementById('ts-grid-{{ section.id }}');
  if (!grid) return;

  function cardImg(el) {
    var card = el.closest('.kc-card');
    return card ? card.querySelector('.kc-card__img') : null;
  }

  /* Swatch hover/click → swap card image (same behaviour as the collection page) */
  grid.addEventListener('mouseover', function (e) {
    var sw = e.target.closest('.kc-card__swatch');
    if (!sw || !sw.dataset.img) return;
    var img = cardImg(sw);
    if (img) img.src = sw.dataset.img;
  });
  grid.addEventListener('mouseout', function (e) {
    var sw = e.target.closest('.kc-card__swatch');
    if (!sw) return;
    var img = cardImg(sw);
    var card = sw.closest('.kc-card');
    if (img && card) img.src = card.dataset.current || img.getAttribute('data-default');
  });
  grid.addEventListener('click', function (e) {
    var atc = e.target.closest('.kc-card__atc');
    if (atc) { e.preventDefault(); tsAddToCart(atc); return; }

    var sw = e.target.closest('.kc-card__swatch');
    if (!sw) return;
    var group = sw.parentElement;
    if (group) group.querySelectorAll('.kc-card__swatch').forEach(function (s) { s.classList.remove('is-active'); });
    sw.classList.add('is-active');
    if (sw.dataset.img) {
      var img = cardImg(sw);
      var card = sw.closest('.kc-card');
      if (img && card) { img.src = sw.dataset.img; card.dataset.current = sw.dataset.img; }
    }
  });

  function tsAddToCart(btn) {
    var id = btn.getAttribute('data-variant');
    if (!id || btn.dataset.loading) return;
    btn.dataset.loading = '1';

    var drawer = document.querySelector('cart-drawer');
    var body = { items: [{ id: parseInt(id, 10), quantity: 1 }] };
    var sectionIds = [];
    if (drawer && typeof drawer.getSectionsToRender === 'function') {
      try { drawer.getSectionsToRender().forEach(function (s) { sectionIds.push(s.id); }); } catch (e) {}
    }
    if (sectionIds.length) { body.sections = sectionIds.join(','); body.sections_url = window.location.pathname; }

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/javascript', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify(body)
    })
      .then(function (r) { return r.json(); })
      .then(function (res) {
        if (res.status) return;
        if (drawer && res.sections && typeof drawer.renderContents === 'function') {
          drawer.classList.remove('is-empty');
          drawer.renderContents(res);
        } else {
          window.location.href = (window.routes && window.routes.cart_url) ? window.routes.cart_url : '/cart';
        }
      })
      .catch(function () {})
      .finally(function () { delete btn.dataset.loading; });
  }
})();
</script>

{% schema %}
{
  "name": "Top Selling Products",
  "tag": "section",
  "class": "section-top-selling",
  "max_blocks": 16,
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "textarea", "id": "subheading", "label": "Subheading (optional)" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 20, "max": 56, "step": 1, "unit": "px", "default": 32 },
    { "type": "color", "id": "heading_color", "label": "Heading / button colour", "default": "#111111" },
    { "type": "color", "id": "underline_color", "label": "Heading underline colour", "default": "#c47a5a" },
    { "type": "text", "id": "button_label", "label": "Button label (optional)", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "range", "id": "header_gap", "label": "Gap below header", "min": 16, "max": 64, "step": 4, "unit": "px", "default": 28 },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "products_count", "label": "Max products to show", "min": 2, "max": 16, "step": 1, "default": 8 },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 4, "info": "Tablet shows 3, mobile shows 2 automatically." },
    { "type": "range", "id": "max_swatches", "label": "Max colour swatches per card", "min": 2, "max": 8, "step": 1, "default": 6 },

    { "type": "header", "content": "Section background & spacing" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f0efed" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 900, "max": 1800, "step": 20, "unit": "px", "default": 1400 },
    { "type": "range", "id": "side_padding", "label": "Side padding", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Select Product" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Top Selling Products",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
