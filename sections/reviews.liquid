{% style %}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_bg_color }};
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .reviews-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    max-width: {{ section.settings.max_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: {{ section.settings.side_padding }}px;
    padding-right: {{ section.settings.side_padding }}px;
  }

  #shopify-section-{{ section.id }} .reviews-section__head {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: {{ section.settings.head_bottom_gap }}px;
  }

  #shopify-section-{{ section.id }} .text-eyebrow {
    font-family: {{ section.settings.eyebrow_font_family }}, sans-serif;
    font-size: {{ section.settings.eyebrow_font_size }}px;
    font-weight: {{ section.settings.eyebrow_font_weight }};
    letter-spacing: {{ section.settings.eyebrow_letter_spacing }}px;
    text-transform: {{ section.settings.eyebrow_text_transform }};
    color: {{ section.settings.eyebrow_color }};
    margin: 0 0 {{ section.settings.eyebrow_bottom_gap }}px;
  }

  #shopify-section-{{ section.id }} .reviews-section__head {{ section.settings.heading_size }} {
    font-family: {{ section.settings.heading_font_family }}, serif;
    font-size: {{ section.settings.heading_font_size }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    line-height: {{ section.settings.heading_line_height | divided_by: 10.0 }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_bottom_gap }}px;
  }

  #shopify-section-{{ section.id }} .reviews-rating {
    display: inline-flex;
    align-items: center;
    gap: {{ section.settings.rating_gap }}px;
    margin-top: {{ section.settings.rating_top_gap }}px;
  }

  #shopify-section-{{ section.id }} .reviews-stars {
    display: flex;
    gap: 4px;
  }

  #shopify-section-{{ section.id }} .reviews-stars svg {
    width: {{ section.settings.header_star_size }}px;
    height: {{ section.settings.header_star_size }}px;
    fill: {{ section.settings.star_color }};
    stroke: none;
  }

  #shopify-section-{{ section.id }} .reviews-rating span:last-child {
    font-family: {{ section.settings.rating_text_font_family }}, sans-serif;
    font-size: {{ section.settings.rating_text_font_size }}px;
    color: {{ section.settings.rating_text_color }};
  }

  /* ── GRID MODE ── */
  #shopify-section-{{ section.id }} .reviews-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .reviews-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }

  @media (max-width: 599px) {
    #shopify-section-{{ section.id }} .reviews-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }
  }

  /* ── CAROUSEL MODE ── */
  #shopify-section-{{ section.id }} .reviews-carousel-wrapper {
    position: relative;
    padding: 0 {{ section.settings.arrow_offset }}px;
  }

  #shopify-section-{{ section.id }} .reviews-carousel {
    display: flex;
    gap: {{ section.settings.card_gap }}px;
    overflow: hidden;
    cursor: grab;
    user-select: none;
  }

  #shopify-section-{{ section.id }} .reviews-carousel:active {
    cursor: grabbing;
  }

  #shopify-section-{{ section.id }} .reviews-carousel .review-card {
    flex: 0 0 calc((100% - {{ section.settings.card_gap }}px * ({{ section.settings.carousel_visible }} - 1)) / {{ section.settings.carousel_visible }});
    min-width: 0;
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .reviews-carousel .review-card {
      flex: 0 0 calc((100% - {{ section.settings.card_gap }}px) / 2);
    }
  }

  @media (max-width: 599px) {
    #shopify-section-{{ section.id }} .reviews-carousel .review-card {
      flex: 0 0 100%;
    }
  }

  /* Dots */
  #shopify-section-{{ section.id }} .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: {{ section.settings.dots_top_gap }}px;
  }

  #shopify-section-{{ section.id }} .carousel-dot {
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ section.settings.dot_inactive_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.2s;
  }

  #shopify-section-{{ section.id }} .carousel-dot.active {
    background: {{ section.settings.dot_active_color }};
    transform: scale(1.3);
  }

  /* Arrows */
  #shopify-section-{{ section.id }} .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: {{ section.settings.arrow_bg_color }};
    border: 1px solid {{ section.settings.card_border_color }};
    color: {{ section.settings.arrow_icon_color }};
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background 0.2s;
  }

  #shopify-section-{{ section.id }} .carousel-btn:hover {
    background: {{ section.settings.arrow_hover_bg }};
  }

  #shopify-section-{{ section.id }} .carousel-btn.prev { left: 0; }
  #shopify-section-{{ section.id }} .carousel-btn.next { right: 0; }

  #shopify-section-{{ section.id }} .carousel-btn svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── CARD ── */
  #shopify-section-{{ section.id }} .review-card {
    background-color: {{ section.settings.card_bg_color }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding_vertical }}px {{ section.settings.card_padding_horizontal }}px;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.card_inner_gap }}px;
    {% if section.settings.card_shadow != blank %}box-shadow: {{ section.settings.card_shadow }};{% endif %}
  }

  #shopify-section-{{ section.id }} .review-card__stars {
    display: flex;
    gap: {{ section.settings.card_star_gap }}px;
  }

  #shopify-section-{{ section.id }} .review-card__stars svg {
    width: {{ section.settings.card_star_size }}px;
    height: {{ section.settings.card_star_size }}px;
    fill: {{ section.settings.star_color }};
    stroke: none;
  }

  #shopify-section-{{ section.id }} .review-card__title {
    font-family: {{ section.settings.review_title_font_family }}, serif;
    font-size: {{ section.settings.review_title_font_size }}px;
    font-weight: {{ section.settings.review_title_font_weight }};
    color: {{ section.settings.review_title_color }};
    margin: 0;
    line-height: {{ section.settings.review_title_line_height | divided_by: 10.0 }};
    letter-spacing: {{ section.settings.review_title_letter_spacing }}px;
  }

  #shopify-section-{{ section.id }} .review-card__text {
    font-family: {{ section.settings.review_text_font_family }}, sans-serif;
    font-size: {{ section.settings.review_text_font_size }}px;
    font-weight: {{ section.settings.review_text_font_weight }};
    color: {{ section.settings.review_text_color }};
    line-height: {{ section.settings.review_text_line_height | divided_by: 10.0 }};
    margin: 0;
    flex: 1;
  }

  #shopify-section-{{ section.id }} .review-card__author {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: {{ section.settings.author_top_gap }}px;
    padding-top: {{ section.settings.author_divider_gap }}px;
    {% if section.settings.show_author_divider %}border-top: 1px solid {{ section.settings.card_border_color }};{% endif %}
  }

  #shopify-section-{{ section.id }} .review-card__name {
    font-family: {{ section.settings.author_name_font_family }}, serif;
    font-size: {{ section.settings.author_name_font_size }}px;
    font-weight: {{ section.settings.author_name_font_weight }};
    color: {{ section.settings.author_name_color }};
    letter-spacing: {{ section.settings.author_name_letter_spacing }}px;
  }

  #shopify-section-{{ section.id }} .review-card__product {
    font-family: {{ section.settings.product_label_font_family }}, sans-serif;
    font-size: {{ section.settings.product_label_font_size }}px;
    font-weight: {{ section.settings.product_label_font_weight }};
    color: {{ section.settings.product_label_color }};
    letter-spacing: {{ section.settings.product_label_letter_spacing }}px;
    text-transform: {{ section.settings.product_label_text_transform }};
  }
{% endstyle %}

<section class="reviews-section" id="reviews-{{ section.id }}">
  <div class="reviews-section__inner">

    <div class="reviews-section__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="text-eyebrow text-muted">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_size }}>{{ section.settings.heading }}</{{ section.settings.heading_size }}>
      {%- endif -%}
      {%- if section.settings.rating_text != blank -%}
        <div class="reviews-rating">
          <span class="reviews-stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endfor -%}
          </span>
          <span>{{ section.settings.rating_text }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.layout == 'carousel' -%}
      <div class="reviews-carousel-wrapper">
        {%- if section.settings.show_arrows -%}
          <button class="carousel-btn prev" aria-label="Previous">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
        {%- endif -%}

        <div class="reviews-carousel" id="carousel-{{ section.id }}">
          {%- for block in section.blocks -%}
            <article class="review-card" {{ block.shopify_attributes }}>
              <div class="review-card__stars">
                {%- for i in (1..block.settings.stars) -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- endfor -%}
              </div>
              {%- if block.settings.title != blank -%}
                <h3 class="review-card__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="review-card__text">{{ block.settings.text }}</p>
              {%- endif -%}
              <div class="review-card__author">
                <span class="review-card__name">{{ block.settings.author }}</span>
                <span class="review-card__product">{{ block.settings.product_name }}</span>
              </div>
            </article>
          {%- endfor -%}
        </div>

        {%- if section.settings.show_arrows -%}
          <button class="carousel-btn next" aria-label="Next">
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endif -%}
      </div>

      {%- if section.settings.show_dots -%}
        <div class="carousel-dots" id="dots-{{ section.id }}">
          {%- for block in section.blocks -%}
            <button class="carousel-dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="reviews-grid">
        {%- for block in section.blocks -%}
          <article class="review-card" {{ block.shopify_attributes }}>
            <div class="review-card__stars">
              {%- for i in (1..block.settings.stars) -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endfor -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="review-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="review-card__text">{{ block.settings.text }}</p>
            {%- endif -%}
            <div class="review-card__author">
              <span class="review-card__name">{{ block.settings.author }}</span>
              <span class="review-card__product">{{ block.settings.product_name }}</span>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{%- if section.settings.layout == 'carousel' -%}
<script>
(function () {
  var sectionId = '{{ section.id }}';
  var carousel = document.getElementById('carousel-' + sectionId);
  if (!carousel) return;

  var dotsWrap = document.getElementById('dots-' + sectionId);
  var dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.carousel-dot')) : [];
  var sectionEl = carousel.closest('#shopify-section-' + sectionId);
  var prevBtn = sectionEl ? sectionEl.querySelector('.carousel-btn.prev') : null;
  var nextBtn = sectionEl ? sectionEl.querySelector('.carousel-btn.next') : null;

  var autoPlay = {{ section.settings.auto_play | json }};
  var autoSpeed = {{ section.settings.auto_speed }} * 1000;
  var pauseOnHover = {{ section.settings.pause_on_hover | json }};
  var totalCards = {{ section.blocks.size }};
  var visibleCount = {{ section.settings.carousel_visible }};
  var currentIndex = 0;
  var autoTimer = null;
  var isDragging = false;
  var startX = 0;
  var scrollStart = 0;

  function getCardWidth() {
    var card = carousel.querySelector('.review-card');
    if (!card) return 0;
    var gap = parseInt('{{ section.settings.card_gap }}') || 20;
    return card.offsetWidth + gap;
  }

  function updateVisible() {
    if (window.innerWidth <= 599) visibleCount = 1;
    else if (window.innerWidth <= 989) visibleCount = 2;
    else visibleCount = {{ section.settings.carousel_visible }};
  }

  function updateDots() {
    dots.forEach(function (dot, i) {
      dot.classList.toggle('active', i === currentIndex);
    });
  }

  function scrollTo(index) {
    var max = Math.max(0, totalCards - visibleCount);
    currentIndex = Math.max(0, Math.min(index, max));
    carousel.scrollTo({ left: currentIndex * getCardWidth(), behavior: 'smooth' });
    updateDots();
  }

  function next() { scrollTo(currentIndex + 1 > totalCards - visibleCount ? 0 : currentIndex + 1); }
  function prev() { scrollTo(currentIndex - 1 < 0 ? totalCards - visibleCount : currentIndex - 1); }

  function startAuto() {
    if (!autoPlay) return;
    autoTimer = setInterval(next, autoSpeed);
  }
  function stopAuto() { clearInterval(autoTimer); }

  if (prevBtn) prevBtn.addEventListener('click', function () { stopAuto(); prev(); startAuto(); });
  if (nextBtn) nextBtn.addEventListener('click', function () { stopAuto(); next(); startAuto(); });

  dots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      stopAuto();
      scrollTo(parseInt(dot.dataset.index, 10));
      startAuto();
    });
  });

  if (pauseOnHover) {
    carousel.addEventListener('mouseenter', stopAuto);
    carousel.addEventListener('mouseleave', startAuto);
  }

  /* Drag */
  carousel.addEventListener('mousedown', function (e) {
    isDragging = true; startX = e.pageX; scrollStart = carousel.scrollLeft;
    carousel.style.scrollBehavior = 'auto';
  });
  carousel.addEventListener('mousemove', function (e) {
    if (!isDragging) return;
    carousel.scrollLeft = scrollStart - (e.pageX - startX);
  });
  function endDrag(clientX) {
    if (!isDragging) return;
    isDragging = false; carousel.style.scrollBehavior = '';
    var diff = clientX - startX;
    if (diff < -50) next();
    else if (diff > 50) prev();
    else scrollTo(currentIndex);
  }
  carousel.addEventListener('mouseup', function (e) { endDrag(e.pageX); });
  carousel.addEventListener('mouseleave', function (e) { endDrag(e.pageX); });

  /* Touch */
  carousel.addEventListener('touchstart', function (e) { startX = e.touches[0].clientX; }, { passive: true });
  carousel.addEventListener('touchend', function (e) {
    var diff = e.changedTouches[0].clientX - startX;
    if (diff < -50) next(); else if (diff > 50) prev();
  }, { passive: true });

  window.addEventListener('resize', function () { updateVisible(); scrollTo(currentIndex); });
  updateVisible();
  startAuto();
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "header", "content": "Section Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "From the people who wear it" },
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Worn, remembered, recognised." },
    { "type": "select", "id": "heading_size", "label": "Heading tag", "options": [{"value":"h1","label":"H1"},{"value":"h2","label":"H2"},{"value":"h3","label":"H3"}], "default": "h2" },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9 out of 5 · based on 240+ verified reviews" },

    { "type": "header", "content": "Layout Mode" },
    { "type": "select", "id": "layout", "label": "Display mode", "options": [{"value":"grid","label":"Grid"},{"value":"carousel","label":"Carousel (auto-slide)"}], "default": "grid" },

    { "type": "header", "content": "Carousel Settings" },
    { "type": "range", "id": "carousel_visible", "label": "Cards visible (desktop)", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "checkbox", "id": "auto_play", "label": "Auto-slide", "default": true },
    { "type": "range", "id": "auto_speed", "label": "Auto-slide speed (seconds)", "min": 2, "max": 10, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "pause_on_hover", "label": "Pause on hover", "default": true },
    { "type": "checkbox", "id": "show_arrows", "label": "Show prev / next arrows", "default": true },
    { "type": "checkbox", "id": "show_dots", "label": "Show dot indicators", "default": true },

    { "type": "header", "content": "Arrow Style" },
    { "type": "color", "id": "arrow_bg_color", "label": "Arrow background", "default": "#1a1a1a" },
    { "type": "color", "id": "arrow_hover_bg", "label": "Arrow hover background", "default": "#2a2a2a" },
    { "type": "color", "id": "arrow_icon_color", "label": "Arrow icon color", "default": "#ffffff" },
    { "type": "range", "id": "arrow_size", "label": "Arrow button size (px)", "min": 32, "max": 72, "step": 2, "default": 44 },
    { "type": "range", "id": "arrow_offset", "label": "Arrow side offset (px)", "min": 0, "max": 80, "step": 2, "default": 24 },

    { "type": "header", "content": "Dot Indicators" },
    { "type": "color", "id": "dot_active_color", "label": "Active dot color", "default": "#e8a020" },
    { "type": "color", "id": "dot_inactive_color", "label": "Inactive dot color", "default": "#444444" },
    { "type": "range", "id": "dot_size", "label": "Dot size (px)", "min": 6, "max": 16, "step": 1, "default": 8 },
    { "type": "range", "id": "dots_top_gap", "label": "Dots top gap (px)", "min": 8, "max": 60, "step": 2, "default": 28 },

    { "type": "header", "content": "Section Layout" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 0, "max": 200, "step": 4, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 0, "max": 200, "step": 4, "default": 96 },
    { "type": "range", "id": "side_padding", "label": "Side padding (px)", "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 800, "max": 1800, "step": 20, "default": 1400 },
    { "type": "range", "id": "head_bottom_gap", "label": "Heading block bottom gap (px)", "min": 0, "max": 120, "step": 4, "default": 56 },
    { "type": "color", "id": "section_bg_color", "label": "Section background", "default": "#0f0f0f" },
    { "type": "select", "id": "heading_alignment", "label": "Text alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },

    { "type": "header", "content": "Eyebrow Typography" },
    { "type": "text", "id": "eyebrow_font_family", "label": "Font family", "default": "Georgia" },
    { "type": "range", "id": "eyebrow_font_size", "label": "Font size (px)", "min": 8, "max": 24, "step": 1, "default": 11 },
    { "type": "select", "id": "eyebrow_font_weight", "label": "Font weight", "options": [{"value":"300","label":"Light"},{"value":"400","label":"Regular"},{"value":"500","label":"Medium"},{"value":"600","label":"Semi Bold"},{"value":"700","label":"Bold"}], "default": "400" },
    { "type": "range", "id": "eyebrow_letter_spacing", "label": "Letter spacing (px)", "min": 0, "max": 8, "step": 1, "default": 2 },
    { "type": "select", "id": "eyebrow_text_transform", "label": "Text transform", "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"Uppercase"},{"value":"lowercase","label":"Lowercase"},{"value":"capitalize","label":"Capitalize"}], "default": "uppercase" },
