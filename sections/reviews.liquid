    { "type": "select", "id": "heading_font_weight", "label": "Font weight", "options": [{"value":"300","label":"Light"},{"value":"400","label":"Regular"},{"value":"500","label":"Medium"},{"value":"600","label":"Semi Bold"},{"value":"700","label":"Bold"}], "default": "400" },
    { "type": "range", "id": "heading_letter_spacing", "label": "Letter spacing (px)", "min": -4, "max": 8, "step": 1, "default": 0 },
    { "type": "range", "id": "heading_line_height", "label": "Line height (÷10 = actual, e.g. 11 = 1.1)", "min": 10, "max": 20, "step": 1, "default": 11 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "range", "id": "heading_bottom_gap", "label": "Bottom gap (px)", "min": 0, "max": 48, "step": 2, "default": 16 },

