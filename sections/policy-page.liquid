<div class="policy-page">
  <p class="text-eyebrow text-muted">{{ section.settings.eyebrow | default: 'Legal' }}</p>
  <h1>{{ page.title }}</h1>
  <div class="policy-content">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "Policy Page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Legal" }
  ]
}
{% endschema %}
