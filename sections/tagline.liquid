{% style %}
  #shopify-section-{{ section.id }} .custom-announcement-bar {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    border-top: {{ section.settings.border_top }}px solid {{ section.settings.border_color }};
    border-bottom: {{ section.settings.border_bottom }}px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .custom-announcement-bar__inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    text-align: {{ section.settings.text_align }};
    padding-left: {{ section.settings.content_padding }}px;
    padding-right: {{ section.settings.content_padding }}px;
  }

  #shopify-section-{{ section.id }} .custom-announcement-bar__eyebrow {
    margin: 0 0 {{ section.settings.eyebrow_spacing }}px;
    color: {{ section.settings.eyebrow_color }};
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: {{ section.settings.eyebrow_weight }};
    letter-spacing: {{ section.settings.eyebrow_letter_spacing }}px;
    text-transform: {{ section.settings.eyebrow_transform }};
    line-height: 1.2;
    opacity: {{ section.settings.eyebrow_opacity }};
  }

  #shopify-section-{{ section.id }} .custom-announcement-bar__heading {
    margin: 0;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: {{ section.settings.heading_weight }};
    font-style: {{ section.settings.heading_style }};
    line-height: {{ section.settings.heading_line_height }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    max-width: {{ section.settings.heading_width }}px;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .custom-announcement-bar__heading span {
    display: inline-block;
  }

  {% if section.settings.enable_text_shadow %}
  #shopify-section-{{ section.id }} .custom-announcement-bar__heading,
  #shopify-section-{{ section.id }} .custom-announcement-bar__eyebrow {
    text-shadow: 0 0 {{ section.settings.shadow_blur }}px {{ section.settings.shadow_color }};
  }
  {% endif %}

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .custom-announcement-bar {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .custom-announcement-bar__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .custom-announcement-bar__eyebrow {
      font-size: {{ section.settings.eyebrow_size_mobile }}px;
    }
  }
{% endstyle %}

<section class="custom-announcement-bar">
  <div class="custom-announcement-bar__inner">

    {% if section.settings.eyebrow != blank %}
      <p class="custom-announcement-bar__eyebrow">
        {{ section.settings.eyebrow }}
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <{{ section.settings.heading_tag }} class="custom-announcement-bar__heading">
        <span>{{ section.settings.heading }}</span>
      </{{ section.settings.heading_tag }}>
    {% endif %}

  </div>
</section>

