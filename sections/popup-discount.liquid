{%- comment -%}
  Section: Popup Discount (popup-discount.liquid)
  Premium email-capture popup with a floating launcher button.

  - Floating launcher (bottom-left) opens the popup on click.
  - Optional timed auto-open, once per N days (localStorage + cookie fallback).
  - Form uses the theme's native .field / .button components + color scheme,
    so it matches the theme exactly. Helvetica enforced per request.
  - Desktop: landscape layout (image beside the form) when an image is set.
  - Mobile: bottom-sheet, single column.
  - Closes via X, click-outside, or Esc. Focus-trapped + accessible.
  - Submits the native {% form 'customer' %} over AJAX → Customers / Email Marketing.

  Add this section to your Home page template (Online Store 2.0).
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign uid = section.id
  assign use_custom = s.enable_custom_colors
  assign delay_ms = s.delay_seconds | times: 1000
  assign code = s.discount_code | strip | default: 'WELCOME10'
  assign desktop_image = s.image
  assign mobile_image = s.mobile_image | default: s.image
  comment
    has_image drives the desktop landscape layout (needs a desktop image).
    show_media renders the image block when either a desktop or mobile image is set.
  endcomment
  assign has_image = false
  if desktop_image != blank
    assign has_image = true
  endif
  assign show_media = false
  if desktop_image != blank or s.mobile_image != blank
    assign show_media = true
  endif
-%}

{%- capture custom_vars -%}
  {%- if use_custom -%}
    --pd-bg: {{ s.popup_bg }};
    --pd-text: {{ s.text_color }};
    --pd-heading: {{ s.heading_color | default: s.text_color }};
    --color-button: {{ s.button_color | color_extract: 'red' }} {{ s.button_color | color_extract: 'green' }} {{ s.button_color | color_extract: 'blue' }};
    --color-button-text: {{ s.button_text_color | color_extract: 'red' }} {{ s.button_text_color | color_extract: 'green' }} {{ s.button_text_color | color_extract: 'blue' }};
    --alpha-button-background: 1;
    --alpha-button-border: 1;
  {%- endif -%}
{%- endcapture -%}

<style>
  /* ===== Floating launcher ===== */
  .pd-launcher-{{ uid }} {
    position: fixed;
    left: 20px;
    bottom: 20px;
    z-index: 99990;
    font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    box-shadow: 0 10px 30px -8px rgba(0, 0, 0, 0.4);
    animation: pd-launch-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .pd-launcher-{{ uid }} .pd-launcher__icon { margin-right: 8px; font-size: 1.6rem; line-height: 1; }
  @keyframes pd-launch-in { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  @media (max-width: 749px) {
    .pd-launcher-{{ uid }} { left: 14px; bottom: 14px; }
  }

  /* ===== Overlay ===== */
  #pd-{{ uid }} {
    --pd-font: Helvetica, "Helvetica Neue", Arial, sans-serif;
    --pd-radius: 16px;
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: rgba(15, 15, 20, 0.55);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, visibility 0s linear 0.35s;
    font-family: var(--pd-font);
  }
  #pd-{{ uid }}[hidden] { display: none; }
  #pd-{{ uid }}.is-open { opacity: 1; visibility: visible; transition: opacity 0.35s ease; }

  #pd-{{ uid }} *,
  #pd-{{ uid }} *::before,
  #pd-{{ uid }} *::after { box-sizing: border-box; }
  #pd-{{ uid }} .pd-body * { font-family: var(--pd-font); }

  /* ===== Modal ===== */
  #pd-{{ uid }} .pd-modal {
    position: relative;
    width: 100%;
    max-width: 480px;
    max-height: calc(100vh - 40px);
    overflow: hidden;
    background: var(--pd-bg, rgb(var(--color-background)));
    color: var(--pd-text, rgb(var(--color-foreground)));
    border-radius: var(--pd-radius);
    box-shadow: 0 30px 70px -20px rgba(0, 0, 0, 0.45), 0 8px 24px -12px rgba(0, 0, 0, 0.35);
    transform: translateY(18px) scale(0.97);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  }
  #pd-{{ uid }}.is-open .pd-modal { transform: translateY(0) scale(1); opacity: 1; }

  /* Media */
  #pd-{{ uid }} .pd-media {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.05);
  }
  #pd-{{ uid }} .pd-media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  #pd-{{ uid }} .pd-body { padding: 36px; overflow-y: auto; max-height: calc(100vh - 40px); }

  /* Close — white, large, no background */
  #pd-{{ uid }} .pd-close {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: #ffffff;
    font-size: 38px;
    line-height: 1;
    cursor: pointer;
    z-index: 4;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.55);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  #pd-{{ uid }} .pd-close span { display: block; margin-top: -4px; }
  #pd-{{ uid }} .pd-close:hover { transform: rotate(90deg); opacity: 0.85; }
  #pd-{{ uid }} .pd-close:focus-visible { outline: 2px solid #ffffff; outline-offset: 2px; }

  /* Typography */
  #pd-{{ uid }} .pd-heading {
    margin: 0 0 10px;
    font-family: var(--pd-font);
    font-size: 27px;
    line-height: 1.15;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--pd-heading, var(--pd-text, rgb(var(--color-foreground))));
  }
  #pd-{{ uid }} .pd-sub {
    margin: 0 0 22px;
    font-size: 15px;
    line-height: 1.55;
    opacity: 0.75;
    text-transform: none;
  }

  /* Theme fields — spacing only; look comes from the theme .field component */
  #pd-{{ uid }} .pd-field { margin-bottom: 14px; }
  #pd-{{ uid }} .pd-error {
    display: none;
    margin: -4px 0 14px;
    color: #d92d20;
    font-size: 13px;
    line-height: 1.4;
  }
  #pd-{{ uid }} .pd-error.is-visible { display: block; }
  #pd-{{ uid }} .field__input[aria-invalid="true"] + .field__label { color: #d92d20; }

  /* Buttons (theme .button) — uppercase per request */
  #pd-{{ uid }} .button { text-transform: uppercase; }
  #pd-{{ uid }} .pd-submit { margin-top: 6px; }
  #pd-{{ uid }} .pd-submit .pd-spinner { display: none; }
  #pd-{{ uid }} .pd-submit.is-loading { pointer-events: none; }
  #pd-{{ uid }} .pd-submit.is-loading .pd-submit__label { visibility: hidden; }
  #pd-{{ uid }} .pd-submit.is-loading .pd-spinner {
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    width: 22px;
    height: 22px;
    margin: -11px 0 0 -11px;
    border: 2.5px solid rgba(var(--color-button-text), 0.35);
    border-top-color: rgb(var(--color-button-text));
    border-radius: 50%;
    animation: pd-spin 0.7s linear infinite;
  }
  @keyframes pd-spin { to { transform: rotate(360deg); } }

  #pd-{{ uid }} .pd-fineprint { margin: 14px 0 0; font-size: 11.5px; line-height: 1.5; opacity: 0.55; }

  /* Success */
  #pd-{{ uid }} .pd-state[hidden] { display: none; }
  #pd-{{ uid }} .pd-success { text-align: center; }
  #pd-{{ uid }} .pd-check {
    width: 64px; height: 64px; margin: 0 auto 18px; border-radius: 50%;
    background: rgba(34, 160, 90, 0.12);
    display: flex; align-items: center; justify-content: center;
    animation: pd-pop 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  #pd-{{ uid }} .pd-check svg { width: 30px; height: 30px; stroke: #1d9b56; }
  #pd-{{ uid }} .pd-check svg path { stroke-dasharray: 30; stroke-dashoffset: 30; animation: pd-draw 0.5s ease 0.18s forwards; }
  @keyframes pd-pop { from { transform: scale(0); } to { transform: scale(1); } }
  @keyframes pd-draw { to { stroke-dashoffset: 0; } }

  #pd-{{ uid }} .pd-code { display: flex; align-items: stretch; gap: 10px; margin: 20px 0 18px; }
  #pd-{{ uid }} .pd-code__value {
    flex: 1; display: flex; align-items: center; justify-content: center;
    padding: 0 16px; min-height: 50px;
    font-family: var(--pd-font); font-size: 18px; font-weight: 700; letter-spacing: 0.12em;
    border: 1.5px dashed rgba(var(--color-foreground), 0.35); border-radius: 10px;
    background: rgba(var(--color-foreground), 0.03);
  }
  #pd-{{ uid }} .pd-copy { min-width: 0; white-space: nowrap; }

  /* ===== Desktop landscape (image beside form) ===== */
  @media (min-width: 750px) {
    #pd-{{ uid }} .pd-modal.pd-has-image {
      max-width: 820px;
      display: grid;
      grid-template-columns: 0.92fr 1.08fr;
      align-items: stretch;
    }
    #pd-{{ uid }} .pd-has-image .pd-media {
      aspect-ratio: auto;
      height: 100%;
      min-height: 460px;
    }
    #pd-{{ uid }} .pd-has-image .pd-body {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 44px 42px;
    }
  }

  /* ===== Mobile full-screen ===== */
  @media (max-width: 749px) {
    #pd-{{ uid }} { padding: 0; align-items: stretch; }
    #pd-{{ uid }} .pd-modal {
      max-width: 100%;
      width: 100%;
      height: 100%;
      max-height: none;
      border-radius: 0;
      display: flex;
      flex-direction: column;
      transform: translateY(100%);
    }
    #pd-{{ uid }}.is-open .pd-modal { transform: translateY(0); }
    /* Image fills the top portion of the screen */
    #pd-{{ uid }} .pd-media {
      aspect-ratio: auto;
      flex: 0 0 42%;
      min-height: 42%;
    }
    /* Form fills the rest and scrolls if needed */
    #pd-{{ uid }} .pd-body {
      flex: 1 1 auto;
      max-height: none;
      padding: 28px 22px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    #pd-{{ uid }} .pd-heading { font-size: 24px; }
    #pd-{{ uid }} .pd-code { flex-direction: column; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .pd-launcher-{{ uid }},
    #pd-{{ uid }},
    #pd-{{ uid }} .pd-modal,
    #pd-{{ uid }} .pd-close,
    #pd-{{ uid }} .pd-check,
    #pd-{{ uid }} .pd-check svg path { transition: none !important; animation: none !important; }
    #pd-{{ uid }} .pd-check svg path { stroke-dashoffset: 0; }
  }
</style>

{%- comment -%} ========== FLOATING LAUNCHER ========== {%- endcomment -%}
{%- if s.show_launcher -%}
  <button
    type="button"
    id="pd-launcher-{{ uid }}"
    class="button pd-launcher-{{ uid }} color-{{ s.color_scheme }}"
    data-pd-open="{{ uid }}"
    aria-haspopup="dialog"
    aria-controls="pd-{{ uid }}"
    {% if custom_vars != blank %}style="{{ custom_vars | strip_newlines }}"{% endif %}
  >
    {%- if s.launcher_icon != blank -%}
      <span class="pd-launcher__icon" aria-hidden="true">{{ s.launcher_icon }}</span>
    {%- endif -%}
    {{ s.launcher_label | default: 'Get 10% Off' }}
  </button>
{%- endif -%}

{%- comment -%} ========== POPUP ========== {%- endcomment -%}
<div
  id="pd-{{ uid }}"
  class="color-{{ s.color_scheme }}"
  role="dialog"
  aria-modal="true"
  aria-labelledby="pd-title-{{ uid }}"
  hidden
  {% if custom_vars != blank %}style="{{ custom_vars | strip_newlines }}"{% endif %}
  data-pd
  data-delay="{{ delay_ms }}"
  data-frequency-days="{{ s.frequency_days }}"
  data-auto-open="{{ s.auto_open }}"
  data-storage-key="pd-popup-{{ uid }}"
>
  <div class="pd-modal{% if has_image %} pd-has-image{% endif %}">
    <button type="button" class="pd-close" data-pd-close aria-label="Close popup">
      <span aria-hidden="true">&times;</span>
    </button>

    {%- if show_media -%}
      {%- assign main_image = desktop_image | default: mobile_image -%}
      <div class="pd-media">
        <picture>
          {%- if mobile_image != blank -%}
            <source
              media="(max-width: 749px)"
              srcset="{{ mobile_image | image_url: width: 600 }} 600w, {{ mobile_image | image_url: width: 1000 }} 1000w"
            >
          {%- endif -%}
          <img
            src="{{ main_image | image_url: width: 960 }}"
            srcset="{{ main_image | image_url: width: 480 }} 480w, {{ main_image | image_url: width: 960 }} 960w"
            sizes="(max-width: 749px) 100vw, 400px"
            alt="{{ s.heading | strip_html | escape }}"
            width="{{ main_image.width }}"
            height="{{ main_image.height }}"
            loading="lazy"
          >
        </picture>
      </div>
    {%- endif -%}

    <div class="pd-body">
      {%- comment -%} ---------- FORM STATE ---------- {%- endcomment -%}
      <div class="pd-state pd-state--form" data-pd-form-state>
        <h2 id="pd-title-{{ uid }}" class="pd-heading">{{ s.heading }}</h2>
        {%- if s.subheading != blank -%}
          <p class="pd-sub">{{ s.subheading }}</p>
        {%- endif -%}

        {%- form 'customer', class: 'pd-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter, popup-discount">

          <div class="pd-field field">
            <input
              class="field__input"
              id="pd-first-{{ uid }}"
              type="text"
              name="contact[first_name]"
              autocomplete="given-name"
              placeholder="First name"
              aria-required="true"
              required
            >
            <label class="field__label" for="pd-first-{{ uid }}">First name</label>
          </div>

          <div class="pd-field field">
            <input
              class="field__input"
              id="pd-email-{{ uid }}"
              type="email"
              name="contact[email]"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              placeholder="Email address"
              aria-required="true"
              required
            >
            <label class="field__label" for="pd-email-{{ uid }}">Email address</label>
          </div>

          <div class="pd-field field">
            <input
              class="field__input"
              id="pd-phone-{{ uid }}"
              type="tel"
              name="contact[phone]"
              autocomplete="tel"
              placeholder="Phone number (optional)"
            >
            <label class="field__label" for="pd-phone-{{ uid }}">Phone number (optional)</label>
          </div>

          <p class="pd-error" data-pd-error role="alert" aria-live="assertive"></p>

          <button type="submit" class="button button--full-width pd-submit" data-pd-submit>
            <span class="pd-submit__label">{{ s.button_label | default: 'Get My Discount' }}</span>
            <span class="pd-spinner" aria-hidden="true"></span>
          </button>

          {%- if s.fineprint != blank -%}
            <p class="pd-fineprint">{{ s.fineprint }}</p>
          {%- endif -%}
        {%- endform -%}
      </div>

      {%- comment -%} ---------- SUCCESS STATE ---------- {%- endcomment -%}
      <div class="pd-state pd-state--success pd-success" data-pd-success-state hidden aria-live="polite">
        <div class="pd-check" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <h2 class="pd-heading">{{ s.success_heading | default: '🎉 Your Discount is Ready!' }}</h2>
        <p class="pd-sub">{{ s.success_message }}</p>

        <div class="pd-code">
          <code class="pd-code__value" data-pd-code>{{ code }}</code>
          <button type="button" class="button button--secondary pd-copy" data-pd-copy data-code="{{ code | escape }}">
            Copy code
          </button>
        </div>

        <button type="button" class="button button--full-width" data-pd-close>
          {{ s.success_button_label | default: 'Continue Shopping' }}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('pd-{{ uid }}');
    if (!root) return;

    var launcher = document.getElementById('pd-launcher-{{ uid }}');
    var form = root.querySelector('.pd-form');
    var submitBtn = root.querySelector('[data-pd-submit]');
    var errorEl = root.querySelector('[data-pd-error]');
    var formState = root.querySelector('[data-pd-form-state]');
    var successState = root.querySelector('[data-pd-success-state]');
    var emailInput = root.querySelector('input[type="email"]');
    var firstInput = root.querySelector('input[name="contact[first_name]"]');

    var delay = parseInt(root.getAttribute('data-delay'), 10) || 0;
    var days = parseInt(root.getAttribute('data-frequency-days'), 10);
    var autoOpen = root.getAttribute('data-auto-open') === 'true';
    var storageKey = root.getAttribute('data-storage-key');
    var designMode = !!(window.Shopify && window.Shopify.designMode);

    var lastFocused = null;

    /* ---- frequency cap ---- */
    function getSeen() {
      try { var v = window.localStorage.getItem(storageKey); if (v) return parseInt(v, 10); } catch (e) {}
      var m = document.cookie.match(new RegExp('(?:^|; )' + storageKey + '=([^;]+)'));
      return m ? parseInt(m[1], 10) : 0;
    }
    function setSeen() {
      var now = Date.now();
      try { window.localStorage.setItem(storageKey, String(now)); } catch (e) {}
      var maxAge = (days > 0 ? days : 365) * 86400;
      document.cookie = storageKey + '=' + now + ';path=/;max-age=' + maxAge + ';SameSite=Lax';
    }
    function shouldAutoOpen() {
      if (!autoOpen) return false;
      if (days <= 0) return true;
      var seen = getSeen();
      return !seen || (Date.now() - seen) > days * 86400000;
    }

    /* ---- focus trap ---- */
    function focusables() {
      return Array.prototype.slice.call(
        root.querySelectorAll('a[href],button:not([disabled]),input:not([disabled]),[tabindex]:not([tabindex="-1"])')
      ).filter(function (el) { return el.offsetParent !== null && !el.closest('[hidden]'); });
    }
    function onKeydown(e) {
      if (e.key === 'Escape') { close(); return; }
      if (e.key !== 'Tab') return;
      var f = focusables(); if (!f.length) return;
      var first = f[0], last = f[f.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }

    /* ---- open / close ---- */
    function open() {
      if (root.dataset.open === 'true') return;
      root.dataset.open = 'true';
      lastFocused = document.activeElement;
      root.hidden = false;
      if (launcher) launcher.style.display = 'none';
      requestAnimationFrame(function () { requestAnimationFrame(function () { root.classList.add('is-open'); }); });
      document.documentElement.style.overflow = 'hidden';
      document.addEventListener('keydown', onKeydown);
      if (!designMode) setSeen();
      var target = (successState.hidden ? firstInput : null) || root.querySelector('[data-pd-close]');
      if (target) setTimeout(function () { target.focus({ preventScroll: true }); }, 380);
    }
    function close() {
      root.dataset.open = 'false';
      root.classList.remove('is-open');
      document.documentElement.style.overflow = '';
      document.removeEventListener('keydown', onKeydown);
      var done = function () { root.hidden = true; root.removeEventListener('transitionend', done); };
      root.addEventListener('transitionend', done);
      setTimeout(done, 450);
      if (launcher) launcher.style.display = '';
      if (lastFocused && lastFocused.focus) lastFocused.focus();
    }

    /* launcher + close interactions */
    if (launcher) launcher.addEventListener('click', open);
    root.addEventListener('click', function (e) {
      if (e.target === root) close();
      if (e.target.closest('[data-pd-close]')) close();
    });

    /* ---- validation ---- */
    function isEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }
    function showError(msg, field) {
      errorEl.textContent = msg; errorEl.classList.add('is-visible');
      if (field) { field.setAttribute('aria-invalid', 'true'); field.focus(); }
    }
    function clearError() {
      errorEl.textContent = ''; errorEl.classList.remove('is-visible');
      [firstInput, emailInput].forEach(function (el) { if (el) el.removeAttribute('aria-invalid'); });
    }
    function showSuccess() {
      formState.hidden = true; successState.hidden = false;
      var h = successState.querySelector('.pd-heading');
      if (h) { h.setAttribute('tabindex', '-1'); h.focus({ preventScroll: true }); }
    }

    /* ---- submit (AJAX → Shopify customer form) ---- */
    if (form) {
      form.setAttribute('novalidate', 'novalidate');
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        clearError();
        var firstVal = (firstInput && firstInput.value || '').trim();
        var emailVal = (emailInput && emailInput.value || '').trim();
        if (!firstVal) { showError('Please enter your first name.', firstInput); return; }
        if (!emailVal) { showError('Please enter your email address.', emailInput); return; }
        if (!isEmail(emailVal)) { showError('Please enter a valid email address.', emailInput); return; }

        submitBtn.classList.add('is-loading');
        submitBtn.setAttribute('aria-busy', 'true');

        var action = form.getAttribute('action') || window.location.pathname;
        fetch(action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' }
        })
          .then(function (res) {
            if (res.ok || res.status === 0 || res.type === 'opaqueredirect') return true;
            throw new Error('bad status');
          })
          .then(function () { showSuccess(); })
          .catch(function () { showError('Something went wrong. Please try again.'); })
          .finally(function () {
            submitBtn.classList.remove('is-loading');
            submitBtn.removeAttribute('aria-busy');
          });
      });
      [firstInput, emailInput].forEach(function (el) { if (el) el.addEventListener('input', clearError); });
    }

    /* ---- copy code ---- */
    var copyBtn = root.querySelector('[data-pd-copy]');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        var codeVal = copyBtn.getAttribute('data-code') || '';
        var original = copyBtn.textContent;
        var feedback = function () {
          copyBtn.textContent = 'Copied!';
          setTimeout(function () { copyBtn.textContent = original; }, 1800);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(codeVal).then(feedback).catch(function () { legacyCopy(codeVal); feedback(); });
        } else { legacyCopy(codeVal); feedback(); }
      });
    }
    function legacyCopy(text) {
      var ta = document.createElement('textarea');
      ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta); ta.select();
      try { document.execCommand('copy'); } catch (e) {}
      document.body.removeChild(ta);
    }

    /* ---- timed auto-open ---- */
    function init() {
      if (designMode) { open(); return; }
      if (shouldAutoOpen()) setTimeout(open, delay);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else { init(); }

    /* theme editor */
    document.addEventListener('shopify:section:select', function (e) {
      if (e.detail && e.detail.sectionId === '{{ uid }}') open();
    });
    document.addEventListener('shopify:section:deselect', function (e) {
      if (e.detail && e.detail.sectionId === '{{ uid }}') close();
    });
  })();
</script>

