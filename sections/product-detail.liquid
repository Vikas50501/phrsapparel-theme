<script>
(function () {
  /* ── Gallery thumb switcher ──────────────────────────────── */
  var mainImg = document.getElementById('ProductMainImage');
  document.querySelectorAll('.product-gallery__thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.product-gallery__thumb').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      if (mainImg) {
        mainImg.src = btn.dataset.full;
        if (btn.dataset.contain !== undefined) {
          mainImg.classList.add('is-contain');
        } else {
          mainImg.classList.remove('is-contain');
        }
      }
    });
  });

  /* ── Qty stepper ─────────────────────────────────────────── */
  var qtyDisplay = document.getElementById('QtyDisplay');
  var qtyInput   = document.getElementById('QtyInput');
  document.querySelectorAll('.qty-stepper .dec').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var v = parseInt(qtyInput.value, 10);
      if (v > 1) { qtyInput.value = v - 1; qtyDisplay.textContent = v - 1; }
    });
  });
  document.querySelectorAll('.qty-stepper .inc').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var v = parseInt(qtyInput.value, 10);
      qtyInput.value = v + 1; qtyDisplay.textContent = v + 1;
    });
  });

  /* ── Product tabs ────────────────────────────────────────── */
  document.querySelectorAll('.product-tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.dataset.tab;
      document.querySelectorAll('.product-tab-btn').forEach(function(b){
        b.classList.remove('active');
        b.setAttribute('aria-selected','false');
      });
      document.querySelectorAll('.product-tab-panel').forEach(function(p){ p.classList.remove('active'); });
      btn.classList.add('active');
      btn.setAttribute('aria-selected','true');
      var panel = document.querySelector('[data-panel="' + tab + '"]');
      if (panel) panel.classList.add('active');
    });
  });

  /* ── Notes strip dots ────────────────────────────────────── */
  var track = document.getElementById('NotesTrack');
  var dots  = document.getElementById('NotesDots');
  if (track && dots) {
    var cards = track.querySelectorAll('.note-card');
    var count = Math.ceil(cards.length / 3);
    for (var i = 0; i < count; i++) {
      var s = document.createElement('span');
      if (i === 0) s.classList.add('active');
      dots.appendChild(s);
    }
    track.addEventListener('scroll', function() {
      var idx = Math.round(track.scrollLeft / (track.scrollWidth / count));
      dots.querySelectorAll('span').forEach(function(s, i){ s.classList.toggle('active', i === idx); });
    });
  }

  /* ── Variant price update ────────────────────────────────── */
  var variantData = {{ product.variants | json }};
  var hiddenId    = document.querySelector('#ProductForm input[name="id"]');
  var priceCur    = document.getElementById('PriceCurrent');
  var priceComp   = document.getElementById('PriceCompare');
  var priceMrp    = document.getElementById('PriceMrpLine');
  var priceSave   = document.getElementById('PriceSavings');

  var moneyFormat = {{ shop.money_format | json }};
  function formatMoney(cents) {
    return Shopify.formatMoney ? Shopify.formatMoney(cents, moneyFormat) : ('₹' + (cents / 100).toFixed(0));
  }

  function updatePrice(variantId) {
    var v = variantData.find(function(x){ return x.id === variantId; });
    if (!v) return;
    var showMrp = v.compare_at_price && v.compare_at_price > v.price;
    if (priceCur) {
      priceCur.textContent = formatMoney(v.price);
      priceCur.setAttribute('content', (v.price / 100).toFixed(2));
    }
    if (priceMrp) priceMrp.style.display = showMrp ? '' : 'none';
    if (priceComp && showMrp) priceComp.textContent = formatMoney(v.compare_at_price);
    if (priceSave && showMrp) priceSave.textContent = 'SAVE ' + formatMoney(v.compare_at_price - v.price);
  }

  document.addEventListener('change', function(e) {
    if (e.target && e.target.name === 'id') updatePrice(parseInt(e.target.value, 10));
  });

})();
</script>

