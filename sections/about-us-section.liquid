{%- comment -%} Pre-assign variables before style block {%- endcomment -%}
{%- assign au_accent_r = section.settings.accent_color | color_extract: 'red' -%}
{%- assign au_accent_g = section.settings.accent_color | color_extract: 'green' -%}
{%- assign au_accent_b = section.settings.accent_color | color_extract: 'blue' -%}

{%- style -%}
/* ═══════════════════════════════════════════════════════════════
   ABOUT US — Premium editorial layout
   Matches theme: #f0efed warm off-white, serif display headings
═══════════════════════════════════════════════════════════════ */

/* ── Section wrapper ─────────────────────────────────────────── */
.au-{{ section.id }} {
  background: {{ section.settings.bg }};
  color: {{ section.settings.text_color }};
}

/* ── Shared container ────────────────────────────────────────── */
.au-container-{{ section.id }} {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 {{ section.settings.side_pad }}px;
}

/* ═══════════════ HERO — full-bleed image + title ═══════════════ */
.au-hero-{{ section.id }} {
  position: relative;
  height: {{ section.settings.hero_height_mobile }}px;
  overflow: hidden;
  background: #111;
}

@media (min-width: 750px) {
  .au-hero-{{ section.id }} {
    height: {{ section.settings.hero_height }}px;
  }
}

.au-hero-{{ section.id }} img,
.au-hero-{{ section.id }} .placeholder-svg {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  display: block;
  transition: transform 8s ease;
}

.au-hero-{{ section.id }}:hover img { transform: scale(1.03); }

.au-hero-overlay-{{ section.id }} {
  position: absolute; inset: 0;
  background: rgba(0,0,0,{{ section.settings.hero_overlay | divided_by: 100.0 }});
  z-index: 1;
}

.au-hero-content-{{ section.id }} {
  position: absolute; inset: 0; z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: {{ section.settings.hero_valign }};
  align-items: {{ section.settings.hero_halign }};
  text-align: {{ section.settings.hero_text_align }};
  padding: {{ section.settings.hero_pad }}px {{ section.settings.side_pad }}px;
}

.au-eyebrow-{{ section.id }} {
  font-size: {{ section.settings.eyebrow_size }}px;
  font-weight: 600;
  letter-spacing: {{ section.settings.eyebrow_spacing | divided_by: 100.0 }}em;
  text-transform: uppercase;
  color: {{ section.settings.accent_color }};
  margin: 0 0 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.au-eyebrow-{{ section.id }}::before,
.au-eyebrow-{{ section.id }}::after {
  content: '';
  flex: 0 0 {{ section.settings.eyebrow_line }}px;
  height: 1px;
  background: {{ section.settings.accent_color }};
  opacity: 0.7;
}

.au-hero-title-{{ section.id }} {
  font-size: var(--font-h1-size);
  font-weight: var(--font-h1-weight);
  font-style: normal;
  font-family: inherit;
  color: {{ section.settings.hero_title_color }};
  letter-spacing: {{ section.settings.hero_title_spacing | divided_by: 100.0 }}em;
  line-height: 1.05;
  margin: 0;
  max-width: {{ section.settings.hero_title_max_width }}px;
}

.au-hero-sub-{{ section.id }} {
  font-size: {{ section.settings.hero_sub_size }}px;
  color: rgba({{ au_accent_r }},{{ au_accent_g }},{{ au_accent_b }},0.9);
  margin: 20px 0 0;
  font-weight: 400;
  letter-spacing: 0.04em;
  line-height: 1.6;
  max-width: 500px;
}

/* ═══════════════ INTRO — split layout ══════════════════════════ */
.au-intro-{{ section.id }} {
  padding: {{ section.settings.section_pad }}px 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.au-intro-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: {{ section.settings.intro_left_w }}fr {{ section.settings.intro_right_w }}fr;
  gap: {{ section.settings.intro_gap }}px;
  align-items: center;
}

@media (max-width: 768px) {
  .au-intro-grid-{{ section.id }} { grid-template-columns: 1fr; }
}

.au-intro-left-{{ section.id }} {}

.au-section-label-{{ section.id }} {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: {{ section.settings.accent_color }};
  margin: 0 0 20px;
  display: block;
}

.au-display-title-{{ section.id }} {
  font-size: var(--font-h2-size);
  font-weight: var(--font-h2-weight);
  font-style: normal;
  font-family: inherit;
  color: {{ section.settings.heading_color }};
  letter-spacing: {{ section.settings.display_spacing | divided_by: 100.0 }}em;
  line-height: 1.1;
  margin: 0;
}

.au-intro-right-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: {{ section.settings.body_gap }}px;
}

.au-body-{{ section.id }} {
  font-size: {{ section.settings.body_size }}px;
  font-weight: {{ section.settings.body_weight }};
  color: {{ section.settings.body_color }};
  line-height: {{ section.settings.body_lh | divided_by: 100.0 }};
  margin: 0;
}

.au-body-large-{{ section.id }} {
  font-size: {{ section.settings.body_size | plus: 3 }}px;
  color: {{ section.settings.heading_color }};
  font-weight: 500;
  line-height: 1.55;
  margin: 0;
}

/* ═══════════════ STATS ══════════════════════════════════════════ */
.au-stats-{{ section.id }} {
  background: {{ section.settings.stats_bg }};
  padding: {{ section.settings.stats_pad }}px 0;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.au-stats-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat({{ section.settings.stats_cols }}, 1fr);
  gap: 1px;
  background: rgba(0,0,0,0.08);
}

@media (max-width: 600px) {
  .au-stats-grid-{{ section.id }} {
    grid-template-columns: repeat(2, 1fr);
  }
}

.au-stat-{{ section.id }} {
  background: {{ section.settings.stats_bg }};
  padding: {{ section.settings.stats_item_pad }}px;
  text-align: center;
}

.au-stat-num-{{ section.id }} {
  font-size: var(--font-h2-size);
  font-weight: var(--font-h2-weight);
  font-family: inherit;
  font-style: normal;
  color: {{ section.settings.stat_num_color }};
  line-height: 1;
  margin: 0 0 8px;
  letter-spacing: -0.02em;
}

.au-stat-label-{{ section.id }} {
  font-size: {{ section.settings.stat_label_size }}px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: {{ section.settings.stat_label_color }};
  margin: 0;
}

.au-stat-desc-{{ section.id }} {
  font-size: 13px;
  color: {{ section.settings.body_color }};
  margin: 6px 0 0;
  line-height: 1.4;
}

/* ═══════════════ IMAGE + TEXT BAND ══════════════════════════════ */
.au-band-{{ section.id }} {
  padding: {{ section.settings.section_pad }}px 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.au-band-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: {{ section.settings.band_gap }}px;
  align-items: center;
}

.au-band-grid-{{ section.id }}[data-reverse="true"] {
  direction: rtl;
}

.au-band-grid-{{ section.id }}[data-reverse="true"] > * {
  direction: ltr;
}

@media (max-width: 768px) {
  .au-band-grid-{{ section.id }} {
    grid-template-columns: 1fr;
    direction: ltr !important;
  }
  .au-band-grid-{{ section.id }} > * { direction: ltr !important; }
}

.au-band-img-{{ section.id }} {
  position: relative;
  aspect-ratio: {{ section.settings.band_aspect }};
  overflow: hidden;
  border-radius: {{ section.settings.band_radius }}px;
  background: #ddd;
}

.au-band-img-{{ section.id }} img,
.au-band-img-{{ section.id }} .placeholder-svg {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.6s ease;
}

.au-band-img-{{ section.id }}:hover img { transform: scale(1.04); }

.au-band-text-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: {{ section.settings.body_gap }}px;
  padding: {{ section.settings.band_text_pad }}px;
}

/* ═══════════════ TEAM GRID ══════════════════════════════════════ */
.au-team-{{ section.id }} {
  padding: {{ section.settings.section_pad }}px 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.au-team-header-{{ section.id }} {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: {{ section.settings.body_gap | times: 2 }}px;
  flex-wrap: wrap;
  gap: 16px;
}

.au-team-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat({{ section.settings.team_cols }}, 1fr);
  gap: {{ section.settings.team_gap }}px;
}

@media (max-width: 768px) {
  .au-team-grid-{{ section.id }} { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 420px) {
  .au-team-grid-{{ section.id }} { grid-template-columns: 1fr; }
}

.au-member-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.au-member-img-{{ section.id }} {
  aspect-ratio: {{ section.settings.member_aspect }};
  overflow: hidden;
  border-radius: {{ section.settings.member_radius }}px;
  background: #e0e0e0;
  position: relative;
}

.au-member-img-{{ section.id }} img,
.au-member-img-{{ section.id }} .placeholder-svg {
  width: 100%; height: 100%;
  object-fit: cover; object-position: top;
  display: block;
  transition: transform 0.5s ease;
}

.au-member-{{ section.id }}:hover .au-member-img-{{ section.id }} img {
  transform: scale(1.05);
}

.au-member-name-{{ section.id }} {
  font-size: var(--font-h3-size);
  font-weight: var(--font-h3-weight);
  font-family: inherit;
  color: {{ section.settings.heading_color }};
  margin: 0;
  line-height: 1.2;
}

.au-member-role-{{ section.id }} {
  font-size: {{ section.settings.member_role_size }}px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: {{ section.settings.accent_color }};
  margin: 4px 0 0;
}

.au-member-bio-{{ section.id }} {
  font-size: 13px;
  color: {{ section.settings.body_color }};
  line-height: 1.6;
  margin: 4px 0 0;
}

/* ═══════════════ VALUES ═════════════════════════════════════════ */
.au-values-{{ section.id }} {
  padding: {{ section.settings.section_pad }}px 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.au-values-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat({{ section.settings.values_cols }}, 1fr);
  gap: {{ section.settings.values_gap }}px;
  margin-top: {{ section.settings.body_gap | times: 2 }}px;
}

@media (max-width: 768px) {
  .au-values-grid-{{ section.id }} { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 420px) {
  .au-values-grid-{{ section.id }} { grid-template-columns: 1fr; }
}

.au-value-{{ section.id }} {
  padding: {{ section.settings.values_pad }}px;
  background: {{ section.settings.values_card_bg }};
  border: 1px solid {{ section.settings.values_card_border }};
  border-radius: {{ section.settings.values_radius }}px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.au-value-{{ section.id }}:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0,0,0,0.08);
}

.au-value-icon-{{ section.id }} {
  font-size: {{ section.settings.value_icon_size }}px;
  line-height: 1;
  display: block;
}

.au-value-title-{{ section.id }} {
  font-size: var(--font-h3-size);
  font-weight: var(--font-h3-weight);
  font-family: inherit;
  color: {{ section.settings.heading_color }};
  margin: 0;
  letter-spacing: -0.01em;
}

.au-value-text-{{ section.id }} {
  font-size: 14px;
  color: {{ section.settings.body_color }};
  line-height: 1.6;
  margin: 0;
}

/* ═══════════════ CTA BAND ═══════════════════════════════════════ */
.au-cta-{{ section.id }} {
  padding: {{ section.settings.section_pad }}px 0;
  background: {{ section.settings.cta_bg }};
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.au-cta-inner-{{ section.id }} {
  text-align: {{ section.settings.cta_align }};
  display: flex;
  flex-direction: column;
  align-items: {{ section.settings.cta_align_flex }};
  gap: 28px;
}

.au-cta-title-{{ section.id }} {
  font-size: var(--font-h2-size);
  font-weight: var(--font-h2-weight);
  font-style: normal;
  font-family: inherit;
  color: {{ section.settings.cta_title_color }};
  letter-spacing: -0.02em;
  line-height: 1.1;
  margin: 0;
  max-width: {{ section.settings.cta_title_max_width }}px;
}

.au-cta-sub-{{ section.id }} {
  font-size: {{ section.settings.body_size }}px;
  color: {{ section.settings.cta_sub_color }};
  margin: 0;
  line-height: 1.6;
  max-width: 500px;
}

.au-cta-btns-{{ section.id }} {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  justify-content: {{ section.settings.cta_align }};
}

.au-btn-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: {{ section.settings.btn_py }}px {{ section.settings.btn_px }}px;
  font-size: {{ section.settings.btn_size }}px;
  font-weight: {{ section.settings.btn_weight }};
  letter-spacing: {{ section.settings.btn_ls | divided_by: 100.0 }}em;
  text-transform: {{ section.settings.btn_tt }};
  text-decoration: none;
  border-radius: {{ section.settings.btn_r }}px;
  border: {{ section.settings.btn_bw }}px solid transparent;
  transition: background 0.22s, color 0.22s, border-color 0.22s, transform 0.2s;
  font-family: inherit;
  cursor: pointer;
  white-space: nowrap;
}

.au-btn-{{ section.id }}:hover { transform: translateY(-2px); }

.au-btn-primary-{{ section.id }} {
  background: {{ section.settings.btn1_bg }};
  color: {{ section.settings.btn1_color }};
  border-color: {{ section.settings.btn1_bg }};
}

.au-btn-primary-{{ section.id }}:hover {
  background: {{ section.settings.btn1_bg_h }};
  color: {{ section.settings.btn1_color_h }};
  border-color: {{ section.settings.btn1_bg_h }};
}

.au-btn-outline-{{ section.id }} {
  background: transparent;
  color: {{ section.settings.btn2_color }};
  border-color: {{ section.settings.btn2_border }};
}

.au-btn-outline-{{ section.id }}:hover {
  background: {{ section.settings.btn2_bg_h }};
  color: {{ section.settings.btn2_color_h }};
  border-color: {{ section.settings.btn2_bg_h }};
}

/* ═══════════════ SECTION VISIBILITY TOGGLES ═════════════════════ */
.au-section-hidden { display: none !important; }

/* ═══════════════ CUSTOM OVERRIDES ═══════════════════════════════ */
.au-display-title-{{ section.id }} {
  text-transform: uppercase !important;
}
.au-section-label-{{ section.id }} {
  margin-bottom: 0 !important;
}
@media screen and (max-width: 767px) {
  h2.au-cta-title-{{ section.id }} {
    font-size: 25px !important;
  }
  h2.au-display-title-{{ section.id }} {
    font-size: 25px !important;
  }
  .au-intro-grid-{{ section.id }} {
    gap: 35px !important;
  }
}
{%- endstyle -%}

<div class="au-{{ section.id }}">

  {%- comment -%}──── HERO ────{%- endcomment -%}
  {%- unless section.settings.hide_hero -%}
  <div class="au-hero-{{ section.id }}">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | img_url: '2400x' }}"
           alt="{{ section.settings.hero_image.alt | default: section.settings.hero_title | escape }}"
           loading="eager">
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
    <div class="au-hero-overlay-{{ section.id }}"></div>
    <div class="au-hero-content-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="au-eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.hero_title != blank -%}
        <h1 class="au-hero-title-{{ section.id }}">{{ section.settings.hero_title }}</h1>
      {%- endif -%}
      {%- if section.settings.hero_sub != blank -%}
        <p class="au-hero-sub-{{ section.id }}">{{ section.settings.hero_sub }}</p>
      {%- endif -%}
    </div>
  </div>
  {%- endunless -%}

  {%- comment -%}──── INTRO ────{%- endcomment -%}
  {%- unless section.settings.hide_intro -%}
  <div class="au-intro-{{ section.id }}">
    <div class="au-container-{{ section.id }}">
      <div class="au-intro-grid-{{ section.id }}">
        <div class="au-intro-left-{{ section.id }}">
          {%- if section.settings.intro_label != blank -%}
            <span class="au-section-label-{{ section.id }}">{{ section.settings.intro_label }}</span>
          {%- endif -%}
          {%- if section.settings.intro_title != blank -%}
            <h2 class="au-display-title-{{ section.id }}">{{ section.settings.intro_title }}</h2>
          {%- endif -%}
        </div>
        <div class="au-intro-right-{{ section.id }}">
          {%- if section.settings.intro_lead != blank -%}
            <p class="au-body-large-{{ section.id }}">{{ section.settings.intro_lead }}</p>
          {%- endif -%}
          {%- if section.settings.intro_body != blank -%}
            <p class="au-body-{{ section.id }}">{{ section.settings.intro_body }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
  {%- endunless -%}

  {%- comment -%}──── STATS ────{%- endcomment -%}
  {%- unless section.settings.hide_stats -%}
  {%- assign has_stats = false -%}
  {%- if section.settings.stat1_num != blank or section.settings.stat2_num != blank or section.settings.stat3_num != blank or section.settings.stat4_num != blank -%}
    {%- assign has_stats = true -%}
  {%- endif -%}
  {%- if has_stats -%}
  <div class="au-stats-{{ section.id }}">
    <div class="au-container-{{ section.id }}">
      <div class="au-stats-grid-{{ section.id }}">
        {%- for i in (1..4) -%}
          {%- liquid
            case i
              when 1
                assign sn = section.settings.stat1_num
                assign sl = section.settings.stat1_label
                assign sd = section.settings.stat1_desc
              when 2
                assign sn = section.settings.stat2_num
                assign sl = section.settings.stat2_label
                assign sd = section.settings.stat2_desc
              when 3
                assign sn = section.settings.stat3_num
                assign sl = section.settings.stat3_label
                assign sd = section.settings.stat3_desc
              when 4
                assign sn = section.settings.stat4_num
                assign sl = section.settings.stat4_label
                assign sd = section.settings.stat4_desc
            endcase
          -%}
          {%- if sn != blank -%}
          <div class="au-stat-{{ section.id }}">
            <p class="au-stat-num-{{ section.id }}">{{ sn }}</p>
            {%- if sl != blank -%}<p class="au-stat-label-{{ section.id }}">{{ sl }}</p>{%- endif -%}
            {%- if sd != blank -%}<p class="au-stat-desc-{{ section.id }}">{{ sd }}</p>{%- endif -%}
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
  {%- endif -%}
  {%- endunless -%}

  {%- comment -%}──── IMAGE + TEXT BAND ────{%- endcomment -%}
  {%- unless section.settings.hide_band -%}
  {%- if section.settings.band_image != blank or section.settings.band_title != blank -%}
  <div class="au-band-{{ section.id }}">
    <div class="au-container-{{ section.id }}">
      <div class="au-band-grid-{{ section.id }}" data-reverse="{{ section.settings.band_reverse }}">
        <div class="au-band-img-{{ section.id }}">
          {%- if section.settings.band_image != blank -%}
            <img src="{{ section.settings.band_image | img_url: '1200x' }}"
                 alt="{{ section.settings.band_image.alt | default: section.settings.band_title | escape }}"
                 loading="lazy">
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="au-band-text-{{ section.id }}">
          {%- if section.settings.band_label != blank -%}
            <span class="au-section-label-{{ section.id }}">{{ section.settings.band_label }}</span>
          {%- endif -%}
          {%- if section.settings.band_title != blank -%}
            <h2 class="au-display-title-{{ section.id }}">{{ section.settings.band_title }}</h2>
          {%- endif -%}
          {%- if section.settings.band_lead != blank -%}
            <p class="au-body-large-{{ section.id }}">{{ section.settings.band_lead }}</p>
          {%- endif -%}
          {%- if section.settings.band_body != blank -%}
            <p class="au-body-{{ section.id }}">{{ section.settings.band_body }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
  {%- endif -%}
  {%- endunless -%}

  {%- comment -%}──── TEAM ────{%- endcomment -%}
  {%- unless section.settings.hide_team -%}
  {%- assign has_members = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'member' -%}{%- assign has_members = true -%}{%- endif -%}
  {%- endfor -%}
  {%- if has_members -%}
  <div class="au-team-{{ section.id }}">
    <div class="au-container-{{ section.id }}">
      <div class="au-team-header-{{ section.id }}">
        <div>
          {%- if section.settings.team_label != blank -%}
            <span class="au-section-label-{{ section.id }}">{{ section.settings.team_label }}</span>
          {%- endif -%}
          {%- if section.settings.team_title != blank -%}
            <h2 class="au-display-title-{{ section.id }}" style="margin-top:12px;">{{ section.settings.team_title }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.team_sub != blank -%}
          <p class="au-body-{{ section.id }}" style="max-width:320px;">{{ section.settings.team_sub }}</p>
        {%- endif -%}
      </div>
      <div class="au-team-grid-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'member' -%}
          <div class="au-member-{{ section.id }}" {{ block.shopify_attributes }}>
            <div class="au-member-img-{{ section.id }}">
              {%- if block.settings.photo != blank -%}
                <img src="{{ block.settings.photo | img_url: '600x' }}"
                     alt="{{ block.settings.photo.alt | default: block.settings.name | escape }}"
                     loading="lazy">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div>
              {%- if block.settings.name != blank -%}
                <p class="au-member-name-{{ section.id }}">{{ block.settings.name }}</p>
              {%- endif -%}
              {%- if block.settings.role != blank -%}
                <p class="au-member-role-{{ section.id }}">{{ block.settings.role }}</p>
              {%- endif -%}
              {%- if block.settings.bio != blank -%}
                <p class="au-member-bio-{{ section.id }}">{{ block.settings.bio }}</p>
              {%- endif -%}
            </div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
  {%- endif -%}
  {%- endunless -%}

  {%- comment -%}──── VALUES ────{%- endcomment -%}
  {%- unless section.settings.hide_values -%}
  {%- assign has_values = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'value' -%}{%- assign has_values = true -%}{%- endif -%}
  {%- endfor -%}
  {%- if has_values -%}
  <div class="au-values-{{ section.id }}">
    <div class="au-container-{{ section.id }}">
      <div>
        {%- if section.settings.values_label != blank -%}
          <span class="au-section-label-{{ section.id }}">{{ section.settings.values_label }}</span>
        {%- endif -%}
        {%- if section.settings.values_title != blank -%}
          <h2 class="au-display-title-{{ section.id }}" style="margin-top:12px;">{{ section.settings.values_title }}</h2>
        {%- endif -%}
      </div>
      <div class="au-values-grid-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'value' -%}
          <div class="au-value-{{ section.id }}" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <span class="au-value-icon-{{ section.id }}">{{ block.settings.icon }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="au-value-title-{{ section.id }}">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="au-value-text-{{ section.id }}">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
  {%- endif -%}
  {%- endunless -%}

  {%- comment -%}──── CTA ────{%- endcomment -%}
  {%- unless section.settings.hide_cta -%}
  {%- if section.settings.cta_title != blank -%}
  <div class="au-cta-{{ section.id }}">
    <div class="au-container-{{ section.id }}">
      <div class="au-cta-inner-{{ section.id }}">
        {%- if section.settings.cta_eyebrow != blank -%}
          <p class="au-eyebrow-{{ section.id }}">{{ section.settings.cta_eyebrow }}</p>
        {%- endif -%}
        <h2 class="au-cta-title-{{ section.id }}">{{ section.settings.cta_title }}</h2>
        {%- if section.settings.cta_sub != blank -%}
          <p class="au-cta-sub-{{ section.id }}">{{ section.settings.cta_sub }}</p>
        {%- endif -%}
        {%- if section.settings.btn1_label != blank or section.settings.btn2_label != blank -%}
          <div class="au-cta-btns-{{ section.id }}">
            {%- if section.settings.btn1_label != blank -%}
              <a class="au-btn-{{ section.id }} au-btn-primary-{{ section.id }}"
                 href="{{ section.settings.btn1_link | default: '#' }}">{{ section.settings.btn1_label }}</a>
            {%- endif -%}
            {%- if section.settings.btn2_label != blank -%}
              <a class="au-btn-{{ section.id }} au-btn-outline-{{ section.id }}"
                 href="{{ section.settings.btn2_link | default: '#' }}">{{ section.settings.btn2_label }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
  {%- endif -%}
  {%- endunless -%}

</div>

