{% style %}
  #shopify-section-{{ section.id }} .contact-page {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="contact-page">
  <p class="text-eyebrow text-muted">{{ section.settings.eyebrow | default: 'Get in touch' }}</p>
  <h1>{{ section.settings.heading | default: 'Contact' }}</h1>
  {%- if section.settings.intro != blank -%}
    <p class="contact-page__intro">{{ section.settings.intro }}</p>
  {%- endif -%}

  <div class="contact-grid">
    <div class="contact-form">
      {%- form 'contact' -%}
        {%- if form.posted_successfully? -%}
          <p style="color:oklch(0.6 0.13 145);font-size:0.9375rem;">Thank you — we'll be in touch shortly.</p>
        {%- endif -%}

        {%- if form.errors -%}
          <ul class="customer-errors">
            {%- for error in form.errors -%}
              <li>{{ form.errors.messages[error] }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <label>
          <span class="field-label">Name</span>
          <input type="text" name="contact[name]" value="{{ form.name }}" autocomplete="name" required>
        </label>
        <label>
          <span class="field-label">Email</span>
          <input type="email" name="contact[email]" value="{{ form.email }}" autocomplete="email" required>
        </label>
        <label>
          <span class="field-label">Subject</span>
          <input type="text" name="contact[subject]" value="{{ form.subject }}">
        </label>
        <label>
          <span class="field-label">Message</span>
          <textarea name="contact[body]" rows="6" required>{{ form.body }}</textarea>
        </label>
        <button type="submit">Send message</button>
      {%- endform -%}
    </div>

    <div class="contact-info">
      {%- if section.settings.email != blank -%}
        <div class="contact-info__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:{{ section.settings.email }}">
            <p class="label">Email</p>
            <p class="value">{{ section.settings.email }}</p>
          </a>
        </div>
      {%- endif -%}

      {%- if section.settings.response_time != blank -%}
        <div class="contact-info__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div>
            <p class="label">Response Time</p>
            <p class="value">{{ section.settings.response_time }}</p>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.instagram_url != blank -%}
        <div class="contact-info__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">
            <p class="label">Instagram</p>
            <p class="value">@{{ section.settings.instagram_handle | default: 'indinoir.store' }}</p>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Get in touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "A question about your order, a fragrance inquiry, or just something unsaid. We read every message." },
    { "type": "text", "id": "email", "label": "Contact email" },
    { "type": "text", "id": "response_time", "label": "Response time", "default": "Within 24–48 hours" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram handle" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 0, "max": 200, "step": 4, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 0, "max": 200, "step": 4, "default": 80 }
  ],
  "presets": [
    { "name": "Contact Page" }
  ]
}
{% endschema %}
