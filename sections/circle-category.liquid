{%- liquid
  assign s = section.settings
  assign mobile_items = s.mobile_items_visible | default: 3
  assign m_gap = s.mobile_item_gap | default: 14
  assign m_gap_total = m_gap | times: mobile_items
  assign dir_num = 1
  if s.marquee_direction == 'right'
    assign dir_num = -1
  endif
  assign cc_underline_display = 'block'
  unless s.show_underline
    assign cc_underline_display = 'none'
  endunless
-%}
{%- style -%}
  /* ════════════════════════════════════════════════════
     CATEGORY CIRCLES — seamless infinite marquee
  ════════════════════════════════════════════════════ */

  .cc-section-{{ section.id }} {
    background: {{ s.bg_color }};
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .cc-section-{{ section.id }} {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  .cc-container-{{ section.id }} {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Heading ─────────────────────────────────────────── */
  .cc-heading-wrap-{{ section.id }} {
    text-align: {{ s.heading_align }};
    margin-bottom: {{ s.heading_gap }}px;
    padding: 0 24px;
  }

  .cc-heading-{{ section.id }} {
    display: inline-block;
    position: relative;
    font-size: var(--font-h2-size);
    font-weight: var(--font-h2-weight);
    font-family: inherit;
    color: {{ s.heading_color }};
    letter-spacing: {{ s.heading_spacing | divided_by: 100.0 }}em;
    line-height: 1.2;
    margin: 0;
    padding-bottom: {{ s.underline_gap }}px;
  }

  .cc-heading-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: {{ s.underline_width }}px;
    height: {{ s.underline_height }}px;
    background: {{ s.underline_color }};
    border-radius: {{ s.underline_height }}px;
    display: {{ cc_underline_display }};
  }

  .cc-heading-wrap-{{ section.id }}[data-align="left"]  .cc-heading-{{ section.id }}::after { left: 0; transform: none; }
  .cc-heading-wrap-{{ section.id }}[data-align="right"] .cc-heading-{{ section.id }}::after { left: auto; right: 0; transform: none; }

  /* ── Marquee viewport ────────────────────────────────── */
  .cc-viewport-{{ section.id }} {
    overflow: hidden;
    position: relative;
    padding: 0;
  }

  /* Fade edges */
  .cc-viewport-{{ section.id }}::before,
  .cc-viewport-{{ section.id }}::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: {{ s.edge_fade }}px;
    z-index: 2;
    pointer-events: none;
  }
  .cc-viewport-{{ section.id }}::before { left: 0;  background: linear-gradient(to right, {{ s.bg_color }}, transparent); }
  .cc-viewport-{{ section.id }}::after  { right: 0; background: linear-gradient(to left,  {{ s.bg_color }}, transparent); }

  /* ── Scroller: native swipe/drag; JS drives the auto-scroll ── */
  .cc-scroller-{{ section.id }} {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    /* vertical room so the hover lift + shadow are not clipped */
    padding: {{ s.slider_pad_y | plus: 14 }}px 0;
    {% if s.enable_drag %}cursor: grab;{% endif %}
  }
  .cc-scroller-{{ section.id }}::-webkit-scrollbar { display: none; }
  .cc-scroller-{{ section.id }}.is-dragging { cursor: grabbing; }
  .cc-scroller-{{ section.id }}.is-dragging a { pointer-events: none; }

  /* ── Track: two identical copies for the seamless loop ── */
  .cc-track-{{ section.id }} {
    display: flex;
    width: max-content;
  }

  /* ── Prev / next arrows ──────────────────────────────── */
  .cc-arrow-{{ section.id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: {{ s.arrow_size }}px;
    height: {{ s.arrow_size }}px;
    border-radius: 50%;
    border: none;
    background: {{ s.arrow_bg }};
    color: {{ s.arrow_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0,0,0,0.14);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .cc-arrow-{{ section.id }}--prev { left: 12px; }
  .cc-arrow-{{ section.id }}--next { right: 12px; }
  .cc-arrow-{{ section.id }} svg { width: 44%; height: 44%; }
  .cc-arrow-{{ section.id }}:hover { transform: translateY(-50%) scale(1.08); }
  @media screen and (max-width: 749px) {
    .cc-arrow-{{ section.id }} { width: {{ s.arrow_size | times: 0.8 | round }}px; height: {{ s.arrow_size | times: 0.8 | round }}px; }
  }

  /* ── Each category item ──────────────────────────────── */
  .cc-item-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ s.label_gap }}px;
    flex-shrink: 0;
    text-decoration: none;
    color: inherit;
    width: {{ s.circle_size }}px;
    margin-right: {{ s.item_gap }}px;
  }

  .cc-circle-{{ section.id }} {
    width: {{ s.circle_size }}px;
    height: {{ s.circle_size }}px;
    border-radius: 50%;
    overflow: hidden;
    background: {{ s.circle_bg }};
    border: {{ s.circle_border_width }}px solid {{ s.circle_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease,
                border-color 0.3s;
  }

  .cc-item-{{ section.id }}:hover .cc-circle-{{ section.id }} {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.10);
    border-color: {{ s.circle_border_hover }};
  }

  .cc-circle-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    pointer-events: none;
    transform-origin: center center;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    padding: {{ s.image_padding }}px;
    box-sizing: border-box;
  }

  .cc-item-{{ section.id }}:hover .cc-circle-{{ section.id }} img {
    transform: rotate({{ s.hover_rotate }}deg) scale({{ s.hover_scale | divided_by: 100.0 }});
  }

  .cc-circle-{{ section.id }} .placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  /* ── Label ───────────────────────────────────────────── */
  .cc-label-{{ section.id }} {
    font-size: {{ s.label_size }}px;
    font-weight: {{ s.label_weight }};
    font-family: inherit;
    color: {{ s.label_color }};
    letter-spacing: {{ s.label_spacing | divided_by: 100.0 }}em;
    text-transform: {{ s.label_transform }};
    text-align: center;
    line-height: 1.3;
    margin: 0;
    transition: color 0.3s;
  }

  .cc-item-{{ section.id }}:hover .cc-label-{{ section.id }} {
    color: {{ s.label_hover_color }};
  }

  /* ── Mobile: show exactly N circles, fully editable ──── */
  @media screen and (max-width: 749px) {
    .cc-section-{{ section.id }} {
      padding-top: {{ s.mobile_padding_top }}px;
      padding-bottom: {{ s.mobile_padding_bottom }}px;
    }
    .cc-heading-{{ section.id }} { font-size: {{ s.mobile_heading_size }}px; }
    .cc-item-{{ section.id }},
    .cc-circle-{{ section.id }} {
      width: calc((100vw - {{ m_gap_total }}px) / {{ mobile_items }});
    }
    .cc-circle-{{ section.id }} {
      height: calc((100vw - {{ m_gap_total }}px) / {{ mobile_items }});
    }
    .cc-item-{{ section.id }} { margin-right: {{ m_gap }}px; }
    .cc-circle-{{ section.id }} img { padding: {{ s.mobile_image_padding }}px; }
    .cc-label-{{ section.id }} { font-size: {{ s.mobile_label_size }}px; }
  }
{%- endstyle -%}

<div class="cc-section-{{ section.id }}" id="cc-section-{{ section.id }}">

  <div class="cc-container-{{ section.id }}">
    {%- if s.heading != blank -%}
      <div class="cc-heading-wrap-{{ section.id }}" data-align="{{ s.heading_align }}">
        <h2 class="cc-heading-{{ section.id }}">{{ s.heading }}</h2>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Carousel — full width so the edge fade works edge-to-edge {%- endcomment -%}
  <div class="cc-viewport-{{ section.id }}" id="cc-viewport-{{ section.id }}">

    {%- if s.show_arrows -%}
      <button type="button" class="cc-arrow-{{ section.id }} cc-arrow-{{ section.id }}--prev" id="cc-prev-{{ section.id }}" aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
      </button>
      <button type="button" class="cc-arrow-{{ section.id }} cc-arrow-{{ section.id }}--next" id="cc-next-{{ section.id }}" aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    {%- endif -%}

    <div class="cc-scroller-{{ section.id }}" id="cc-scroller-{{ section.id }}">
    <div class="cc-track-{{ section.id }}" id="cc-track-{{ section.id }}">

      {%- comment -%} Copy 1 (real blocks) {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <a class="cc-item-{{ section.id }}" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
            <div class="cc-circle-{{ section.id }}">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | img_url: '600x600' }}" alt="{{ block.settings.image.alt | default: block.settings.label | escape }}" loading="lazy" width="{{ s.circle_size }}" height="{{ s.circle_size }}">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            {%- if block.settings.label != blank -%}
              <span class="cc-label-{{ section.id }}">{{ block.settings.label }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Copy 2 (clone for the seamless loop; hidden from a11y) {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <a class="cc-item-{{ section.id }}" href="{{ block.settings.link | default: '#' }}" aria-hidden="true" tabindex="-1">
            <div class="cc-circle-{{ section.id }}">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | img_url: '600x600' }}" alt="" loading="lazy" width="{{ s.circle_size }}" height="{{ s.circle_size }}">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            {%- if block.settings.label != blank -%}
              <span class="cc-label-{{ section.id }}">{{ block.settings.label }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>
    </div>
  </div>

</div>

<script>
(function () {
  'use strict';
  var SID      = '{{ section.id }}';
  var AUTOPLAY = {{ s.enable_autoplay | default: true, allow_false: true }};
  var DRAG     = {{ s.enable_drag | default: true, allow_false: true }};
  var PAUSE_HOVER = {{ s.pause_on_hover | default: true, allow_false: true }};
  var DIR      = {{ dir_num }};
  var DURATION = {{ s.marquee_speed }};

  var viewport = document.getElementById('cc-viewport-' + SID);
  var scroller = document.getElementById('cc-scroller-' + SID);
  var track    = document.getElementById('cc-track-' + SID);
  if (!scroller || !track) return;

  var oneCopy = 0;
  function measure() { oneCopy = track.scrollWidth / 2; }
  measure();
  window.addEventListener('resize', function () { measure(); }, { passive: true });
  window.addEventListener('load', function () { measure(); }, { passive: true });

  if (DIR < 0) { scroller.scrollLeft = oneCopy; }

  function normalize() {
    if (oneCopy <= 0) return;
    if (scroller.scrollLeft >= oneCopy) { scroller.scrollLeft -= oneCopy; }
    else if (scroller.scrollLeft < 0)   { scroller.scrollLeft += oneCopy; }
  }

  var paused = false, isDown = false, idle = null, last = null;
  var pos = scroller.scrollLeft;
  function syncPos() { pos = scroller.scrollLeft; }
  function pause()  { paused = true; }
  function resumeSoon() { clearTimeout(idle); idle = setTimeout(function () { syncPos(); paused = false; last = null; }, 1200); }

  /* Auto-scroll loop — accumulate position as a float so sub-pixel speeds still
     advance on mobile, where scrollLeft is integer-quantised (adding 0.4px/frame
     would otherwise round back to 0 forever). */
  function frame(ts) {
    if (last == null) last = ts;
    var dt = ts - last; last = ts;
    if (dt > 100) dt = 16; /* tab was inactive — avoid a big jump */
    if (AUTOPLAY && !paused && !isDown && oneCopy > 0) {
      var pxPerMs = oneCopy / (DURATION * 1000);
      pos += DIR * pxPerMs * dt;
      if (pos >= oneCopy) { pos -= oneCopy; }
      else if (pos < 0)   { pos += oneCopy; }
      scroller.scrollLeft = pos;
    }
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);

  /* Pause on hover — only on real hover devices (NOT touch, where mouseenter
     fires without a matching mouseleave and would pause autoplay forever) */
  var canHover = window.matchMedia && window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  if (PAUSE_HOVER && canHover) {
    viewport.addEventListener('mouseenter', pause);
    viewport.addEventListener('mouseleave', function () { if (!isDown) { syncPos(); paused = false; last = null; } });
  }

  /* Manual drag — MOUSE/PEN only (touch uses native scroll so taps open links).
     No pointer-capture, so a real click still reaches the <a>. */
  if (DRAG) {
    var startX = 0, startSL = 0, moved = false;
    scroller.addEventListener('pointerdown', function (e) {
      if (e.pointerType === 'touch') return;            /* let native touch scroll + tap-to-link work */
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      isDown = true; moved = false; startX = e.clientX; startSL = scroller.scrollLeft;
    });
    window.addEventListener('pointermove', function (e) {
      if (!isDown) return;
      var d = e.clientX - startX;
      if (Math.abs(d) > 8) { moved = true; scroller.classList.add('is-dragging'); }
      if (moved) { scroller.scrollLeft = startSL - d; normalize(); }
    });
    function up() { if (!isDown) return; isDown = false; scroller.classList.remove('is-dragging'); resumeSoon(); }
    window.addEventListener('pointerup', up);
    window.addEventListener('pointercancel', up);
    /* only swallow the click if it was an actual drag */
    scroller.addEventListener('click', function (e) { if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; } }, true);
  }

  /* Native touch swipe + trackpad: pause auto, wrap, resume */
  scroller.addEventListener('touchstart', pause, { passive: true });
  scroller.addEventListener('touchend', function () { isDown = false; scroller.classList.remove('is-dragging'); resumeSoon(); }, { passive: true });
  scroller.addEventListener('wheel', function () { pause(); resumeSoon(); }, { passive: true });
  scroller.addEventListener('scroll', function () { if (!AUTOPLAY || paused || isDown) normalize(); }, { passive: true });

  /* Arrows */
  var prev = document.getElementById('cc-prev-' + SID);
  var next = document.getElementById('cc-next-' + SID);
  function step() { return Math.max(160, scroller.clientWidth * 0.8); }
  function nudge(d) {
    pause();
    scroller.scrollBy({ left: d, behavior: 'smooth' });
    setTimeout(normalize, 450);
    resumeSoon();
  }
  if (prev) prev.addEventListener('click', function () { nudge(-step()); });
  if (next) next.addEventListener('click', function () { nudge(step()); });

  document.addEventListener('visibilitychange', function () { if (document.hidden) { paused = true; } else { syncPos(); paused = false; last = null; } });
})();
</script>

{% schema %}
{
  "name": "Category Circles Slider",
  "tag": "section",
  "class": "section-category-circles",
  "max_blocks": 20,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text",         "id": "label", "label": "Label", "default": "Category" },
        { "type": "url",          "id": "link",  "label": "Link" }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "Season Collection" },
    {
      "type": "select", "id": "heading_align", "label": "Alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "heading_spacing", "label": "Letter spacing", "min": 0, "max": 20, "step": 1, "unit": "em", "default": 0, "info": "Divided by 100" },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#111111" },
    { "type": "range", "id": "heading_gap", "label": "Gap below heading", "min": 16, "max": 80, "step": 4, "unit": "px", "default": 36 },

    { "type": "header", "content": "Heading underline" },
    { "type": "checkbox", "id": "show_underline", "label": "Show underline", "default": true },
    { "type": "color", "id": "underline_color", "label": "Underline colour", "default": "#c47a5a" },
    { "type": "range", "id": "underline_width", "label": "Underline width", "min": 20, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "underline_height", "label": "Underline thickness", "min": 1, "max": 8, "step": 1, "unit": "px", "default": 3 },
    { "type": "range", "id": "underline_gap", "label": "Gap above underline", "min": 4, "max": 24, "step": 2, "unit": "px", "default": 10 },

    { "type": "header", "content": "Carousel (infinite scroll)" },
    { "type": "checkbox", "id": "enable_autoplay", "label": "Auto-scroll (continuous)", "default": true, "info": "Turn off to make it a manual slider (drag / arrows only)." },
    { "type": "range", "id": "marquee_speed", "label": "Scroll speed (seconds per loop)", "min": 10, "max": 120, "step": 5, "unit": "s", "default": 40, "info": "Higher = slower. Speed scales with how many items you have." },
    {
      "type": "select", "id": "marquee_direction", "label": "Scroll direction",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "checkbox", "id": "pause_on_hover", "label": "Pause on hover", "default": true },
    { "type": "checkbox", "id": "enable_drag", "label": "Allow drag / swipe", "default": true },
    { "type": "checkbox", "id": "show_arrows", "label": "Show prev / next arrows", "default": false },
    { "type": "range", "id": "arrow_size", "label": "Arrow size", "min": 28, "max": 64, "step": 2, "unit": "px", "default": 40 },
    { "type": "color", "id": "arrow_bg", "label": "Arrow background", "default": "#ffffff" },
    { "type": "color", "id": "arrow_color", "label": "Arrow icon colour", "default": "#111111" },
    { "type": "range", "id": "item_gap", "label": "Gap between items (desktop)", "min": 8, "max": 60, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "slider_pad_y", "label": "Carousel top/bottom padding", "min": 0, "max": 60, "step": 4, "unit": "px", "default": 12 },
    { "type": "range", "id": "edge_fade", "label": "Edge fade width", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40, "info": "Fades items at the left and right edges into the background" },

    { "type": "header", "content": "Circles" },
    { "type": "range", "id": "circle_size", "label": "Circle diameter (desktop)", "min": 80, "max": 280, "step": 4, "unit": "px", "default": 188 },
    { "type": "range", "id": "image_padding", "label": "Image inner padding", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 20, "info": "Space between the image and the circle edge" },
    { "type": "color", "id": "circle_bg", "label": "Circle background", "default": "#f5f5f5" },
    { "type": "range", "id": "circle_border_width", "label": "Border thickness", "min": 0, "max": 6, "step": 1, "unit": "px", "default": 1 },
    { "type": "color", "id": "circle_border_color", "label": "Border colour", "default": "#e8e8e8" },
    { "type": "color", "id": "circle_border_hover", "label": "Border colour — hover", "default": "#bbbbbb" },

    { "type": "header", "content": "Image hover animation" },
    { "type": "range", "id": "hover_rotate", "label": "Rotation on hover", "min": -45, "max": 45, "step": 1, "unit": "°", "default": -15 },
    { "type": "range", "id": "hover_scale", "label": "Scale on hover", "min": 80, "max": 130, "step": 2, "unit": "%", "default": 110 },

    { "type": "header", "content": "Label" },
    { "type": "range", "id": "label_size", "label": "Label font size (desktop)", "min": 11, "max": 22, "step": 1, "unit": "px", "default": 14 },
    {
      "type": "select", "id": "label_weight", "label": "Label weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select", "id": "label_transform", "label": "Label case",
      "options": [
        { "value": "none",       "label": "As typed" },
        { "value": "uppercase",  "label": "UPPERCASE" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    { "type": "range", "id": "label_spacing", "label": "Label letter spacing", "min": 0, "max": 20, "step": 1, "unit": "em", "default": 0, "info": "Divided by 100" },
    { "type": "color", "id": "label_color", "label": "Label colour", "default": "#111111" },
    { "type": "color", "id": "label_hover_color", "label": "Label colour — hover", "default": "#555555" },
    { "type": "range", "id": "label_gap", "label": "Gap between circle and label", "min": 4, "max": 32, "step": 2, "unit": "px", "default": 14 },

    { "type": "header", "content": "📱 Mobile" },
