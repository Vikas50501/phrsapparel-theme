{% style %}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }

  #shopify-section-{{ section.id }} .words-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_horizontal }}px;
    padding-right: {{ section.settings.padding_horizontal }}px;
  }

  #shopify-section-{{ section.id }} .words-section__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    text-align: {{ section.settings.text_align }};
  }

  #shopify-section-{{ section.id }} .text-eyebrow {
    color: {{ section.settings.eyebrow_color }};
    font-size: {{ section.settings.eyebrow_font_size }}px;
    letter-spacing: {{ section.settings.eyebrow_letter_spacing }}em;
    text-transform: {{ section.settings.eyebrow_transform }};
    font-weight: {{ section.settings.eyebrow_font_weight }};
    margin: 0 0 {{ section.settings.eyebrow_margin_bottom }}px;
    font-family: {{ section.settings.eyebrow_font_family }}, sans-serif;
  }

  #shopify-section-{{ section.id }} .quote {
    color: {{ section.settings.quote_color }};
    font-size: {{ section.settings.quote_font_size }}px;
    line-height: {{ section.settings.quote_line_height }};
    font-family: {{ section.settings.quote_font_family }}, serif;
    font-weight: {{ section.settings.quote_font_weight }};
    letter-spacing: {{ section.settings.quote_tracking }}em;
  }

  #shopify-section-{{ section.id }} .quote em {
    font-style: italic;
    color: {{ section.settings.quote_em_color }};
  }

  {%- if section.settings.custom_css != blank -%}
    {{ section.settings.custom_css }}
  {%- endif -%}
{% endstyle %}

<section class="words-section">
  <div class="words-section__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="text-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.quote != blank -%}
      <div class="quote">{{ section.settings.quote }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Quote Banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "For those who understand"
    },
    {
      "type": "richtext",
      "id": "quote",
      "label": "Quote text",
      "default": "<p>True presence doesn't demand attention. It is felt. Remembered. <em>Recognized.</em></p>"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#141414"
    },
    {
      "type": "header",
      "content": "Eyebrow Style"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#888888"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "label": "Eyebrow font size (px)",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 11
    },
    {
      "type": "range",
      "id": "eyebrow_letter_spacing",
      "label": "Eyebrow letter spacing (em)",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "select",
      "id": "eyebrow_transform",
      "label": "Eyebrow text transform",
      "options": [
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" },
        { "value": "none", "label": "None" }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "eyebrow_font_weight",
      "label": "Eyebrow font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" }
      ],
      "default": "400"
    },
    {
      "type": "text",
      "id": "eyebrow_font_family",
      "label": "Eyebrow font family",
      "default": "Helvetica Neue"
    },
    {
      "type": "range",
      "id": "eyebrow_margin_bottom",
      "label": "Eyebrow bottom margin (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 20
    },
    {
      "type": "header",
      "content": "Quote Style"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Quote text color",
      "default": "#f0ece4"
    },
    {
      "type": "color",
      "id": "quote_em_color",
      "label": "Italic (em) text color",
      "default": "#f0ece4"
    },
    {
      "type": "range",
      "id": "quote_font_size",
      "label": "Quote font size (px)",
      "min": 16,
      "max": 72,
      "step": 2,
      "default": 32
    },
    {
      "type": "range",
      "id": "quote_line_height",
      "label": "Quote line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.4
    },
    {
      "type": "range",
      "id": "quote_tracking",
      "label": "Quote letter spacing (em)",
      "min": -0.1,
      "max": 0.2,
      "step": 0.1,
      "default": 0.0
    },
    {
      "type": "select",
      "id": "quote_font_weight",
      "label": "Quote font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "400"
    },
    {
      "type": "text",
      "id": "quote_font_family",
      "label": "Quote font family",
      "default": "Cormorant Garamond"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width (px)",
      "min": 400,
      "max": 1400,
      "step": 20,
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS"
    }
  ],
  "presets": [
    { "name": "Quote Banner" }
  ]
}
{% endschema %}