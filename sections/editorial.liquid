{% style %}
  #shopify-section-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ section.settings.section_bg_color }};
  }

  #shopify-section-{{ section.id }} .editorial-bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: {{ section.settings.bg_image_position }};
    background-repeat: no-repeat;
    {% if section.settings.bg_image != blank %}
      background-image: url({{ section.settings.bg_image | image_url: width: 1920 }});
    {% endif %}
  }

  #shopify-section-{{ section.id }} .editorial-bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    mix-blend-mode: {{ section.settings.overlay_blend_mode }};
  }

  {% if section.settings.use_bg_noise %}
  #shopify-section-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.04;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }
  {% endif %}

  #shopify-section-{{ section.id }} .editorial-section__inner {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: {{ section.settings.layout_ratio }};
    align-items: center;
    gap: {{ section.settings.column_gap }}px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .editorial-section__image-wrap {
    position: relative;
    border-radius: {{ section.settings.image_border_radius }}px;
    overflow: hidden;
    {% if section.settings.image_shadow %}
      box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .editorial-section__image-wrap img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .editorial-section__content {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.content_gap }}px;
    text-align: {{ section.settings.text_align }};
  }

  {% if section.settings.text_align == 'center' %}
  #shopify-section-{{ section.id }} .editorial-section__content { align-items: center; }
  {% elsif section.settings.text_align == 'right' %}
  #shopify-section-{{ section.id }} .editorial-section__content { align-items: flex-end; }
  {% else %}
  #shopify-section-{{ section.id }} .editorial-section__content { align-items: flex-start; }
  {% endif %}

  #shopify-section-{{ section.id }} .editorial-eyebrow {
    font-family: {{ section.settings.eyebrow_font_family }};
    font-size: {{ section.settings.eyebrow_font_size }}px;
    letter-spacing: {{ section.settings.eyebrow_letter_spacing }};
    color: {{ section.settings.eyebrow_color }};
    text-transform: uppercase;
    font-weight: {{ section.settings.eyebrow_font_weight }};
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .editorial-heading {
    font-family: {{ section.settings.heading_font_family }};
    font-size: clamp({{ section.settings.heading_font_size_min }}px, {{ section.settings.heading_font_size_fluid }}vw, {{ section.settings.heading_font_size_max }}px);
    font-weight: {{ section.settings.heading_font_weight }};
    color: {{ section.settings.heading_color }};
    line-height: {{ section.settings.heading_line_height }};
    letter-spacing: {{ section.settings.heading_letter_spacing }};
  }

  #shopify-section-{{ section.id }} .editorial-heading__normal {
    color: {{ section.settings.heading_color }};
    display: block;
  }

  #shopify-section-{{ section.id }} .editorial-heading__italic {
    font-style: italic;
    color: {{ section.settings.heading_em_color }};
    display: block;
  }

  #shopify-section-{{ section.id }} .editorial-body {
    font-family: {{ section.settings.body_font_family }};
    font-size: {{ section.settings.body_font_size }}px;
    color: {{ section.settings.body_color }};
    line-height: {{ section.settings.body_line_height }};
    max-width: {{ section.settings.body_max_width }}px;
  }

  #shopify-section-{{ section.id }} .editorial-btn {
    display: inline-block;
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    font-family: {{ section.settings.btn_font_family }};
    font-size: {{ section.settings.btn_font_size }}px;
    font-weight: {{ section.settings.btn_font_weight }};
    letter-spacing: {{ section.settings.btn_letter_spacing }};
    text-transform: uppercase;
    text-decoration: none;
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    border: {{ section.settings.btn_border_width }}px solid {{ section.settings.btn_border_color }};
    border-radius: {{ section.settings.btn_border_radius }}px;
    transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .editorial-btn:hover {
    background-color: {{ section.settings.btn_hover_bg_color }};
    color: {{ section.settings.btn_hover_text_color }};
    border-color: {{ section.settings.btn_hover_border_color }};
  }

  @media screen and (max-width: {{ section.settings.mobile_breakpoint }}px) {
    #shopify-section-{{ section.id }} .editorial-section__inner {
      grid-template-columns: 1fr;
      padding-left: {{ section.settings.mobile_padding_x }}px;
      padding-right: {{ section.settings.mobile_padding_x }}px;
    }
    {% if section.settings.mobile_image_order == 'first' %}
    #shopify-section-{{ section.id }} .editorial-section__image-wrap { order: -1; }
    #shopify-section-{{ section.id }} .editorial-section__content { order: 1; }
    {% else %}
    #shopify-section-{{ section.id }} .editorial-section__image-wrap { order: 1; }
    #shopify-section-{{ section.id }} .editorial-section__content { order: -1; }
    {% endif %}
  }

  {{ section.settings.custom_css }}
{% endstyle %}

<section id="shopify-section-{{ section.id }}" class="editorial-section">

  {%- if section.settings.bg_image != blank -%}
    <div class="editorial-bg-image"></div>
  {%- endif -%}

  {%- if section.settings.show_overlay -%}
    <div class="editorial-bg-overlay"></div>
  {%- endif -%}

  <div class="editorial-section__inner">

    {%- if section.settings.image != blank -%}
      <div class="editorial-section__image-wrap">
        {{ section.settings.image | image_url: width: 900 | image_tag:
          alt: section.settings.image_alt,
          loading: 'lazy',
          sizes: '(min-width: 768px) 50vw, 100vw'
        }}
      </div>
    {%- endif -%}

    <div class="editorial-section__content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="editorial-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading_normal != blank or section.settings.heading_italic != blank -%}
        <div class="editorial-heading">
          {%- if section.settings.heading_normal != blank -%}
            <span class="editorial-heading__normal">{{ section.settings.heading_normal }}</span>
          {%- endif -%}
          {%- if section.settings.heading_italic != blank -%}
            <em class="editorial-heading__italic">{{ section.settings.heading_italic }}</em>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <p class="editorial-body">{{ section.settings.body_text }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url | default: '/pages/story' }}" class="editorial-btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
