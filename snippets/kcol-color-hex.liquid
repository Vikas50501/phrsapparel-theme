{%- comment -%}
  Maps a colour name to a hex value for collection-page swatches.
  Usage: {% render 'kcol-color-hex', color: value %}
{%- endcomment -%}
{%- liquid
  assign c = color | downcase | strip
  assign hex = '#cccccc'
  if c contains 'black' or c contains 'jet' or c contains 'onyx'
    assign hex = '#111111'
  elsif c contains 'white' or c contains 'pearl' or c contains 'snow'
    assign hex = '#f2f2f2'
  elsif c contains 'ivory' or c contains 'cream'
    assign hex = '#f5f0e6'
  elsif c contains 'navy'
    assign hex = '#1a237e'
  elsif c contains 'sky' or c contains 'light blue'
    assign hex = '#6db3f2'
  elsif c contains 'blue'
    assign hex = '#2f5fd0'
  elsif c contains 'teal' or c contains 'aqua' or c contains 'cyan'
    assign hex = '#008c8c'
  elsif c contains 'olive'
    assign hex = '#6b8e23'
  elsif c contains 'lime'
    assign hex = '#9acd32'
  elsif c contains 'green'
    assign hex = '#2e7d32'
  elsif c contains 'gold'
    assign hex = '#d4af37'
  elsif c contains 'yellow'
    assign hex = '#f1c40f'
  elsif c contains 'orange'
    assign hex = '#e67e22'
  elsif c contains 'maroon' or c contains 'burgundy' or c contains 'wine'
    assign hex = '#800020'
  elsif c contains 'red'
    assign hex = '#c0392b'
  elsif c contains 'pink' or c contains 'rose'
    assign hex = '#e84393'
  elsif c contains 'purple' or c contains 'violet' or c contains 'lavender'
    assign hex = '#7b1fa2'
  elsif c contains 'brown' or c contains 'chocolate' or c contains 'coffee'
    assign hex = '#795548'
  elsif c contains 'beige' or c contains 'sand' or c contains 'tan' or c contains 'khaki' or c contains 'camel'
    assign hex = '#c2a878'
  elsif c contains 'charcoal'
    assign hex = '#36454f'
  elsif c contains 'silver'
    assign hex = '#c0c0c0'
  elsif c contains 'grey' or c contains 'gray'
    assign hex = '#9aa0a6'
  endif
  echo hex
-%}
