{%- comment -%}
  PHARELIGIONS product card — shared by the collection page (main-collection-product)
  and the Top Selling section (top-selling). Styling lives in collection-page.css
  under the .template-collection scope, so the host must include that stylesheet
  and wrap this card in an element with class "template-collection".

  Accepts:
  - product:      {Product} required
  - max_swatches: {Number} optional, default 6
{%- endcomment -%}
{%- liquid
  assign max_swatches = max_swatches | default: 6
  assign is_new = false
  if product.tags contains 'New' or product.tags contains 'new'
    assign is_new = true
  endif
  assign default_img = product.featured_image | image_url: width: 600
-%}
<div class="kc-card"{% if block %} {{ block.shopify_attributes }}{% endif %}>
  <div class="kc-card__media">
    <a href="{{ product.url }}" class="kc-card__media-link" aria-label="{{ product.title | escape }}">
      {%- if product.featured_image != blank -%}
        <img class="kc-card__img" data-default="{{ default_img }}" src="{{ default_img }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </a>
    {%- liquid
      assign kc_badge_disc = 0
      if product.compare_at_price > product.price
        assign kc_badge_disc = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round
      endif
    -%}
    <div class="kc-card__badges">
      {%- if kc_badge_disc > 0 -%}<span class="kc-badge kc-badge--disc">{{ kc_badge_disc }}% OFF</span>{%- endif -%}
      {%- if is_new -%}<span class="kc-badge kc-badge--new">New</span>{%- endif -%}
      {%- unless product.available -%}<span class="kc-badge kc-badge--sold">Sold Out</span>{%- endunless -%}
    </div>

    {%- comment -%} Hover quick actions {%- endcomment -%}
    <div class="kc-card__actions">
      <a class="kc-card__action" href="{{ product.url }}" title="View product" aria-label="View {{ product.title | escape }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1.5 12S5 5 12 5s10.5 7 10.5 7-3.5 7-10.5 7S1.5 12 1.5 12z"/><circle cx="12" cy="12" r="3"/></svg>
      </a>
      {%- if product.available -%}
        {%- if product.has_only_default_variant -%}
          <button type="button" class="kc-card__action kc-card__atc" data-variant="{{ product.selected_or_first_available_variant.id }}" title="Add to cart" aria-label="Add {{ product.title | escape }} to cart">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          </button>
        {%- else -%}
          <a class="kc-card__action" href="{{ product.url }}" title="Choose options" aria-label="Choose options for {{ product.title | escape }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- comment -%} Size options on hover (only if product has a Size option) {%- endcomment -%}
    {%- for option in product.options_with_values -%}
      {%- assign on = option.name | downcase -%}
      {%- if on contains 'size' -%}
        <div class="kc-card__sizes">
          {%- for value in option.values -%}
            <a class="kc-card__size" href="{{ product.url }}">{{ value }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="kc-card__info">
    {%- assign rating = product.metafields.reviews.rating.value -%}
    {%- if rating != blank -%}
      {%- assign r = rating.rating | round -%}
      <div class="kc-card__stars" aria-label="Rated {{ r }} out of 5">
        {%- for i in (1..5) -%}<span class="{% if i <= r %}is-on{% endif %}">&#9733;</span>{%- endfor -%}
      </div>
    {%- endif -%}
    <a href="{{ product.url }}" class="kc-card__title">{{ product.title }}</a>
    <div class="kc-card__price">
      {%- if product.compare_at_price > product.price -%}
        <span class="kc-on-sale">{{ product.price | money }}</span> <s>{{ product.compare_at_price | money }}</s>
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </div>
    {%- comment -%} Variant colour swatches — hover/click changes the card image {%- endcomment -%}
    {%- for option in product.options_with_values -%}
      {%- assign on = option.name | downcase -%}
      {%- if on contains 'color' or on contains 'colour' -%}
        <div class="kc-card__swatches">
          {%- for value in option.values limit: max_swatches -%}
            {%- capture cdot %}{% render 'kcol-color-hex', color: value %}{% endcapture -%}
            {%- comment -%} find this colour's variant image {%- endcomment -%}
            {%- assign sw_img = '' -%}
            {%- for variant in product.variants -%}
              {%- case option.position -%}
                {%- when 1 -%}{%- assign vopt = variant.option1 -%}
                {%- when 2 -%}{%- assign vopt = variant.option2 -%}
                {%- when 3 -%}{%- assign vopt = variant.option3 -%}
              {%- endcase -%}
              {%- if vopt == value and variant.image != blank -%}{%- assign sw_img = variant.image | image_url: width: 600 -%}{%- break -%}{%- endif -%}
            {%- endfor -%}
            <span class="kc-card__swatch{% if forloop.first %} is-active{% endif %}" data-img="{{ sw_img }}"
              {%- if value.swatch.image -%}
                style="background-image:url('{{ value.swatch.image | image_url: width: 40 }}'); background-size:cover; background-position:center;"
              {%- elsif value.swatch.color -%}
                style="background-color: {{ value.swatch.color }};"
              {%- else -%}
                style="background-color: {{ cdot | strip }};"
              {%- endif -%}
              title="{{ value }}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
