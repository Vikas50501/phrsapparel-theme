{%- comment -%}
  AUTO IP CURRENCY CONVERTER + premium country/currency selector (PHARELIGIONS)
  - Auto-detects visitor country by IP, converts displayed prices with LIVE rates
  - Renders a selector into every <div class="acc-mount"></div> (header + footer)
  - All countries incl. Nigeria (NGN); remembers choice; re-converts on variant/cart changes
  - Display-only conversion (checkout stays in store base currency — Shopify limitation)
{%- endcomment -%}

<style>
  /* ── Trigger pill (sits on dark header/footer) ── */
  .acc-selector { position: relative; display: inline-flex; font-family: inherit; line-height: 1; max-width: 100%; }
  .acc-trigger {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: transparent;
    border: 0;
    color: rgb(var(--color-foreground, 255 255 255));
    padding: 7px 10px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease, opacity 0.2s ease;
  }
  .acc-trigger:hover { background: rgba(var(--color-foreground, 255 255 255), 0.08); }
  .acc-trigger:focus-visible { outline: 2px solid rgba(var(--color-foreground, 255 255 255), 0.6); outline-offset: 2px; }
  /* flag image — renders on every OS (emoji flags don't show on Windows) */
  .acc-flag {
    display: inline-block; width: 22px; height: 16px; flex-shrink: 0;
    border-radius: 3px; object-fit: cover; box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
    background: rgba(127,127,127,0.15);
  }
  .acc-trigger .acc-label { overflow: hidden; text-overflow: ellipsis; }
  .acc-trigger .acc-caret { width: 12px; height: 12px; flex-shrink: 0; transition: transform 0.2s ease; opacity: 0.7; }
  .acc-selector.is-open .acc-trigger .acc-caret { transform: rotate(180deg); }

  /* ── Dropdown ── */
  .acc-menu {
    position: absolute;
    z-index: 1000;
    width: 300px;
    max-width: calc(100vw - 24px);
    background: #ffffff;
    color: #111111;
    border-radius: 14px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.28);
    overflow: hidden;
    display: none;
    flex-direction: column;
    max-height: min(60vh, 420px);
    font-family: inherit;
  }
  .acc-menu.is-open { display: flex; animation: accFade 0.18s ease-out; }
  @keyframes accFade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .acc-menu[data-dir="down"] { top: calc(100% + 10px); }
  .acc-menu[data-dir="up"]   { bottom: calc(100% + 10px); }
  .acc-menu[data-align="right"] { right: 0; }
  .acc-menu[data-align="left"]  { left: 0; }

  .acc-search { position: sticky; top: 0; background: #fff; padding: 12px; border-bottom: 1px solid #eee; }
  .acc-search input {
    width: 100%; box-sizing: border-box;
    padding: 10px 12px; border: 1px solid #e2e2e2; border-radius: 9px;
    font-size: 14px; font-family: inherit; outline: none; color: #111;
  }
  .acc-search input:focus { border-color: #111; }

  .acc-list { overflow-y: auto; padding: 6px; scrollbar-width: thin; -webkit-overflow-scrolling: touch; }
  .acc-option {
    display: flex; align-items: center; gap: 11px;
    padding: 10px; border-radius: 8px;
    cursor: pointer; font-size: 13.5px; color: #222;
  }
  .acc-option:hover { background: #f4f4f4; }
  .acc-option.is-active { background: #111; color: #fff; }
  .acc-option .acc-name { flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .acc-option .acc-cc { font-size: 12px; color: #999; font-variant-numeric: tabular-nums; }
  .acc-option.is-active .acc-cc { color: rgba(255,255,255,0.7); }
  .acc-empty { padding: 18px; text-align: center; color: #888; font-size: 13px; }

  /* ── Header: keep the full label on desktop, compact on small screens ── */
  @media (max-width: 989px) { .acc-mount--header .acc-trigger .acc-country { display: none; } }

  /* ── Footer: full width, comfortable tap target ── */
  .acc-mount--footer { display: block; width: 100%; }
  .acc-mount--footer .acc-selector { width: auto; }
  .acc-mount--footer .acc-trigger { padding-left: 0; }
  .acc-mount--footer .acc-trigger:hover { background: transparent; opacity: 0.7; }

  /* ── Mobile burger-menu variant: full-width row, opens upward, wide menu ── */
  .acc-mount--drawer { display: block; width: 100%; padding: 4px 0; }
  .acc-mount--drawer .acc-selector { width: 100%; }
  .acc-mount--drawer .acc-trigger {
    width: 100%; justify-content: flex-start; gap: 12px;
    padding: 14px 4px; font-size: 16px; border-radius: 10px;
  }
  .acc-mount--drawer .acc-trigger .acc-caret { margin-left: auto; }
  /* in-flow dropdown so the drawer's own scroll handles it (no clipping) */
  .acc-mount--drawer .acc-menu {
    position: static; width: 100%; max-width: 100%; margin-top: 8px;
    box-shadow: none; border: 1px solid #e6e6e6; max-height: 320px;
  }

  /* On phones the header pill is hidden (selector lives in the burger menu);
     menus never overflow the viewport. */
  @media (max-width: 749px) {
    .acc-menu { width: min(320px, calc(100vw - 24px)); }
  }

  @media (prefers-reduced-motion: reduce) { .acc-menu.is-open { animation: none; } }
</style>

<script>
(function () {
  'use strict';

  var BASE = {{ cart.currency.iso_code | json }} || 'AED';

  var COUNTRY_CURRENCY = {
    AF:'AFN',AL:'ALL',DZ:'DZD',AD:'EUR',AO:'AOA',AG:'XCD',AR:'ARS',AM:'AMD',AU:'AUD',AT:'EUR',AZ:'AZN',
    BS:'BSD',BH:'BHD',BD:'BDT',BB:'BBD',BY:'BYN',BE:'EUR',BZ:'BZD',BJ:'XOF',BT:'BTN',BO:'BOB',BA:'BAM',
    BW:'BWP',BR:'BRL',BN:'BND',BG:'BGN',BF:'XOF',BI:'BIF',KH:'KHR',CM:'XAF',CA:'CAD',CV:'CVE',CF:'XAF',
    TD:'XAF',CL:'CLP',CN:'CNY',CO:'COP',KM:'KMF',CG:'XAF',CD:'CDF',CR:'CRC',HR:'EUR',CU:'CUP',CY:'EUR',
    CZ:'CZK',DK:'DKK',DJ:'DJF',DM:'XCD',DO:'DOP',EC:'USD',EG:'EGP',SV:'USD',GQ:'XAF',ER:'ERN',EE:'EUR',
    SZ:'SZL',ET:'ETB',FJ:'FJD',FI:'EUR',FR:'EUR',GA:'XAF',GM:'GMD',GE:'GEL',DE:'EUR',GH:'GHS',GR:'EUR',
    GD:'XCD',GT:'GTQ',GN:'GNF',GW:'XOF',GY:'GYD',HT:'HTG',HN:'HNL',HK:'HKD',HU:'HUF',IS:'ISK',IN:'INR',
    ID:'IDR',IR:'IRR',IQ:'IQD',IE:'EUR',IL:'ILS',IT:'EUR',JM:'JMD',JP:'JPY',JO:'JOD',KZ:'KZT',KE:'KES',
    KI:'AUD',KP:'KPW',KR:'KRW',KW:'KWD',KG:'KGS',LA:'LAK',LV:'EUR',LB:'LBP',LS:'LSL',LR:'LRD',LY:'LYD',
    LI:'CHF',LT:'EUR',LU:'EUR',MO:'MOP',MG:'MGA',MW:'MWK',MY:'MYR',MV:'MVR',ML:'XOF',MT:'EUR',MH:'USD',
    MR:'MRU',MU:'MUR',MX:'MXN',FM:'USD',MD:'MDL',MC:'EUR',MN:'MNT',ME:'EUR',MA:'MAD',MZ:'MZN',MM:'MMK',
    NA:'NAD',NR:'AUD',NP:'NPR',NL:'EUR',NZ:'NZD',NI:'NIO',NE:'XOF',NG:'NGN',MK:'MKD',NO:'NOK',OM:'OMR',
    PK:'PKR',PW:'USD',PA:'PAB',PG:'PGK',PY:'PYG',PE:'PEN',PH:'PHP',PL:'PLN',PT:'EUR',QA:'QAR',RO:'RON',
    RU:'RUB',RW:'RWF',KN:'XCD',LC:'XCD',VC:'XCD',WS:'WST',SM:'EUR',ST:'STN',SA:'SAR',SN:'XOF',RS:'RSD',
    SC:'SCR',SL:'SLL',SG:'SGD',SK:'EUR',SI:'EUR',SB:'SBD',SO:'SOS',ZA:'ZAR',SS:'SSP',ES:'EUR',LK:'LKR',
    SD:'SDG',SR:'SRD',SE:'SEK',CH:'CHF',SY:'SYP',TW:'TWD',TJ:'TJS',TZ:'TZS',TH:'THB',TL:'USD',TG:'XOF',
    TO:'TOP',TT:'TTD',TN:'TND',TR:'TRY',TM:'TMT',TV:'AUD',UG:'UGX',UA:'UAH',AE:'AED',GB:'GBP',US:'USD',
    UY:'UYU',UZ:'UZS',VU:'VUV',VE:'VES',VN:'VND',YE:'YER',ZM:'ZMW',ZW:'ZWL'
  };
  var SYM = {
    USD:'$',EUR:'€',GBP:'£',JPY:'¥',CNY:'¥',INR:'₹',KRW:'₩',BRL:'R$',AUD:'A$',CAD:'C$',CHF:'CHF',
    SEK:'kr',NOK:'kr',DKK:'kr',PLN:'zł',CZK:'Kč',HUF:'Ft',RON:'lei',RUB:'₽',TRY:'₺',ZAR:'R',MXN:'MX$',
    SGD:'S$',HKD:'HK$',NZD:'NZ$',THB:'฿',MYR:'RM',PHP:'₱',IDR:'Rp',TWD:'NT$',AED:'د.إ',SAR:'﷼',QAR:'﷼',
    KWD:'د.ك',BHD:'BD',OMR:'﷼',JOD:'JD',EGP:'E£',PKR:'₨',BDT:'৳',LKR:'Rs',NPR:'Rs',NGN:'₦',GHS:'₵',
    KES:'KSh',TZS:'TSh',UGX:'USh',COP:'$',PEN:'S/',CLP:'$',ARS:'$',VND:'₫',MMK:'K',KHR:'៛',NAD:'N$'
  };
  var POPULAR = ['AE','US','GB','IN','SA','EU','CA','AU','NG','PK','BD','EG','SG','MY','ZA','DE','FR','JP','CN','BR','TR','PH','ID','TH','VN','KW','QA','BH','OM'];

  var regionNames = null;
  try { regionNames = new Intl.DisplayNames(['en'], { type: 'region' }); } catch (e) {}
  function countryName(cc) { try { return (regionNames && regionNames.of(cc)) || cc; } catch (e) { return cc; } }
  function flagURL(cc) { return (cc && cc.length === 2) ? 'https://flagcdn.com/' + cc.toLowerCase() + '.svg' : ''; }
  function curOf(cc) { return COUNTRY_CURRENCY[cc] || BASE; }

  var rates = {}, activeCountry = '', activeCurrency = BASE, stored = [], mounts = [];

  /* ── IP detection (fallback chain) ── */
  function detectCountry() {
    var apis = [
      { url: 'https://ipapi.co/json/', get: function (d) { return d.country_code; } },
      { url: 'https://ipwho.is/', get: function (d) { return d.country_code; } }
    ];
    return apis.reduce(function (p, api) {
      return p.then(function (cc) {
        if (cc) return cc;
        return fetch(api.url).then(function (r) { return r.json(); }).then(function (d) {
          var c = api.get(d); return (c && c.length === 2) ? c.toUpperCase() : null;
        }).catch(function () { return null; });
      });
    }, Promise.resolve(null));
  }

  /* ── Live exchange rates (cached 1h) ── */
  function fetchRates() {
    try {
      var c = JSON.parse(localStorage.getItem('acc_rates') || '{}');
      if (c.base === BASE && c.ts && (Date.now() - c.ts < 3600000)) return Promise.resolve(c.rates);
    } catch (e) {}
    return fetch('https://open.er-api.com/v6/latest/' + BASE)
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d && d.rates) { try { localStorage.setItem('acc_rates', JSON.stringify({ base: BASE, rates: d.rates, ts: Date.now() })); } catch (e) {} return d.rates; }
        return null;
      }).catch(function () { return null; });
  }

  /* ── Price conversion (per text-node, skips % badges) ──
     Target ONLY price-bearing leaf elements. Never use wrappers that also
     hold variant/option values (e.g. .product-option, .cart-item__price-wrapper),
     or sizes like "32" get converted into currency. */
  var SELECTORS = [
    '.cvc-money',                                          /* store money-format wrapper — every price, never options */
    '.kc-card__price', '.kc-on-sale',
    '.kushi-price-item--sale', '.kushi-price-item--regular',
    '.price-item--regular', '.price-item--sale', '.price-item--last',
    '.money', '.cart-fbt__price',
    '.cart-item__final-price', '.cart-item__old-price', '.totals__total-value'
  ].join(',');

  function parseNum(t) {
    /* Keep only digits + separators, then DROP any leading/trailing separators that
       come from the currency label itself (e.g. "Dhs." -> leading dot, "د.إ" -> trailing).
       Then: a final group of 1-2 digits after a separator is the decimal part;
       everything else is grouping. Handles "Dhs. 1,234.56", "1.234,56", "Rs. 470", etc. */
    var s = (t || '').replace(/[^\d.,]/g, '').replace(/^[.,]+/, '').replace(/[.,]+$/, '');
    if (!/\d/.test(s)) return null;
    var m = s.match(/^(.*)([.,])(\d{1,2})$/);
    var n = m ? parseFloat(m[1].replace(/[.,]/g, '') + '.' + m[3]) : parseFloat(s.replace(/[.,]/g, ''));
    return isNaN(n) ? null : n;
  }
  function fmt(amt, cur) {
    var zero = (cur === 'JPY' || cur === 'KRW' || cur === 'VND' || cur === 'IDR');
    try {
      return new Intl.NumberFormat(undefined, { style: 'currency', currency: cur, currencyDisplay: 'narrowSymbol', minimumFractionDigits: zero ? 0 : 2, maximumFractionDigits: zero ? 0 : 2 }).format(amt);
    } catch (e1) {
      try { return new Intl.NumberFormat(undefined, { style: 'currency', currency: cur, minimumFractionDigits: zero ? 0 : 2, maximumFractionDigits: zero ? 0 : 2 }).format(amt); }
      catch (e2) { return (SYM[cur] || cur + ' ') + amt.toFixed(zero ? 0 : 2); }
    }
  }
  var nodes = [], mo = null;   /* text nodes we've touched, with their base-currency originals */
  function setVal(node, v) { if (node.nodeValue !== v) node.nodeValue = v; }
  function convertNode(node, rate, cur) {
    var orig = node.__accOrig;
    if (orig === undefined) {
      var t = node.nodeValue;
      if (!/\d/.test(t) || t.indexOf('%') > -1) return;   /* skip non-prices & discount badges */
      node.__accOrig = orig = t;
      nodes.push(node);
    }
    if (cur === BASE) { setVal(node, orig); return; }
    var n = parseNum(orig);
    if (n === null || isNaN(n)) return;
    setVal(node, fmt(n * rate, cur));
  }
  function convert(cur) {
    if (mo) mo.disconnect();                               /* don't let our own writes retrigger the observer */
    try {
      if (cur === BASE) {
        nodes.forEach(function (nd) { if (nd.__accOrig !== undefined) setVal(nd, nd.__accOrig); });
      } else if (rates[cur]) {
        var rate = rates[cur];
        [].forEach.call(document.querySelectorAll(SELECTORS), function (el) {
          var w = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null, false), node;
          while ((node = w.nextNode())) { convertNode(node, rate, cur); }
        });
      }
    } finally {
      if (mo) mo.observe(document.body, { childList: true, subtree: true, characterData: true });
    }
  }

  /* ── State ── */
  function setCountry(cc, persist) {
    activeCountry = cc; activeCurrency = curOf(cc);
    if (persist !== false) { try { localStorage.setItem('acc_country', cc); } catch (e) {} }
    mounts.forEach(updateTrigger);
    convert(activeCurrency);
  }

  /* ── Selector UI (per mount) ── */
  function updateTrigger(m) {
    var fl = m.trigger.querySelector('.acc-flag'); fl.src = flagURL(activeCountry); fl.alt = activeCountry;
    m.trigger.querySelector('.acc-country').textContent = countryName(activeCountry);
    m.trigger.querySelector('.acc-cur').textContent = activeCurrency + ' ' + (SYM[activeCurrency] || '');
    var opts = m.menu.querySelectorAll('.acc-option');
    [].forEach.call(opts, function (o) { o.classList.toggle('is-active', o.getAttribute('data-cc') === activeCountry); });
  }

  function buildMenu(m) {
    var ccs = Object.keys(COUNTRY_CURRENCY);
    var ordered = POPULAR.filter(function (c) { return COUNTRY_CURRENCY[c]; })
      .concat(ccs.filter(function (c) { return POPULAR.indexOf(c) === -1; }).sort(function (a, b) { return countryName(a).localeCompare(countryName(b)); }));
    var html = '';
    ordered.forEach(function (cc) {
      var cur = curOf(cc);
      html += '<div class="acc-option" role="option" data-cc="' + cc + '" data-search="' + (countryName(cc) + ' ' + cur).toLowerCase() + '">' +
        '<img class="acc-flag" loading="lazy" src="' + flagURL(cc) + '" alt="">' +
        '<span class="acc-name">' + countryName(cc) + '</span>' +
        '<span class="acc-cc">' + cur + ' ' + (SYM[cur] || '') + '</span></div>';
    });
    m.list.innerHTML = html;
  }

  function positionMenu(m) {
    var r = m.trigger.getBoundingClientRect();
    m.menu.setAttribute('data-dir', (r.top > window.innerHeight / 2) ? 'up' : 'down');
    m.menu.setAttribute('data-align', (r.left > window.innerWidth / 2) ? 'right' : 'left');
  }

  function createSelector(host) {
    host.innerHTML = '';
    var sel = document.createElement('div'); sel.className = 'acc-selector';
    var trigger = document.createElement('button');
    trigger.type = 'button'; trigger.className = 'acc-trigger'; trigger.setAttribute('aria-haspopup', 'listbox'); trigger.setAttribute('aria-expanded', 'false');
    trigger.innerHTML = '<img class="acc-flag" alt=""><span class="acc-label"><span class="acc-country"></span> (<span class="acc-cur"></span>)</span>' +
      '<svg class="acc-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>';
    var menu = document.createElement('div'); menu.className = 'acc-menu'; menu.setAttribute('role', 'listbox');
    menu.innerHTML = '<div class="acc-search"><input type="text" placeholder="Search country or currency…" aria-label="Search"></div><div class="acc-list"></div>';
    sel.appendChild(trigger); sel.appendChild(menu); host.appendChild(sel);

    var m = { host: host, sel: sel, trigger: trigger, menu: menu, list: menu.querySelector('.acc-list') };
    mounts.push(m);
    buildMenu(m);

    function open() { positionMenu(m); sel.classList.add('is-open'); menu.classList.add('is-open'); trigger.setAttribute('aria-expanded', 'true'); var s = menu.querySelector('input'); if (s) { s.value = ''; filter(''); s.focus(); } }
    function close() { sel.classList.remove('is-open'); menu.classList.remove('is-open'); trigger.setAttribute('aria-expanded', 'false'); }
    function filter(q) {
      q = q.toLowerCase(); var any = false;
      [].forEach.call(m.list.querySelectorAll('.acc-option'), function (o) {
        var show = !q || o.getAttribute('data-search').indexOf(q) > -1; o.style.display = show ? '' : 'none'; if (show) any = true;
      });
      var empty = m.list.querySelector('.acc-empty'); if (!any && !empty) { var e = document.createElement('div'); e.className = 'acc-empty'; e.textContent = 'No matches'; m.list.appendChild(e); } else if (any && empty) { empty.remove(); }
    }

    trigger.addEventListener('click', function (e) { e.stopPropagation(); sel.classList.contains('is-open') ? close() : open(); });
    menu.addEventListener('click', function (e) { e.stopPropagation(); var opt = e.target.closest('.acc-option'); if (opt) { setCountry(opt.getAttribute('data-cc')); close(); } });
    menu.querySelector('input').addEventListener('input', function (e) { filter(e.target.value); });
    document.addEventListener('click', close);
    updateTrigger(m);
    return m;
  }

  /* ── Re-convert on dynamic price changes (variant/cart) ── */
  function observe() {
    if (mo) return;
    var t;
    mo = new MutationObserver(function () {
      if (activeCurrency === BASE) return;
      clearTimeout(t); t = setTimeout(function () { convert(activeCurrency); }, 300);
    });
    mo.observe(document.body, { childList: true, subtree: true, characterData: true });
  }

  function reconvertSoon() { [400, 1200, 2500].forEach(function (ms) { setTimeout(function () { if (activeCurrency !== BASE) convert(activeCurrency); }, ms); }); }

  function init() {
    var hosts = document.querySelectorAll('.acc-mount');
    if (!hosts.length) { console.warn('[currency] no .acc-mount found in DOM'); return; }
    window.ACC = { setCountry: setCountry, convert: function () { return convert(activeCurrency); }, get rates() { return rates; }, get active() { return activeCountry + '/' + activeCurrency; } };
    fetchRates().then(function (r) {
      rates = r || {};
      if (!r) console.warn('[currency] exchange-rate fetch failed — prices will stay in ' + BASE);
      [].forEach.call(hosts, createSelector);
      observe();
      /* 1) manual choice always wins (no expiry) */
      var saved = null; try { saved = localStorage.getItem('acc_country'); } catch (e) {}
      if (saved && COUNTRY_CURRENCY[saved]) { setCountry(saved, false); reconvertSoon(); return; }
      /* 2) cached geo (12h) — avoids hammering the IP API on every page view */
      var geo = null; try { var g = JSON.parse(localStorage.getItem('acc_geo') || '{}'); if (g.cc && g.ts && (Date.now() - g.ts < 43200000)) geo = g.cc; } catch (e) {}
      if (geo && COUNTRY_CURRENCY[geo]) { setCountry(geo, false); reconvertSoon(); return; }
      /* 3) detect once, then cache */
      detectCountry().then(function (cc) {
        if (cc && COUNTRY_CURRENCY[cc]) { try { localStorage.setItem('acc_geo', JSON.stringify({ cc: cc, ts: Date.now() })); } catch (e) {} setCountry(cc, false); }
        else { activeCountry = 'AE'; mounts.forEach(updateTrigger); }
        reconvertSoon();
      });
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init); else init();
})();
</script>
